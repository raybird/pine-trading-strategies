//@version=6
// TnSovereignPropFirmUltraV6 — TeleNexus PropFirm 主權超防禦策略 v2
// Author: TeleNexus (Raybird) — refactored from QuantAlgo propfirm-ultra-strategy
// Timezone: Asia/Taipei (CST)
// Version: v26.0604.0630
//
// 核心規訓:
// 1. PropFirm 三層防禦: 日虧限額 / 全局回撤 / 連損暫停 / 冷卻反報復
// 2. SMC 結構引擎: BOS/CHOCH/FVG/OB/Breaker/Inducement 完整譜系
// 3. 動態風險係數: 根據市場體質、DD 深度、恢復模式自動調整曝險
// 4. 主權評分系統: 0-20 分置信度閾值，體制感知自適應門檻

strategy("TN PropFirm Ultra [TeleNexus]",
     overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.cash,
     default_qty_value=1000,
     commission_type=strategy.commission.percent,
     commission_value=0.075,
     margin_long=1, margin_short=1,
     pyramiding=0,
     max_lines_count=200,
     max_labels_count=200,
     max_boxes_count=200)

// ── PropFirm 風控參數 ──────────────────────────────────────────────────────
grpProp = "🛡️ PROPFIRM PROTECTION"
dailyLossMax   = input.float(50.0,  "Daily Loss Max ($)",      group=grpProp)
globalDDMax    = input.float(200.0, "Global Drawdown Max ($)", group=grpProp)
dailyTarget    = input.float(100.0, "Daily Target ($)",        group=grpProp)
globalTarget   = input.float(500.0, "Global Target ($)",       group=grpProp)
riskPctInp     = input.float(0.004, "Risk per Trade (frac)",   group=grpProp, step=0.001)
maxTradesDay   = input.int(20,      "Max Trades/Day",          group=grpProp, minval=1)
maxConsecLoss  = input.int(3,       "Pause After X Losses",    group=grpProp, minval=1)
recoveryMult   = input.float(0.4,   "Recovery Risk Mult",     group=grpProp, step=0.1)
cooldownBars   = input.int(5,       "Cooldown Bars",           group=grpProp, minval=1)

// ── SMC 引擎參數 ────────────────────────────────────────────────────────────
grpSMC = "🏗️ SMC / ICT ENGINE"
bosLenInp   = input.int(10, "BOS Lookback",     group=grpSMC, minval=3)
fvgMinATR   = input.float(0.3, "FVG Min (xATR)", group=grpSMC, step=0.1)

// ── 過濾器 ───────────────────────────────────────────────────────────────────
grpFilter = "📊 FILTERS"
volMult     = input.float(1.2, "Vol Spike Mult", group=grpFilter, step=0.1)
minScoreInp = input.int(5,     "Min Score (base)", group=grpFilter, minval=2, maxval=14)
useKillzones = input.bool(true, "Killzones Only", group=grpFilter)

// ── 視覺 ─────────────────────────────────────────────────────────────────────
grpVis = "🎨 VISUALS"
showEMAs   = input.bool(true, "Show EMAs",  group=grpVis)
showLabels = input.bool(true, "Show Labels", group=grpVis)
showFVG    = input.bool(true, "Show FVG",   group=grpVis)
showOB     = input.bool(true, "Show OB",    group=grpVis)
showDash   = input.bool(true, "Show Dash",  group=grpVis)
showZones  = input.bool(true, "Show SL/TP", group=grpVis)

// ── 基礎指標 ─────────────────────────────────────────────────────────────────
emaF  = ta.ema(close, 9)
emaM  = ta.ema(close, 21)
emaS  = ta.ema(close, 50)
emaT  = ta.ema(close, 200)
atr14 = ta.atr(14)
atr50 = ta.atr(50)
avgVol = ta.sma(volume, 20)
rsi   = ta.rsi(close, 14)
[dp, dm, adx] = ta.dmi(14, 14)

// ── MTF Bias（反重繪）─────────────────────────────────────────────────────
htfE50  = request.security(syminfo.tickerid, "240", ta.ema(close[1], 50),  gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htfE200 = request.security(syminfo.tickerid, "240", ta.ema(close[1], 200), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
dlyE50  = request.security(syminfo.tickerid, "D",   ta.ema(close[1], 50),  gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
dlyE200 = request.security(syminfo.tickerid, "D",   ta.ema(close[1], 200), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htfBull = htfE50 > htfE200; htfBear = htfE50 < htfE200
dlyBull = dlyE50 > dlyE200; dlyBear = dlyE50 < dlyE200
mtfBullW = (dlyBull?1:0)+(htfBull?1:0)
mtfBearW = (dlyBear?1:0)+(htfBear?1:0)

// ── 市場體質 ─────────────────────────────────────────────────────────────────
atrRatio  = atr14 / atr50
isHighVol  = atrRatio > 1.5
isLowVol   = atrRatio < 0.7
isStrTrend = adx > 30
isMildTrend = adx > 20 and adx <= 30
isRanging   = adx <= 20
isCompressed = isLowVol and isRanging
atrChg    = atr14 / nz(atr14[3], atr14)
isNewsSpike = atrChg > 2.0
isDanger = isHighVol and isRanging

string regimeLabel = isNewsSpike ? "NEWS SPIKE" : isDanger ? "DANGER" : isCompressed ? "COMPRESSION" : isHighVol ? "HIGH VOL" : isStrTrend ? "STRONG TREND" : isMildTrend ? "TRENDING" : "RANGING"
bool isSafeMarket = not isDanger and not isCompressed

// ── 時段過濾（UTC）──────────────────────────────────────────────────────────
hUTC     = hour(time, "UTC")
isLondon = hUTC >= 7 and hUTC < 10
isNY     = hUTC >= 13 and hUTC < 16
isAsian  = hUTC >= 0 and hUTC < 4
isKZ    = isLondon or isNY
isSessionOK = useKillzones ? isKZ : true
sessBonus = isKZ ? 1 : 0

// ── SMC 結構檢測 ────────────────────────────────────────────────────────────
ph = ta.pivothigh(high, 5, 5)
pl = ta.pivotlow(low, 5, 5)
var float rPH = na; var float rPL = na
if not na(ph); rPH := ph
if not na(pl); rPL := pl

bullBOS  = not na(rPH) and close > rPH and close[1] <= rPH
bearBOS  = not na(rPL) and close < rPL and close[1] >= rPL

var int structDir = 0
if bullBOS; structDir := 1
if bearBOS; structDir := -1
bullCHOCH = bullBOS and structDir[1] == -1
bearCHOCH = bearBOS and structDir[1] == 1

bullSweep = not na(rPL) and low < rPL and close > rPL
bearSweep = not na(rPH) and high > rPH and close < rPH

bullFVG = low > high[2] and (low - high[2]) > atr14 * fvgMinATR
bearFVG = high < low[2] and (low[2] - high) > atr14 * fvgMinATR

bodyS = math.abs(close - open)
dispUp   = close > high[1] and bodyS > atr14 * 0.8 and close > open
dispDown = close < low[1] and bodyS > atr14 * 0.8 and close < open
bullOB = dispUp   and close[1] < open[1]
bearOB = dispDown and close[1] > open[1]

bullBreaker = bearBOS[1] and bullBOS
bearBreaker = bullBOS[1] and bearBOS

rangeMid = (rPH + rPL) / 2
isDiscount = not na(rangeMid) and close < rangeMid
isPremium  = not na(rangeMid) and close > rangeMid

bullInduce = not na(rPL) and low < rPL and close > rPL and open > rPL
bearInduce = not na(rPH) and high > rPH and close < rPH and open < rPH

volSpike = volume > avgVol * volMult
momF = ta.mom(close, 3); momS = ta.mom(close, 8)
bullMom = momF > 0 and momS > 0; bearMom = momF < 0 and momS < 0

bullPullback = close > emaM and low <= emaF and close > emaF and bullMom
bearPullback = close < emaM and high >= emaF and close < emaF and bearMom
emaStackBull = emaF > emaM and emaM > emaS and emaS > emaT
emaStackBear = emaF < emaM and emaM < emaS and emaS < emaT
bullCont = emaStackBull and momF > 0 and close > emaF and close[1] <= emaF
bearCont = emaStackBear and momF < 0 and close < emaF and close[1] >= emaF

// ── FVG / OB 視覺 ──────────────────────────────────────────────────────────
if showFVG and bullFVG
    box.new(bar_index-2, high[2], bar_index, low, bgcolor=color.new(#00E676,88), border_color=color.new(#00E676,100))
if showFVG and bearFVG
    box.new(bar_index-2, low[2], bar_index, high, bgcolor=color.new(#FF5252,88), border_color=color.new(#FF5252,100))
if showOB and bullOB
    box.new(bar_index-1, high[1], bar_index+5, low[1], bgcolor=color.new(#2196F3,87), border_color=color.new(#2196F3,50))
if showOB and bearOB
    box.new(bar_index-1, high[1], bar_index+5, low[1], bgcolor=color.new(#FF9800,87), border_color=color.new(#FF9800,50))

// ── 主權評分系統 (0-20) ──────────────────────────────────────────────────────
float tW = isStrTrend ? 1.5 : isMildTrend ? 1.2 : 1.0
float rW = isRanging  ? 1.5 : 1.0

float bScore = 0.0
bScore += bullBOS     ? 3.0*tW : 0; bScore += bullCHOCH   ? 2.5*tW : 0
bScore += bullSweep   ? 2.0 : 0;   bScore += bullFVG     ? 1.5*rW : 0
bScore += bullOB      ? 1.5*rW : 0; bScore += bullBreaker ? 2.0 : 0
bScore += bullInduce  ? 1.5 : 0;   bScore += volSpike    ? 1.0 : 0
bScore += bullMom     ? 1.0 : 0;   bScore += isDiscount  ? 1.0 : 0
bScore += bullPullback? 1.5 : 0;   bScore += bullCont    ? 1.5 : 0
bScore += mtfBullW + sessBonus + (emaStackBull?1.5:0)

float sScore = 0.0
sScore += bearBOS     ? 3.0*tW : 0; sScore += bearCHOCH   ? 2.5*tW : 0
sScore += bearSweep   ? 2.0 : 0;   sScore += bearFVG     ? 1.5*rW : 0
sScore += bearOB      ? 1.5*rW : 0; sScore += bearBreaker ? 2.0 : 0
sScore += bearInduce  ? 1.5 : 0;   sScore += volSpike    ? 1.0 : 0
sScore += bearMom     ? 1.0 : 0;   sScore += isPremium   ? 1.0 : 0
sScore += bearPullback? 1.5 : 0;   sScore += bearCont    ? 1.5 : 0
sScore += mtfBearW + sessBonus + (emaStackBear?1.5:0)

float thresh = isStrTrend ? minScoreInp*0.75 : isRanging ? minScoreInp*1.4 : isHighVol ? minScoreInp*1.2 : isDanger ? minScoreInp*1.6 : minScoreInp

bool htfLOK  = mtfBullW>=1 or (mtfBullW==0 and mtfBearW==0)
bool htfSOK  = mtfBearW>=1 or (mtfBullW==0 and mtfBearW==0)
bool isChoppy = math.abs(bScore-sScore)<2.0 and isRanging

bool buyS  = bScore>=thresh and isSessionOK and htfLOK and not isChoppy and isSafeMarket
bool sellS = sScore>=thresh and isSessionOK and htfSOK and not isChoppy and isSafeMarket

if isNewsSpike
    buyS  := bScore>=thresh*1.5 and htfLOK
    sellS := sScore>=thresh*1.5 and htfSOK

// ── PropFirm 風控狀態機 ──────────────────────────────────────────────────────
var float dayStartEq   = strategy.equity
var int   tradesToday  = 0
var int   consecLosses = 0
var bool  isPaused     = false
var bool  isRecovery   = false
var int   lastTradeBar = 0

if ta.change(time("D")) != 0
    dayStartEq  := strategy.equity
    tradesToday := 0
    consecLosses := 0
    isPaused     := false
    isRecovery   := false

dailyPnL  = strategy.equity - dayStartEq
globalPnL = strategy.equity - strategy.initial_capital
globalDD  = strategy.initial_capital - strategy.equity

var int prevClosed = 0
if strategy.closedtrades > prevClosed
    ltp = strategy.closedtrades.profit(strategy.closedtrades-1)
    if ltp < 0; consecLosses += 1; else; consecLosses := 0; isRecovery := false
    prevClosed := strategy.closedtrades
    lastTradeBar := bar_index

if consecLosses >= maxConsecLoss; isPaused := true
isRecovery := consecLosses>=2 and not isPaused
bool cdOK = (bar_index-lastTradeBar)>=cooldownBars or lastTradeBar==0

float rF = 1.0
rF := isRecovery ? recoveryMult : rF
rF := isHighVol  ? rF*0.6 : rF
rF := isNewsSpike? rF*0.4 : rF
rF := isDanger   ? rF*0.3 : rF
rF := dailyPnL<-(dailyLossMax*0.5) ? rF*0.4 : rF
rF := globalDD>globalDDMax*0.7 ? rF*0.3 : rF

bool dailyOK  = dailyPnL > -dailyLossMax
bool globalOK = globalDD < globalDDMax
bool goalHit  = dailyPnL >= dailyTarget
bool canTrade = dailyOK and globalOK and not goalHit and not isPaused and tradesToday<maxTradesDay and cdOK

string accStatus  = not dailyOK?"DAILY LOSS":not globalOK?"GLOBAL DD":goalHit?"GOAL HIT":isPaused?"PAUSED":isRecovery?"RECOVERY":isDanger?"DANGER":"ACTIVE"
string safetyLvl  = rF>=0.8?"SAFE":rF>=0.5?"CAUTION":rF>=0.3?"AGGRESSIVE":"DANGER"

// ── 執行引擎 ─────────────────────────────────────────────────────────────────
float slMult = isHighVol?2.0:isNewsSpike?2.5:isRanging?1.2:1.5
float tpMult = isStrTrend?3.0:isMildTrend?2.5:2.0

float bullSLs = not na(rPL) ? rPL-atr14*0.3 : close-atr14*slMult
float bearSLs = not na(rPH) ? rPH+atr14*0.3 : close+atr14*slMult

if canTrade and strategy.position_size==0
    if buyS
        bSL = math.min(bullSLs, close-atr14*slMult)
        sD  = math.max(close-bSL, atr14*0.5)
        bT1 = close+sD*1.5; bT2 = close+sD*tpMult
        rAm = strategy.equity*riskPctInp*rF
        qty = sD>0 ? rAm/sD : 0
        strategy.entry("TN Buy", strategy.long, qty=qty)
        strategy.exit("TP1 Buy","TN Buy", qty_percent=50, limit=bT1, stop=bSL)
        strategy.exit("TP2 Buy","TN Buy", limit=bT2, stop=bSL)
        tradesToday += 1
    if sellS
        sSL = math.max(bearSLs, close+atr14*slMult)
        sD  = math.max(sSL-close, atr14*0.5)
        sT1 = close-sD*1.5; sT2 = close-sD*tpMult
        rAm = strategy.equity*riskPctInp*rF
        qty = sD>0 ? rAm/sD : 0
        strategy.entry("TN Sell", strategy.short, qty=qty)
        strategy.exit("TP1 Sell","TN Sell", qty_percent=50, limit=sT1, stop=sSL)
        strategy.exit("TP2 Sell","TN Sell", limit=sT2, stop=sSL)
        tradesToday += 1

if strategy.position_size!=0 and (not dailyOK or not globalOK)
    strategy.close_all(comment="EMERGENCY CLOSE")

// ── EMA 視覺 ─────────────────────────────────────────────────────────────────
plot(showEMAs?emaF:na,"EMA9",color.new(#00E676,0),linewidth=1)
plot(showEMAs?emaM:na,"EMA21",color.new(#FF9800,0),linewidth=1)
plot(showEMAs?emaS:na,"EMA50",color.new(#2196F3,0),linewidth=2)
plot(showEMAs?emaT:na,"EMA200",color.new(#9C27B0,0),linewidth=2)

// ── 信號標籤 ─────────────────────────────────────────────────────────────────
plotshape(buyS and canTrade,"BUY",shape.labelup, location.belowbar,color.new(#00E676,0),text="BUY",textcolor=color.white,size=size.small)
plotshape(sellS and canTrade,"SELL",shape.labeldown, location.abovebar,color.new(#FF5252,0),text="SELL",textcolor=color.white,size=size.small)

// ── Dashboard ────────────────────────────────────────────────────────────────
var table dash = table.new(position.top_right,2,15,border_width=1,border_color=color.new(#424242,50))
if showDash and barstate.islast
    table.cell(dash,0,0,"TN PROPFIRM ULTRA",bgcolor=color.new(#0D47A1,0),text_color=color.white,text_size=size.normal)
    table.cell(dash,1,0,"v26.0604.0630",bgcolor=color.new(#0D47A1,0),text_color=color.white,text_size=size.normal)
    table.cell(dash,0,1,"Status",bgcolor=color.new(#37474F,0),text_color=color.white,text_size=size.small)
    table.cell(dash,1,1,accStatus,bgcolor=canTrade?color.new(#00E676,10):color.new(#FF5252,10),text_color=color.white,text_size=size.small)
    table.cell(dash,0,2,"Daily PnL",bgcolor=color.new(#37474F,0),text_color=color.white,text_size=size.small)
    table.cell(dash,1,2,str.tostring(dailyPnL,"#.##")+"/"+str.tostring(dailyTarget,"#")+"$",bgcolor=dailyPnL>=0?color.new(#00E676,10):color.new(#FF5252,10),text_color=color.white,text_size=size.small)
    table.cell(dash,0,3,"Global DD",bgcolor=color.new(#37474F,0),text_color=color.white,text_size=size.small)
    table.cell(dash,1,3,str.tostring(globalDD,"#.##")+"/"+str.tostring(globalDDMax,"#")+"$",bgcolor=globalDD<globalDDMax*0.5?color.new(#00E676,10):globalDD<globalDDMax*0.8?color.new(#FF9800,10):color.new(#FF5252,10),text_color=color.white,text_size=size.small)
    table.cell(dash,0,4,"Global PnL",bgcolor=color.new(#37474F,0),text_color=color.white,text_size=size.small)
    table.cell(dash,1,4,str.tostring(globalPnL,"#.##")+"$",bgcolor=globalPnL>=0?color.new(#00E676,10):color.new(#FF5252,10),text_color=color.white,text_size=size.small)
    rc=isStrTrend?color.new(#00E676,10):isRanging?color.new(#FF9800,10):isHighVol?color.new(#FF5252,10):isDanger?color.new(#B71C1C,10):color.new(#2196F3,10)
    table.cell(dash,0,5,"Market",bgcolor=color.new(#37474F,0),text_color=color.white,text_size=size.small)
    table.cell(dash,1,5,regimeLabel,bgcolor=rc,text_color=color.white,text_size=size.small)
    sc=rF>=0.8?color.new(#00E676,10):rF>=0.5?color.new(#FF9800,10):color.new(#FF5252,10)
    table.cell(dash,0,6,"Safety",bgcolor=color.new(#37474F,0),text_color=color.white,text_size=size.small)
    table.cell(dash,1,6,safetyLvl,bgcolor=sc,text_color=color.white,text_size=size.small)
    hs=mtfBullW>mtfBearW?"BULLISH":mtfBearW>mtfBullW?"BEARISH":"NEUTRAL"
    hc=mtfBullW>mtfBearW?color.new(#00E676,10):mtfBearW>mtfBullW?color.new(#FF5252,10):color.new(#9E9E9E,10)
    table.cell(dash,0,7,"HTF Bias",bgcolor=color.new(#37474F,0),text_color=color.white,text_size=size.small)
    table.cell(dash,1,7,hs,bgcolor=hc,text_color=color.white,text_size=size.small)
    ss=isLondon?"LONDON":isNY?"NEW YORK":isAsian?"ASIAN":"OFF"
    table.cell(dash,0,8,"Session",bgcolor=color.new(#37474F,0),text_color=color.white,text_size=size.small)
    table.cell(dash,1,8,ss,bgcolor=isKZ?color.new(#00E676,10):color.new(#9E9E9E,10),text_color=color.white,text_size=size.small)
    table.cell(dash,0,9,"Score",bgcolor=color.new(#37474F,0),text_color=color.white,text_size=size.small)
    table.cell(dash,1,9,"L:"+str.tostring(bScore,"#.#")+" S:"+str.tostring(sScore,"#.#")+" min:"+str.tostring(thresh,"#.#"),bgcolor=color.new(#1565C0,10),text_color=color.white,text_size=size.small)
    table.cell(dash,0,10,"Trades",bgcolor=color.new(#37474F,0),text_color=color.white,text_size=size.small)
    table.cell(dash,1,10,str.tostring(tradesToday)+"/"+str.tostring(maxTradesDay)+" Loss:"+str.tostring(consecLosses),bgcolor=color.new(#1565C0,10),text_color=color.white,text_size=size.small)
    table.cell(dash,0,11,"Risk Level",bgcolor=color.new(#37474F,0),text_color=color.white,text_size=size.small)
    table.cell(dash,1,11,str.tostring(rF*100,"#")+"%",bgcolor=rF<0.5?color.new(#FF5252,10):rF<0.8?color.new(#FF9800,10):color.new(#00E676,10),text_color=color.white,text_size=size.small)
    ps=strategy.position_size>0?"LONG":strategy.position_size<0?"SHORT":"FLAT"
    pc=strategy.position_size>0?color.new(#00E676,10):strategy.position_size<0?color.new(#FF5252,10):color.new(#9E9E9E,10)
    table.cell(dash,0,12,"Position",bgcolor=color.new(#37474F,0),text_color=color.white,text_size=size.small)
    table.cell(dash,1,12,ps,bgcolor=pc,text_color=color.white,text_size=size.small)
    wr=strategy.closedtrades>0?(strategy.wintrades/strategy.closedtrades)*100:0
    table.cell(dash,0,13,"Winrate",bgcolor=color.new(#37474F,0),text_color=color.white,text_size=size.small)
    table.cell(dash,1,13,str.tostring(wr,"#.#")+"%",bgcolor=wr>=55?color.new(#00E676,10):wr>=45?color.new(#FF9800,10):color.new(#FF5252,10),text_color=color.white,text_size=size.small)
    gl=strategy.grossloss>0?strategy.grossloss:1; pf=strategy.grossprofit/gl
    table.cell(dash,0,14,"Profit Factor",bgcolor=color.new(#37474F,0),text_color=color.white,text_size=size.small)
    table.cell(dash,1,14,str.tostring(pf,"#.##"),bgcolor=pf>=1.5?color.new(#00E676,10):pf>=1.0?color.new(#FF9800,10):color.new(#FF5252,10),text_color=color.white,text_size=size.small)

// ── Alert ────────────────────────────────────────────────────────────────────
alertcondition(buyS and canTrade,"TN LONG","TeleNexus PropFirm Ultra: LONG Signal")
alertcondition(sellS and canTrade,"TN SHORT","TeleNexus PropFirm Ultra: SHORT Signal")
alertcondition(not dailyOK,"DAILY LOSS","Daily Loss Limit Hit")
alertcondition(not globalOK,"GLOBAL DD","Global Drawdown Limit Hit")