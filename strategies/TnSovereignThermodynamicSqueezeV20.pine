//@version=6
// TeleNexus Sovereign: Thermodynamic Squeeze Expansion [v26.0514.0634]
// Spirit Inheritance: PineGen-AI Squeeze & Kronos V20 Geometric Thermodynamics
// Goal: Exploiting Volatility Compression via Adiabatic Expansion Sensing
//
// Logic Matrix:
// 1. Volatility Squeeze: Bollinger Bands (20, 2) contracting inside Keltner Channels (20, 1.5).
// 2. Squeeze Release: Detecting the 'firing' of momentum when bands expand.
// 3. V20 Thermodynamic Audit: Calculating 'Free Energy' vs 'Fractal Entropy'.
// 4. Adiabatic Expansion: Sensing high-conviction位移 (High Energy, Low Entropy).
// 5. Execution Suture: Aligning squeeze release with thermodynamic phase consistency.

strategy("TnSovereignThermodynamicSqueezeV20",
     shorttitle         = "TnS_Sqz_V20",
     overlay            = true,
     initial_capital    = 100000,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 10,
     commission_type    = strategy.commission.percent,
     commission_value   = 0.05,
     slippage           = 1)

// ── Regulation Parameters ───────────────────────────────────────────────────
group_sqz   = "▼ Volatility Squeeze"
sqz_len     = input.int(20, "Squeeze Length")
bb_mult     = input.float(2.0, "Bollinger Multiplier")
kc_mult     = input.float(1.5, "Keltner Multiplier")

group_v20   = "▼ V20 Thermodynamic Gating"
min_energy  = input.float(1.6, "Min Free Energy", minval=0.5, maxval=5.0)
max_entropy = input.float(1.35, "Max Fractal Entropy (D)", minval=1.0, maxval=2.0)

group_risk  = "▼ Risk Management"
sl_atr_mult = input.float(1.8, "SL ATR Multiple")
tp_rr       = input.float(3.2, "Target R:R Ratio")

// ── Causal Components ───────────────────────────────────────────────────────
float atr = ta.atr(14)

// 1. Squeeze Logic
float basis = ta.sma(close, sqz_len)
float dev   = bb_mult * ta.stdev(close, sqz_len)
float bb_up = basis + dev
float bb_lo = basis - dev

float ma    = ta.ema(close, sqz_len)
float range = kc_mult * ta.atr(sqz_len)
float kc_up = ma + range
float kc_lo = ma - range

bool squeeze = (bb_up < kc_up) and (bb_lo > kc_lo)
bool fired   = not squeeze and squeeze[1]

// 2. V20 Thermodynamic Audit (TeleNexus Core)
f_v20_audit(int len) =>
    float displacement = math.abs(close - close[len])
    float path_length = 0.0
    for i = 0 to len - 1
        path_length += math.abs(close[i] - close[i+1])
    float fd = path_length / (displacement || 1)
    
    float range_avg = ta.sma(high - low, len)
    float price_work = math.abs(close - open) / (range_avg || 1)
    float free_energy = price_work / (fd + 0.1)
    [free_energy, fd]

[v20_energy, v20_entropy] = f_v20_audit(20)
bool thermo_pass = v20_energy > min_energy and v20_entropy < max_entropy

// ── Execution Logic ─────────────────────────────────────────────────────────
bool long_entry  = fired and close > bb_up and thermo_pass and barstate.isconfirmed
bool short_entry = fired and close < bb_lo and thermo_pass and barstate.isconfirmed

if long_entry and strategy.position_size == 0
    log.info("[SOVEREIGN_SQZ_LONG] Fired. Energy={0,number,#.##} Entropy={1,number,#.##}. Suture.", v20_energy, v20_entropy)
    strategy.entry("Long", strategy.long, comment="SQZ_FIRE_V20")
    strategy.exit("ExitL", "Long", stop=close - atr * sl_atr_mult, limit=close + atr * sl_atr_mult * tp_rr)

if short_entry and strategy.position_size == 0
    log.info("[SOVEREIGN_SQZ_SHORT] Fired. Energy={0,number,#.##} Entropy={1,number,#.##}. Suture.", v20_energy, v20_entropy)
    strategy.entry("Short", strategy.short, comment="SQZ_FIRE_V20")
    strategy.exit("ExitS", "Short", stop=close + atr * sl_atr_mult, limit=close - atr * sl_atr_mult * tp_rr)

// ── Visuals ──────────────────────────────────────────────────────────────────
plot(bb_up, "BB Upper", color.new(color.aqua, 50))
plot(bb_lo, "BB Lower", color.new(color.aqua, 50))
plot(kc_up, "KC Upper", color.new(color.orange, 50))
plot(kc_lo, "KC Lower", color.new(color.orange, 50))

bgcolor(squeeze ? color.new(color.gray, 90) : fired ? color.new(color.yellow, 85) : na)

// HUD
var table info = table.new(position.top_right, 2, 6, frame_color=color.gray, frame_width=1)
if barstate.islast
    table.cell(info, 0, 0, "Sovereign Sqz", bgcolor=color.new(color.black, 80), text_color=color.white)
    table.cell(info, 1, 0, "v26.0514", bgcolor=color.new(color.black, 80), text_color=color.white)
    table.cell(info, 0, 1, "Free Energy", text_color=color.white)
    table.cell(info, 1, 1, str.tostring(v20_energy, "#.##"), bgcolor=v20_energy > min_energy ? color.new(color.green, 50) : color.new(color.red, 50))
    table.cell(info, 0, 2, "Fractal D", text_color=color.white)
    table.cell(info, 1, 2, str.tostring(v20_entropy, "#.##"), bgcolor=v20_entropy < max_entropy ? color.new(color.aqua, 50) : color.new(color.orange, 50))
    table.cell(info, 0, 3, "Squeeze", text_color=color.white)
    table.cell(info, 1, 3, squeeze ? "ON" : "OFF", text_color=squeeze ? color.yellow : color.gray)
    table.cell(info, 0, 4, "Adiabatic", text_color=color.white)
    table.cell(info, 1, 4, thermo_pass ? "LOCKED" : "VOID", text_color=thermo_pass ? color.lime : color.gray)
    table.cell(info, 0, 5, "Physical Time", text_color=color.white)
    table.cell(info, 1, 5, "06.3401", text_color=color.white)
