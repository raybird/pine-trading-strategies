//@version=6
strategy("Tn Sovereign Stoch v6 [v26.0422.1203]",
    shorttitle         = "TN_STOCH_v26",
    overlay            = true,
    initial_capital    = 100000,
    default_qty_type   = strategy.percent_of_equity,
    default_qty_value  = 10,
    commission_type    = strategy.commission.percent,
    commission_value   = 0.05,
    slippage           = 2,
    process_orders_on_close = true)

// =====================================================
// MODULE 1: SOVEREIGN MOMENTUM DISCIPLINE (STOCH)
// =====================================================

groupStoch = "🌌 隨機指標規訓 (Stochastic)"
stochLen   = input.int(14, "隨機指標長度", minval=1, group=groupStoch)
kSmooth    = input.int(3,  "K 線平滑", minval=1, group=groupStoch)
dSmooth    = input.int(3,  "D 線平滑", minval=1, group=groupStoch)
obLevel    = input.float(80, "超買門檻 (OB)", minval=60, maxval=95, group=groupStoch)
osLevel    = input.float(20, "超賣門檻 (OS)", minval=5, maxval=40, group=groupStoch)

// v6 Calculation: ta.stoch returns float K
float rawK = ta.stoch(high, low, close, stochLen)
float k    = ta.sma(rawK, kSmooth)
float d    = ta.sma(k, dSmooth)

// =====================================================
// MODULE 2: REGIME & RISK AUDIT
// =====================================================

groupAudit = "🛡️ 因果過濾 (Audit Layers)"
emaLen     = input.int(200, "趨勢地板 (EMA)", group=groupAudit)
atrLen     = input.int(14,  "ATR 週期", group=groupAudit)
slMult     = input.float(2.0, "止損 ATR 倍數", group=groupAudit)
tpMult     = input.float(4.0, "獲利 ATR 倍數", group=groupAudit)

float emaVal = ta.ema(close, emaLen)
float atrVal = ta.atr(atrLen)

bool regimeBull = close > emaVal
bool regimeBear = close < emaVal

// =====================================================
// MODULE 3: CAUSAL SIGNALS & EXECUTION
// =====================================================

// Long: K/D Cross in OS Zone AND Bullish Regime
bool longEntry  = ta.crossover(k, d) and k < osLevel and regimeBull
// Short: K/D Cross in OB Zone AND Bearish Regime
bool shortEntry = ta.crossunder(k, d) and k > obLevel and regimeBear

if longEntry and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, comment="STOCH-B")
    strategy.exit("L-Exit", "Long", stop=close - slMult * atrVal, limit=close + tpMult * atrVal)

if shortEntry and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, comment="STOCH-S")
    strategy.exit("S-Exit", "Short", stop=close + slMult * atrVal, limit=close - tpMult * atrVal)

// =====================================================
// MODULE 4: SOVEREIGN AUDIT HUD
// =====================================================

var table hud = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 70), border_width=1)
if barstate.isconfirmed
    table.cell(hud, 0, 0, "◈ STOCH SOV", text_color=color.white, bgcolor=color.new(color.navy, 20))
    table.cell(hud, 1, 0, "STATUS", text_color=color.white, bgcolor=color.new(color.navy, 20))
    
    table.cell(hud, 0, 1, "K / D", text_color=color.gray)
    table.cell(hud, 1, 1, str.tostring(k, "##.##") + " / " + str.tostring(d, "##.##"), text_color=color.yellow)
    
    table.cell(hud, 0, 2, "Market Bias", text_color=color.gray)
    table.cell(hud, 1, 2, regimeBull ? "BULL" : "BEAR", text_color=regimeBull ? color.lime : color.red)
    
    table.cell(hud, 0, 3, "Volatility", text_color=color.gray)
    table.cell(hud, 1, 3, str.tostring(atrVal, "##.##"), text_color=color.aqua)
    
    table.cell(hud, 0, 4, "Version", text_color=color.gray)
    table.cell(hud, 1, 4, "v26.0422.1203", text_color=color.gray)

// Visuals
plot(emaVal, "Regime Floor", color.new(color.gray, 60), 1)
plotshape(longEntry, "Long", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(shortEntry, "Short", shape.triangledown, location.abovebar, color.red, size=size.small)
