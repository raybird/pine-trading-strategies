//@version=6
strategy("Tn Sovereign Session Quant v6 [v26.0422.0601]",
    shorttitle         = "TN_SESSION_v26",
    overlay            = true,
    initial_capital    = 100000,
    default_qty_type   = strategy.percent_of_equity,
    default_qty_value  = 10,
    commission_type    = strategy.commission.percent,
    commission_value   = 0.05,
    slippage           = 2,
    process_orders_on_close = true)

// =====================================================
// MODULE 1: SOVEREIGN SESSION DISCIPLINE
// =====================================================

groupSession = "⏳ 時段規訓 (Session Config)"
sessionTime  = input.session("0900-1500", "執行時段 (預設台股)", group=groupSession)
sessionTz    = input.string("Asia/Taipei", "時區 (Timezone)", group=groupSession)
closeAtEnd   = input.bool(true, "時段結束後自動平倉", group=groupSession)

bool inSession = not na(time(timeframe.period, sessionTime, sessionTz))

// Session High/Low Tracking
var float sessionHigh = na
var float sessionLow  = na

if inSession and not inSession[1]
    sessionHigh := high
    sessionLow  := low
else if inSession
    sessionHigh := math.max(high, sessionHigh)
    sessionLow  := math.min(low, sessionLow)

// =====================================================
// MODULE 2: BREAKOUT & MOMENTUM AUDIT
// =====================================================

groupAudit = "🛡️ 因果過濾 (Audit Layers)"
lookback   = input.int(20, "回測週期", group=groupAudit)
emaLen     = input.int(50, "基準均線", group=groupAudit)

float emaVal = ta.ema(close, emaLen)
bool trendBull = close > emaVal
bool trendBear = close < emaVal

// Breakout Logic: Cross session extreme + Trend confirmation
bool longEntry  = inSession and ta.crossover(close, sessionHigh[1]) and trendBull
bool shortEntry = inSession and ta.crossunder(close, sessionLow[1]) and trendBear

// =====================================================
// MODULE 3: CAUSAL EXECUTION
// =====================================================

if longEntry and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, comment="SOV-B")

if shortEntry and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, comment="SOV-S")

// Auto-Close Logic
if closeAtEnd and not inSession and inSession[1]
    strategy.close_all(comment="END-SESSION")

// =====================================================
// MODULE 4: SOVEREIGN AUDIT HUD
// =====================================================

var table hud = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 70), border_width=1)
if barstate.isconfirmed
    table.cell(hud, 0, 0, "◈ SESSION SOV", text_color=color.white, bgcolor=color.new(color.navy, 20))
    table.cell(hud, 1, 0, "STATUS", text_color=color.white, bgcolor=color.new(color.navy, 20))
    
    table.cell(hud, 0, 1, "In Session", text_color=color.gray)
    table.cell(hud, 1, 1, inSession ? "ACTIVE" : "IDLE", text_color=inSession ? color.lime : color.red)
    
    table.cell(hud, 0, 2, "High/Low", text_color=color.gray)
    table.cell(hud, 1, 2, str.tostring(sessionHigh, "##.##") + "/" + str.tostring(sessionLow, "##.##"), text_color=color.yellow)
    
    table.cell(hud, 0, 3, "Regime", text_color=color.gray)
    table.cell(hud, 1, 3, trendBull ? "BULL" : "BEAR", text_color=trendBull ? color.lime : color.red)
    
    table.cell(hud, 0, 4, "Timezone", text_color=color.gray)
    table.cell(hud, 1, 4, sessionTz, text_color=color.gray)

    table.cell(hud, 0, 5, "Version", text_color=color.gray)
    table.cell(hud, 1, 5, "v26.0422.0601", text_color=color.gray)

// Visuals
bgcolor(inSession ? color.new(color.blue, 96) : color.new(color.gray, 96))
plot(sessionHigh, "Session High", color.new(color.green, 40), 1, style=plot.style_steplinebr)
plot(sessionLow,  "Session Low",  color.new(color.red, 40),   1, style=plot.style_steplinebr)
plot(emaVal, "Regime Floor", color.new(color.orange, 60), 1)
plotshape(longEntry, "Long", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(shortEntry, "Short", shape.triangledown, location.abovebar, color.red, size=size.small)
