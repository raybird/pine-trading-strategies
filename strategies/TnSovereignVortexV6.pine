//@version=6
strategy("Tn Sovereign Vortex v6 [v26.0424.0631]",
    shorttitle         = "TN_VORTEX_v26",
    overlay            = true,
    initial_capital    = 100000,
    default_qty_type   = strategy.percent_of_equity,
    default_qty_value  = 10,
    commission_type    = strategy.commission.percent,
    commission_value   = 0.05,
    slippage           = 2,
    process_orders_on_close = true)

// =====================================================
// MODULE 1: SOVEREIGN VORTEX DISCIPLINE
// =====================================================

groupVTX = "🌌 渦流規訓 (Vortex Config)"
vtxLen   = input.int(14, "渦流週期", minval=1, group=groupVTX)

// Vortex Calculation
vPlus  = math.abs(high - low[1])
vMinus = math.abs(low - high[1])
tr     = ta.tr(true)

viPlus  = ta.sma(vPlus, vtxLen) / ta.sma(tr, vtxLen)
viMinus = ta.sma(vMinus, vtxLen) / ta.sma(tr, vtxLen)

bool bullPol = viPlus > viMinus
bool bearPol = viMinus > viPlus

// =====================================================
// MODULE 2: REGIME & ENERGY AUDIT
// =====================================================

groupAudit = "🛡️ 因果過濾 (Audit Layers)"
trendLen   = input.int(200,   "趨勢地板 (EMA)", group=groupAudit)
atrLen     = input.int(14,    "ATR 週期", group=groupAudit)
slMult     = input.float(2.0, "止損 ATR 倍數", group=groupAudit)
tpMult     = input.float(4.0, "獲利 ATR 倍數", group=groupAudit)

float trendEma = ta.ema(close, trendLen)
float atrVal   = ta.atr(atrLen)

bool regimeBull = close > trendEma
bool regimeBear = close < trendEma

// =====================================================
// MODULE 3: CAUSAL SIGNALS & EXECUTION
// =====================================================

// Long: VI+ crosses above VI- AND Bullish Regime
bool longEntry  = ta.crossover(viPlus, viMinus) and regimeBull
// Short: VI- crosses above VI+ AND Bearish Regime
bool shortEntry = ta.crossover(viMinus, viPlus) and regimeBear

if longEntry and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, comment="VTX-B")
    strategy.exit("L-Exit", "Long", stop=close - slMult * atrVal, limit=close + tpMult * atrVal)

if shortEntry and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, comment="VTX-S")
    strategy.exit("S-Exit", "Short", stop=close + slMult * atrVal, limit=close - tpMult * atrVal)

// =====================================================
// MODULE 4: SOVEREIGN AUDIT HUD
// =====================================================

var table hud = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 70), border_width=1)
if barstate.isconfirmed
    table.cell(hud, 0, 0, "◈ VORTEX SOV", text_color=color.white, bgcolor=color.new(color.navy, 20))
    table.cell(hud, 1, 0, "STATUS", text_color=color.white, bgcolor=color.new(color.navy, 20))
    
    table.cell(hud, 0, 1, "VI (+/-)", text_color=color.gray)
    table.cell(hud, 1, 1, str.tostring(viPlus, "##.##") + " / " + str.tostring(viMinus, "##.##"), text_color=bullPol ? color.lime : color.red)
    
    table.cell(hud, 0, 2, "Market Bias", text_color=color.gray)
    table.cell(hud, 1, 2, regimeBull ? "BULL" : regimeBear ? "BEAR" : "RANGE", text_color=regimeBull ? color.lime : color.red)
    
    table.cell(hud, 0, 3, "Volatility", text_color=color.gray)
    table.cell(hud, 1, 3, str.tostring(atrVal, "##.##"), text_color=color.aqua)
    
    table.cell(hud, 0, 4, "Version", text_color=color.gray)
    table.cell(hud, 1, 4, "v26.0424.0631", text_color=color.gray)

// Visuals
plot(trendEma, "Regime Floor", color.new(color.gray, 60), 1)
plotshape(longEntry, "Long", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(shortEntry, "Short", shape.triangledown, location.abovebar, color.red, size=size.small)
