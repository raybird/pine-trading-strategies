//@version=6
// TeleNexus Sovereign: ICT Surgical Thermodynamic Equilibrium [v26.0513.0632]
// Spirit Inheritance: h33rnan ICT Surgical Engine & Kronos V20 Geometric Thermodynamics
// Goal: Institutional ICT Execution via Adiabatic Expansion & Free Energy Audit
//
// Logic Chain:
// 1. ICT Matrix: Tracking FVGs, Pivot Swings (SH/SL), and OTE zones.
// 2. Liquidity Sweep Audit: Detecting stop hunts and institutional manipulation.
// 3. V20 Thermodynamic Gating: Assessing 'Free Energy' vs 'Fractal Entropy'.
// 4. Adiabatic Expansion: Sensing high-conviction位移 (Ordered Growth).
// 5. Execution Suture: Aligning OTE entries with thermodynamic phase consistency.

strategy("TnSovereignIctSurgicalV20",
     shorttitle         = "TnS_ICT_V20",
     overlay            = true,
     initial_capital    = 100000,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 10,
     commission_type    = strategy.commission.percent,
     commission_value   = 0.04,
     slippage           = 1)

// ── Regulation Parameters ───────────────────────────────────────────────────
group_ict   = "▼ ICT Matrix"
leftBars    = input.int(7, "Pivot Left Bars")
rightBars   = input.int(3, "Pivot Right Bars")
use_ote     = input.bool(true, "Require OTE Zone Entry")

group_v20   = "▼ V20 Thermodynamic Gating"
min_energy  = input.float(1.6, "Min Free Energy", minval=0.5, maxval=5.0)
max_entropy = input.float(1.35, "Max Fractal Entropy (D)", minval=1.0, maxval=2.0)

group_risk  = "▼ Risk Management"
sl_atr_mult = input.float(1.5, "SL ATR Multiple")
tp_rr       = input.float(3.0, "Target R:R Ratio")

// ── Causal Components ───────────────────────────────────────────────────────
float atrVal = ta.atr(14)

// 1. Pivot Swings (SH / SL)
float ph = ta.pivothigh(high, leftBars, rightBars)
float pl = ta.pivotlow(low, leftBars, rightBars)

var float lastSH = na, var float lastSL = na
if not na(ph)
    lastSH := ph
if not na(pl)
    lastSL := pl

// 2. OTE Zone Calculation (62% - 79%)
float rangeSize = math.abs(lastSH - lastSL)
float ote_high  = lastSH - (rangeSize * 0.62)
float ote_low   = lastSH - (rangeSize * 0.79)
bool in_ote_long = close <= ote_high and close >= ote_low

// 3. V20 Thermodynamic Audit (TeleNexus Core)
f_v20_audit(int len) =>
    float displacement = math.abs(close - close[len])
    float path_length = 0.0
    for i = 0 to len - 1
        path_length += math.abs(close[i] - close[i+1])
    float fd = path_length / (displacement || 1)
    
    float range_avg = ta.sma(high - low, len)
    float price_work = math.abs(close - open) / (range_avg || 1)
    float free_energy = price_work / (fd + 0.1)
    [free_energy, fd]

[v20_energy, v20_entropy] = f_v20_audit(20)
bool thermo_pass = v20_energy > min_energy and v20_entropy < max_entropy

// 4. Liquidity Sweep Audit
bool bull_sweep = low < lastSL and close > lastSL
bool bear_sweep = high > lastSH and close < lastSH

// ── Execution Logic ─────────────────────────────────────────────────────────
bool long_entry  = (bull_sweep or (use_ote and in_ote_long)) and thermo_pass and barstate.isconfirmed
bool short_entry = bear_sweep and thermo_pass and barstate.isconfirmed // Simplified short

if long_entry and strategy.position_size == 0
    log.info("[SOVEREIGN_ICT_LONG] Entry. Energy={0,number,#.##} Entropy={1,number,#.##}. Suture.", v20_energy, v20_entropy)
    strategy.entry("Long", strategy.long, comment="ICT_V20_SUTURE")
    strategy.exit("ExitL", "Long", stop=close - atrVal * sl_atr_mult, limit=close + atrVal * sl_atr_mult * tp_rr)

// ── Visuals ──────────────────────────────────────────────────────────────────
plot(lastSH, "Pivot High", color.new(color.red, 80), style=plot.style_stepline)
plot(lastSL, "Pivot Low", color.new(color.green, 80), style=plot.style_stepline)
bgcolor(long_entry ? color.new(color.green, 85) : na)

// Dashboard
var table info = table.new(position.bottom_right, 2, 6, frame_color=color.gray, frame_width=1)
if barstate.islast
    table.cell(info, 0, 0, "Sovereign ICT", bgcolor=color.new(color.black, 80), text_color=color.white)
    table.cell(info, 1, 0, "v26.0513", bgcolor=color.new(color.black, 80), text_color=color.white)
    table.cell(info, 0, 1, "Free Energy", text_color=color.white)
    table.cell(info, 1, 1, str.tostring(v20_energy, "#.##"), bgcolor=v20_energy > min_energy ? color.new(color.green, 50) : color.new(color.red, 50))
    table.cell(info, 0, 2, "Fractal Entropy", text_color=color.white)
    table.cell(info, 1, 2, str.tostring(v20_entropy, "#.##"), bgcolor=v20_entropy < max_entropy ? color.new(color.aqua, 50) : color.new(color.orange, 50))
    table.cell(info, 0, 3, "Adiabatic", text_color=color.white)
    table.cell(info, 1, 3, thermo_pass ? "LOCKED" : "VOID", text_color=thermo_pass ? color.lime : color.gray)
    table.cell(info, 0, 4, "Physical Time", text_color=color.white)
    table.cell(info, 1, 4, "06.3142", text_color=color.white)
