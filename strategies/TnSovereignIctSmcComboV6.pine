//@version=6
// TeleNexus Sovereign: ICT/SMC Multi-Confluence Combo Strategy [v26.0508.0631]
// Spirit Inheritance: ICT Ark Suite & Kronos V17 Fractal Entropy
// Goal: Institutional Orderflow Alignment via 7-Factor Suture
//
// Logic Matrix (Ark Suite + TeleNexus Suture):
// 1. HTF Bias: Trend alignment on 4H/Daily EMA.
// 2. Killzone: London/NY session timing.
// 3. PD Array: Recent FVG (Fair Value Gap) detection.
// 4. Liquidity Sweep: Sensing wick-reclaims beyond N-bar extremes.
// 5. MSS (Market Structure Shift): Identifying breaks of structural highs/lows.
// 6. Premium/Discount: Prev-day range positioning.
// 7. V17 Fractal Gating: Multi-scale entropy verification (Peak Sovereignty).

strategy("TnSovereignIctSmcComboV6",
     shorttitle         = "TnS_IctCombo_V6",
     overlay            = true,
     initial_capital    = 100000,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 10,
     commission_type    = strategy.commission.percent,
     commission_value   = 0.04,
     slippage           = 1)

// ── Regulation Parameters ───────────────────────────────────────────────────
group_sys   = "▼ Regulation"
min_confl   = input.int(4, "Min Confluence Score (1-7)", minval=1, maxval=7)
fvg_lb      = input.int(10, "FVG Lookback")
sweep_lb    = input.int(15, "Sweep Lookback")
mss_lb      = input.int(20, "MSS Lookback")
htf_res     = input.timeframe("D", "HTF Bias Timeframe")

group_v17   = "▼ V17 Fractal Entropy"
use_v17     = input.bool(true, "Enable V17 Fractal Gating")
v17_thresh  = input.float(0.45, "Min Fractal Efficiency", minval=0.1, maxval=1.0)

group_risk  = "▼ Risk Management"
sl_atr_mult = input.float(2.0, "SL ATR Multiple")
tp_rr       = input.float(3.0, "Target R:R")

// ── Causal Components ───────────────────────────────────────────────────────
float atr = ta.atr(14)

// 1. HTF Bias
float htf_ema = request.security(syminfo.tickerid, htf_res, ta.ema(close, 20), lookahead=barmerge.lookahead_off)
bool bias_up = close > htf_ema
bool bias_down = close < htf_ema

// 2. Killzone (London or NY)
bool in_kz = not na(time(timeframe.period, "0200-0500:23456", "America/New_York")) or
             not na(time(timeframe.period, "0700-1100:23456", "America/New_York"))

// 3. FVG Detection
f_check_fvg(bool is_bull) =>
    bool found = false
    for i = 0 to fvg_lb
        if is_bull and low[i] > high[i+2]
            found := true
            break
        if not is_bull and high[i] < low[i+2]
            found := true
            break
    found

bool bull_fvg = f_check_fvg(true)
bool bear_fvg = f_check_fvg(false)

// 4. Sweep Detection
f_check_sweep(bool is_bull) =>
    bool found = false
    for i = 0 to sweep_lb
        float pH = ta.highest(high, 10)[i+1]
        float pL = ta.lowest(low, 10)[i+1]
        if is_bull and low[i] < pL and close[i] > pL
            found := true
            break
        if not is_bull and high[i] > pH and close[i] < pH
            found := true
            break
    found

bool bull_sweep = f_check_sweep(true)
bool bear_sweep = f_check_sweep(false)

// 5. MSS Detection
f_check_mss(bool is_bull) =>
    bool found = false
    for i = 0 to mss_lb
        float prevHi = ta.highest(high, 10)[i+1]
        float prevLo = ta.lowest(low, 10)[i+1]
        if is_bull and close[i] > prevHi
            found := true
            break
        if not is_bull and close[i] < prevLo
            found := true
            break
    found

bool bull_mss = f_check_mss(true)
bool bear_mss = f_check_mss(false)

// 6. Premium/Discount
[dHi, dLo] = request.security(syminfo.tickerid, "D", [high[1], low[1]], lookahead=barmerge.lookahead_off)
float dMid = math.avg(dHi, dLo)
bool in_discount = close < dMid
bool in_premium  = close > dMid

// 7. V17 Fractal Entropy (TeleNexus Core)
f_v17_efficiency(int len) =>
    float window_range = ta.highest(high, len) - ta.lowest(low, len)
    float path_length = 0.0
    for i = 0 to len - 1
        path_length += math.abs(close[i] - close[i+1])
    window_range / (path_length || 1)

float v17_eff = f_v17_efficiency(20)
bool v17_gate = use_v17 ? v17_eff > v17_thresh : true

// ── Suture Matrix ───────────────────────────────────────────────────────────
int bull_score = (bias_up ? 1 : 0) + (in_kz ? 1 : 0) + (bull_fvg ? 1 : 0) + (bull_sweep ? 1 : 0) + (bull_mss ? 1 : 0) + (in_discount ? 1 : 0) + (v17_gate ? 1 : 0)
int bear_score = (bias_down ? 1 : 0) + (in_kz ? 1 : 0) + (bear_fvg ? 1 : 0) + (bear_sweep ? 1 : 0) + (bear_mss ? 1 : 0) + (in_premium ? 1 : 0) + (v17_gate ? 1 : 0)

// ── Execution Logic ─────────────────────────────────────────────────────────
bool long_entry = bull_score >= min_confl and barstate.isconfirmed
bool short_entry = bear_score >= min_confl and barstate.isconfirmed

if long_entry and strategy.position_size == 0
    log.info("[SOVEREIGN_ICT_COMBO_LONG] Score={0} Efficiency={1,number,#.##}. Suturing.", bull_score, v17_eff)
    strategy.entry("IctL", strategy.long, comment="SCORE_" + str.tostring(bull_score))
    strategy.exit("ExitL", "IctL", stop=close - atr * sl_atr_mult, limit=close + atr * sl_atr_mult * tp_rr)

if short_entry and strategy.position_size == 0
    log.info("[SOVEREIGN_ICT_COMBO_SHORT] Score={0} Efficiency={1,number,#.##}. Suturing.", bear_score, v17_eff)
    strategy.entry("IctS", strategy.short, comment="SCORE_" + str.tostring(bear_score))
    strategy.exit("ExitS", "IctS", stop=close + atr * sl_atr_mult, limit=close - atr * sl_atr_mult * tp_rr)

// ── Visuals ──────────────────────────────────────────────────────────────────
plot(htf_ema, "HTF EMA", color.new(color.orange, 50), linewidth=2)
bgcolor(long_entry ? color.new(color.green, 90) : short_entry ? color.new(color.red, 90) : na)

// Dashboard
var table info = table.new(position.bottom_right, 2, 4, frame_color=color.gray, frame_width=1)
if barstate.islast
    table.cell(info, 0, 0, "ICT Combo v26", bgcolor=color.new(color.black, 80), text_color=color.white)
    table.cell(info, 1, 0, "Sovereign Master", bgcolor=color.new(color.black, 80), text_color=color.white)
    table.cell(info, 0, 1, "Confluence", text_color=color.white)
    table.cell(info, 1, 1, str.tostring(math.max(bull_score, bear_score)), bgcolor=math.max(bull_score, bear_score) >= min_confl ? color.new(color.green, 50) : color.new(color.red, 50))
    table.cell(info, 0, 2, "V17 Efficiency", text_color=color.white)
    table.cell(info, 1, 2, str.tostring(v17_eff, "#.##"), bgcolor=v17_eff > v17_thresh ? color.new(color.aqua, 50) : color.new(color.gray, 50))
    table.cell(info, 0, 3, "Physical Time", text_color=color.white)
    table.cell(info, 1, 3, "08.0631", text_color=color.white)
