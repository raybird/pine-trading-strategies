//@version=6
// @description: TeleNexus 自適應風險矩陣策略 - v6 核心實作
// @author: TeleNexus AI (Core v2.9.7)
// @strategy: 利用 2D 矩陣根據 (趨勢強度 x 波動率) 動態調節風險百分比，實現具備「自主掌控」韌性的執行主權。
// [[MEMORY_INTENT:{"level":"rule","confidence":"high","reason":"Implementing Adaptive Risk Matrix as a foundational execution standard.","summary":"Established dynamic risk scaling based on trend/volatility matrix to ensure defensive execution sovereignty."}]]

strategy("TN Adaptive Risk Matrix Sovereign v6", overlay = true, initial_capital = 10000, default_qty_type = strategy.cash, currency = currency.USD)

// 1. 利用 v6 Enum 定義風險規訓
enum RiskProfile
    Conservative = "保守 (0.5% 風險)"
    Moderate     = "標準 (1.0% 風險)"
    Aggressive   = "積極 (2.0% 風險)"

RiskProfile profile = input.enum(RiskProfile.Moderate, "風險偏好設定", group = "風險管理")
float baseRisk      = profile == RiskProfile.Conservative ? 0.005 : profile == RiskProfile.Moderate ? 0.01 : 0.02

// 2. 感知參數
int adxLen    = input.int(14, "ADX 長度", group = "矩陣感知")
int atrLen    = input.int(14, "ATR 長度", group = "矩陣感知")
float atrMult = input.float(2.5, "ATR 止損倍數", group = "風險管理")

// 3. 因果矩陣演算 (Adaptive Matrix)
[plusDI, minusDI, adxValue] = ta.dmi(adxLen, adxLen)
atr = ta.atr(atrLen)
avgAtr = ta.sma(atr, 100)

bool isHighTrend = adxValue > 25
bool isLowTrend  = adxValue < 15
bool isHighVol   = atr > avgAtr * 1.2
bool isLowVol    = atr < avgAtr * 0.8

// 矩陣規訓邏輯：
// - 高趨勢 + 低波 = 因果優勢 (1.5x 風險)
// - 低趨勢 或 高波 = 物理威脅 (0.5x 風險)
float riskMultiplier = 1.0
if isHighTrend and isLowVol
    riskMultiplier := 1.5
else if isLowTrend or isHighVol
    riskMultiplier := 0.5

float finalRiskPercent = baseRisk * riskMultiplier

// 4. 執行邏輯 (EMA 趨勢對位)
emaF = ta.ema(close, 10)
emaS = ta.ema(close, 21)
bool longCond  = ta.crossover(emaF, emaS)
bool shortCond = ta.crossunder(emaF, emaS)

// 5. 動態倉位規訓 (物理對位)
float longStop  = close - (atr * atrMult)
float shortStop = close + (atr * atrMult)
float stopDist  = close - longStop

float riskAmt   = strategy.equity * finalRiskPercent
float qtySize   = stopDist > 0 ? riskAmt / stopDist : na

if longCond
    strategy.entry("Long", strategy.long, qty = qtySize, comment = str.format("R:{0,number,#.##}%", finalRiskPercent * 100))
    strategy.exit("Exit_L", "Long", stop = longStop, limit = close + (stopDist * 2.5))

if shortCond
    strategy.entry("Short", strategy.short, qty = qtySize, comment = str.format("R:{0,number,#.##}%", finalRiskPercent * 100))
    strategy.exit("Exit_S", "Short", stop = shortStop, limit = close - (stopDist * 2.5))

// 6. 視覺化 HUD (v6 Table API)
var table hud = table.new(position.top_right, 2, 4, bgcolor = color.new(color.black, 30), border_width = 1)
if barstate.islast
    table.cell(hud, 0, 0, "Metric", text_color = color.white)
    table.cell(hud, 1, 0, "Value", text_color = color.white)
    table.cell(hud, 0, 1, "Trend (ADX)", text_color = color.white)
    table.cell(hud, 1, 1, str.tostring(adxValue, "#.##"), bgcolor = isHighTrend ? color.teal : color.red)
    table.cell(hud, 0, 2, "Volatility", text_color = color.white)
    table.cell(hud, 1, 2, isHighVol ? "HIGH" : "SAFE", bgcolor = isHighVol ? color.red : color.teal)
    table.cell(hud, 0, 3, "Final Risk", text_color = color.white)
    table.cell(hud, 1, 3, str.tostring(finalRiskPercent * 100, "#.##") + "%", text_color = color.yellow)

plot(emaF, color = color.aqua), plot(emaS, color = color.orange)
