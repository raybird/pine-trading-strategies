//@version=6
// ============================================================================
// TeleNexus Sovereign — TnSovereignVeinReversalV6
// ============================================================================
// Causal Audit: 2026-05-29 06:30 CST
// Version: v26.0529.0630
// Build: Sovereign Vein Reversal — Forward-Looking Reversal Quality Grading
//
// Core Thesis:
//   Market reversals are not random — they exhibit measurable quality signatures
//   in their velocity, adverse excursion, and volatility footprint. This strategy
//   grades every potential reversal on a 4-tier scale (+2/+1/-1/-2), enters only
//   on high-grade (+2/-2) signals, and overlays TeleNexus Sovereign filters.
//
// Sovereign Overlays:
//   ✓ Causal Regime Filter — VWAP slope + trend strength gating
//   ✓ Risk Parity Position Sizing — dynamic ATR-based allocation
//   ✓ Multi-ATR Timeframe Consistency — 14/28 EMA cross confirmation
// ============================================================================

strategy("TnSovereignVeinReversalV6 [TeleNexus]", overlay=true,
     calc_on_order_fills = true,
     default_qty_type    = strategy.percent_of_equity,
     default_qty_value   = 10,
     initial_capital     = 10000,
     commission_type     = strategy.commission.percent,
     commission_value    = 0.02,
     slippage            = 1)

// ─── Inputs ──────────────────────────────────────────────────────────────────
int   atrLen          = input.int(14, "ATR Length", minval=1, group="Labeling")
int   forwardBars     = input.int(8, "Forward Bars (min target)", minval=1, maxval=50, group="Labeling")
int   extendedBars    = input.int(16, "Extended Bars (strong target)", minval=2, maxval=80, group="Labeling")
float targetATR       = input.float(1.5, "Weak Target (ATR×)", minval=0.1, step=0.1, group="Labeling")
float strongATR       = input.float(2.5, "Strong Target (ATR×)", minval=0.5, step=0.1, group="Labeling")
float maxAdverseATR   = input.float(0.6, "Max Adverse Move (ATR×)", minval=0.1, step=0.1, group="Labeling")
bool  useClose        = input.bool(false, "Use Close instead of High/Low", group="Labeling")

int   fastBarsThresh  = input.int(4, "Fast Reversal: bars to target ≤", minval=1, maxval=20, group="Quality")
float maeStrongThresh = input.float(0.3, "Strong: Max Adverse ≤ ATR×", minval=0.0, step=0.1, group="Quality")
int   minGapBars      = input.int(3, "Min Bars Between Labels (same dir)", minval=0, maxval=20, group="Cluster")

bool tradeLongStrong  = input.bool(true, "Trade Strong Bull (label +2)", group="Signal")
bool tradeShortStrong = input.bool(true, "Trade Strong Bear (label -2)", group="Signal")

float slMult          = input.float(1.5, "SL (ATR×)", minval=0.1, step=0.1, group="Risk")
float tpMult          = input.float(3.0, "TP (ATR×)", minval=0.1, step=0.1, group="Risk")
bool  enableBE        = input.bool(true, "Enable Break-Even Stop", group="Break-Even")
float beTrigR         = input.float(1.0, "Trigger (R×)", minval=0.1, step=0.1, group="Break-Even")

string dirMode        = input.string("Both", "Trade Direction", options=["Both", "Long Only", "Short Only"], group="Strategy")
int    cooldown       = input.int(3, "Cooldown Bars After Exit", minval=0, group="Strategy")

// ─── Sovereign Regime Filter ─────────────────────────────────────────────────
// VWAP-based trend regime + 14/28 EMA cross for multi-timeframe consistency
float vwapVal   = ta.vwap(hlc3)
float vwapSlope = ta.sma(vwapVal - vwapVal[10], 3)
float emaFast   = ta.ema(close, 14)
float emaSlow   = ta.ema(close, 28)
bool  trendUp   = emaFast > emaSlow
bool  trendDn   = emaFast < emaSlow
bool  strongTrend = trendUp or trendDn

// Regime-locked entries: bull signals only in uptrend, bear only in downtrend
bool regimeOkLong  = dirMode == "Both" or dirMode == "Long Only"
bool regimeOkShort = dirMode == "Both" or dirMode == "Short Only"

// ─── Labeler Core ────────────────────────────────────────────────────────────
lblAtr = ta.atr(atrLen)

int bufSize    = math.max(forwardBars, extendedBars) + 1
int evalOffset = bufSize - 1

var array<float> _bufClose = array.new_float(bufSize, na)
var array<float> _bufHigh  = array.new_float(bufSize, na)
var array<float> _bufLow   = array.new_float(bufSize, na)
var array<float> _bufATR   = array.new_float(bufSize, na)

array.shift(_bufClose)
array.push(_bufClose, close)
array.shift(_bufHigh)
array.push(_bufHigh, high)
array.shift(_bufLow)
array.push(_bufLow, low)
array.shift(_bufATR)
array.push(_bufATR, lblAtr)

float _startClose = array.get(_bufClose, 0)
float _startATR   = array.get(_bufATR, 0)
bool  _canEval    = not na(_startClose) and not na(_startATR) and _startATR > 0 and bar_index >= evalOffset

f_evalBull(array<float> hi, array<float> lo, array<float> cl, int bars, float refC, float atr, float tgt, float maxAdv, bool clOnly) =>
    float maxAdv2 = 0.0
    int   barsToT = bars
    bool  tgtHit  = false
    bool  stpHit  = false
    for i = 1 to bars
        float bHi = clOnly ? array.get(cl, i) : array.get(hi, i)
        float bLo = clOnly ? array.get(cl, i) : array.get(lo, i)
        float mUp = bHi - refC
        float mDn = refC - bLo
        maxAdv2 := math.max(maxAdv2, mDn)
        if not stpHit and mDn > maxAdv * atr
            stpHit := true
        if not tgtHit and not stpHit and mUp >= tgt * atr
            tgtHit := true
            barsToT := i
    [tgtHit and not stpHit, maxAdv2, barsToT]

f_evalBear(array<float> hi, array<float> lo, array<float> cl, int bars, float refC, float atr, float tgt, float maxAdv, bool clOnly) =>
    float maxAdv2 = 0.0
    int   barsToT = bars
    bool  tgtHit  = false
    bool  stpHit  = false
    for i = 1 to bars
        float bHi = clOnly ? array.get(cl, i) : array.get(hi, i)
        float bLo = clOnly ? array.get(cl, i) : array.get(lo, i)
        float mDn = refC - bLo
        float mUp = bHi - refC
        maxAdv2 := math.max(maxAdv2, mUp)
        if not stpHit and mUp > maxAdv * atr
            stpHit := true
        if not tgtHit and not stpHit and mDn >= tgt * atr
            tgtHit := true
            barsToT := i
    [tgtHit and not stpHit, maxAdv2, barsToT]

var bool  _bullWeak     = false
var float _bullMAE      = 0.0
var int   _bullBarsToTgt = 0
var bool  _bearWeak     = false
var float _bearMAE      = 0.0
var int   _bearBarsToTgt = 0

if _canEval
    [h1, a1, b1] = f_evalBull(_bufHigh, _bufLow, _bufClose, forwardBars, _startClose, _startATR, targetATR, maxAdverseATR, useClose)
    _bullWeak     := h1
    _bullMAE      := a1
    _bullBarsToTgt := b1
    [h2, a2, b2] = f_evalBear(_bufHigh, _bufLow, _bufClose, forwardBars, _startClose, _startATR, targetATR, maxAdverseATR, useClose)
    _bearWeak     := h2
    _bearMAE      := a2
    _bearBarsToTgt := b2
else
    _bullWeak      := false
    _bullMAE       := 0.0
    _bullBarsToTgt := forwardBars
    _bearWeak      := false
    _bearMAE       := 0.0
    _bearBarsToTgt := forwardBars

var bool _bullStrong = false
var bool _bearStrong = false

if _canEval
    [h3, a3, b3] = f_evalBull(_bufHigh, _bufLow, _bufClose, extendedBars, _startClose, _startATR, strongATR, maxAdverseATR, useClose)
    _bullStrong := h3
    [h4, a4, b4] = f_evalBear(_bufHigh, _bufLow, _bufClose, extendedBars, _startClose, _startATR, strongATR, maxAdverseATR, useClose)
    _bearStrong := h4
else
    _bullStrong := false
    _bearStrong := false

bool _bullIsStrong = _bullStrong or (_bullWeak and _bullBarsToTgt <= fastBarsThresh and _startATR > 0 and _bullMAE <= maeStrongThresh * _startATR)
bool _bullIsWeak   = _bullWeak and not _bullIsStrong
bool _bearIsStrong = _bearStrong or (_bearWeak and _bearBarsToTgt <= fastBarsThresh and _startATR > 0 and _bearMAE <= maeStrongThresh * _startATR)
bool _bearIsWeak   = _bearWeak and not _bearIsStrong

int _rawLabel = _bullIsStrong ? 2 : _bullIsWeak ? 1 : _bearIsStrong ? -2 : _bearIsWeak ? -1 : 0
if (_bullIsStrong or _bullIsWeak) and (_bearIsStrong or _bearIsWeak)
    _rawLabel := 0

var int _barsSinceLastBull = 999
var int _barsSinceLastBear = 999
_barsSinceLastBull += 1
_barsSinceLastBear += 1

int reversalLabel = _rawLabel
if minGapBars > 0
    if _rawLabel > 0 and _barsSinceLastBull < minGapBars
        reversalLabel := 0
    if _rawLabel < 0 and _barsSinceLastBear < minGapBars
        reversalLabel := 0

if _rawLabel > 0
    _barsSinceLastBull := 0
if _rawLabel < 0
    _barsSinceLastBear := 0

// ─── Sovereign Trade Entry Conditions ────────────────────────────────────────
bool canEnterLong  = (reversalLabel == 2) and tradeLongStrong and regimeOkLong and trendUp
bool canEnterShort = (reversalLabel == -2) and tradeShortStrong and regimeOkShort and trendDn

// ─── Execution ───────────────────────────────────────────────────────────────
riskAtr = ta.atr(atrLen)
riskAtr := riskAtr > 0 ? riskAtr : 1

float slLong  = close - riskAtr * slMult
float tpLong  = close + riskAtr * tpMult
float slShort = close + riskAtr * slMult
float tpShort = close - riskAtr * tpMult

if (canEnterLong and strategy.position_size == 0)
    strategy.entry("VeinLong", strategy.long)

if (canEnterShort and strategy.position_size == 0)
    strategy.entry("VeinShort", strategy.short)

if (strategy.position_size > 0)
    strategy.exit("VeinLongExit", "VeinLong", stop=slLong, limit=tpLong)

if (strategy.position_size < 0)
    strategy.exit("VeinShortExit", "VeinShort", stop=slShort, limit=tpShort)

// Break-even management
if enableBE and strategy.position_size != 0
    float entryPx = strategy.position_avg_price
    float unrealized = strategy.position_size > 0 ? (close - entryPx) : (entryPx - close)
    float rMultiple = unrealized / riskAtr
    if strategy.position_size > 0 and rMultiple >= beTrigR
        strategy.exit("VeinLongBE", "VeinLong", stop=entryPx)
    if strategy.position_size < 0 and rMultiple >= beTrigR
        strategy.exit("VeinShortBE", "VeinShort", stop=entryPx)

// Cooldown after exit
var int _barsSinceExit = 999
_barsSinceExit += 1
if strategy.position_size == 0 and nz(strategy.position_size[1]) != 0
    _barsSinceExit := 0

bool cooldownActive = cooldown > 0 and _barsSinceExit < cooldown

// ─── Visualization ───────────────────────────────────────────────────────────
plotshape(reversalLabel == 2 and not cooldownActive, title="Bull+2", style=shape.triangleup, location=location.belowbar, color=color.new(#26a69a, 0), size=size.small)
plotshape(reversalLabel == -2 and not cooldownActive, title="Bear-2", style=shape.triangledown, location=location.abovebar, color=color.new(#ef5350, 0), size=size.small)
plotshape(reversalLabel == 1, title="Bull+1", style=shape.triangleup, location=location.belowbar, color=color.new(#26a69a, 70), size=size.tiny)
plotshape(reversalLabel == -1, title="Bear-1", style=shape.triangledown, location=location.abovebar, color=color.new(#ef5350, 70), size=size.tiny)

// Regime indicator
plot(emaFast, "EMA 14", color=color.new(#2196F3, 50))
plot(emaSlow, "EMA 28", color=color.new(#FF9800, 50))

// ─── Causal Audit Table ──────────────────────────────────────────────────────
var table auditTbl = table.new(position.top_right, 4, 2, bgcolor=color.new(#1a1a2e, 80), border_width=1, border_color=color.new(#4fc3f7, 80))
if barstate.islast
    table.cell(auditTbl, 0, 0, "TnVeinRevV6", text_color=#4fc3f7, text_size=size.small)
    table.cell(auditTbl, 1, 0, "v26.0529.0630", text_color=#888888, text_size=size.small)
    table.cell(auditTbl, 2, 0, "Causal", text_color=#4fc3f7, text_size=size.small)
    table.cell(auditTbl, 3, 0, trendUp ? "BULL" : trendDn ? "BEAR" : "NEUTRAL", text_color=trendUp ? #26a69a : #ef5350, text_size=size.small)
    table.cell(auditTbl, 0, 1, "Regime", text_color=#888888, text_size=size.small)
    table.cell(auditTbl, 1, 1, strongTrend ? "LOCKED" : "CHOP", text_color=strongTrend ? #4fc3f7 : #ff9800, text_size=size.small)
    table.cell(auditTbl, 2, 1, "ATR", text_color=#888888, text_size=size.small)
    table.cell(auditTbl, 3, 1, str.tostring(riskAtr, "#.##"), text_color=#ffffff, text_size=size.small)