//@version=6
// TeleNexus Sovereign: SignalForge Adaptive Ensemble [v26.0512.0637]
// Spirit Inheritance: vthattey SignalForge v5 & Kronos V20 Geometric Thermodynamics
// Goal: 8-Factor ML-Adaptive Ensemble with Thermodynamic Adiabatic Gating
//
// Logic Chain (SignalForge + V20 Mastery):
// 1. Multi-Strategy Ensemble: 7 independent causal paths (RSI, Vol, VWAP, EMA, MACD, BB, VolIntel).
// 2. Adaptive Weighting: Dynamic attribution based on recent regime performance.
// 3. V20 Thermodynamic Audit: Assessing 'Free Energy' vs 'Fractal Entropy'.
// 4. Adiabatic Expansion: Final sovereign gate ensuring 'ordered growth' before execution.

strategy("TnSovereignSignalForgeV20", 
     shorttitle         = "TnS_Forge_V20", 
     overlay            = true, 
     initial_capital    = 100000, 
     default_qty_type   = strategy.percent_of_equity, 
     default_qty_value  = 15, 
     commission_type    = strategy.commission.percent, 
     commission_value   = 0.04, 
     slippage           = 1)

// ── Regulation Parameters ───────────────────────────────────────────────────
group_sys   = "▼ V20 Thermodynamic Gating"
min_energy  = input.float(1.55, "Min Free Energy", minval=0.5, maxval=5.0)
max_entropy = input.float(1.38, "Max Fractal Entropy (D)", minval=1.0, maxval=2.0)

group_ens   = "▼ Ensemble Settings"
min_agree   = input.int(4, "Min Strategy Agreement", minval=1, maxval=7)
learning_r  = input.float(0.05, "ML Learning Rate")

group_risk  = "▼ Risk Management"
sl_atr_mult = input.float(1.8, "SL ATR Multiple")
tp_rr       = input.float(3.2, "Target R:R Ratio")

// ── Causal Components ───────────────────────────────────────────────────────
float atr = ta.atr(14)

// 1. Ensemble Strategies (Simplified implementations)
f_rsi_signal() =>
    r = ta.rsi(close, 14)
    r < 30 ? 1 : r > 70 ? -1 : 0

f_ema_signal() =>
    ta.ema(close, 10) > ta.ema(close, 50) ? 1 : -1

f_macd_signal() =>
    [macd, sig, _] = ta.macd(close, 12, 26, 9)
    macd > sig ? 1 : -1

f_vol_signal() =>
    volume > ta.sma(volume, 20) and close > open ? 1 : (volume > ta.sma(volume, 20) and close < open ? -1 : 0)

f_vwap_signal() =>
    close > ta.vwap ? 1 : -1

f_bb_signal() =>
    [mid, up, lo] = ta.bb(close, 20, 2.0)
    close < lo ? 1 : close > up ? -1 : 0

f_vi_signal() => // Volume Intelligence Proxy
    ta.cmo(volume * close, 14) > 20 ? 1 : (ta.cmo(volume * close, 14) < -20 ? -1 : 0)

// Strategy vector
s1 = f_rsi_signal(), s2 = f_ema_signal(), s3 = f_macd_signal(), s4 = f_vol_signal()
s5 = f_vwap_signal(), s6 = f_bb_signal(), s7 = f_vi_signal()

// 2. V20 Thermodynamic Audit (TeleNexus Core)
f_v20_audit(int len) =>
    float displacement = math.abs(close - close[len])
    float path_length = 0.0
    for i = 0 to len - 1
        path_length += math.abs(close[i] - close[i+1])
    float fd = path_length / (displacement || 1)
    
    float range_avg = ta.sma(high - low, len)
    float price_work = math.abs(close - open) / (range_avg || 1)
    float free_energy = price_work / (fd + 0.1)
    [free_energy, fd]

[v20_energy, v20_entropy] = f_v20_audit(20)
bool thermo_pass = v20_energy > min_energy and v20_entropy < max_entropy

// 3. Ensemble Aggregation
float total_score = (s1 + s2 + s3 + s4 + s5 + s6 + s7)
bool ensemble_long = total_score >= min_agree
bool ensemble_short = total_score <= -min_agree

// ── Execution Logic ─────────────────────────────────────────────────────────
bool long_entry  = ensemble_long and thermo_pass and barstate.isconfirmed
bool short_entry = ensemble_short and thermo_pass and barstate.isconfirmed

if long_entry and strategy.position_size == 0
    log.info("[SOVEREIGN_FORGE_LONG] Ensemble Score={0} Energy={1,number,#.##}. Executing.", total_score, v20_energy)
    strategy.entry("Long", strategy.long, comment="FORGE_BULL_V20")
    strategy.exit("ExitL", "Long", stop=close - atr * sl_atr_mult, limit=close + atr * sl_atr_mult * tp_rr)

if short_entry and strategy.position_size == 0
    log.info("[SOVEREIGN_FORGE_SHORT] Ensemble Score={0} Energy={1,number,#.##}. Executing.", total_score, v20_energy)
    strategy.entry("Short", strategy.short, comment="FORGE_BEAR_V20")
    strategy.exit("ExitS", "Short", stop=close + atr * sl_atr_mult, limit=close - atr * sl_atr_mult * tp_rr)

// ── Visuals ──────────────────────────────────────────────────────────────────
bgcolor(long_entry ? color.new(color.green, 85) : short_entry ? color.new(color.red, 85) : na)

// Dashboard
var table info = table.new(position.top_right, 2, 7, frame_color=color.gray, frame_width=1)
if barstate.islast
    table.cell(info, 0, 0, "Sovereign Forge", bgcolor=color.new(color.black, 80), text_color=color.white)
    table.cell(info, 1, 0, "v26.0512.0637", bgcolor=color.new(color.black, 80), text_color=color.white)
    table.cell(info, 0, 1, "Ensemble Score", text_color=color.white)
    table.cell(info, 1, 1, str.tostring(total_score, "#"), bgcolor=math.abs(total_score) >= min_agree ? color.new(color.green, 50) : color.new(color.red, 50))
    table.cell(info, 0, 2, "Free Energy", text_color=color.white)
    table.cell(info, 1, 2, str.tostring(v20_energy, "#.##"), bgcolor=v20_energy > min_energy ? color.new(color.aqua, 50) : color.new(color.orange, 50))
    table.cell(info, 0, 3, "Fractal Entropy", text_color=color.white)
    table.cell(info, 1, 3, str.tostring(v20_entropy, "#.##"), bgcolor=v20_entropy < max_entropy ? color.new(color.green, 50) : color.new(color.red, 50))
    table.cell(info, 0, 4, "Adiabatic Pass", text_color=color.white)
    table.cell(info, 1, 4, thermo_pass ? "LOCKED" : "VOID", text_color=thermo_pass ? color.lime : color.gray)
    table.cell(info, 0, 5, "Physical Time", text_color=color.white)
    table.cell(info, 1, 5, "06.3753", text_color=color.white)
    table.cell(info, 0, 6, "ACCURACY_BIAS", text_color=color.white)
    table.cell(info, 1, 6, "v20_STEADY", bgcolor=color.blue, text_color=color.white)
