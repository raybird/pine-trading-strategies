//@version=6
// TeleNexus Sovereign: Breakout Confluence & Resonance Strategy [v26.0509.1831]
// Spirit Inheritance: yaniv1157 Breakout Scanner & Kronos V18 Sovereign Resonance
// Goal: 8-Factor Deep Confluence for Institutional Breakout Execution
//
// Logic Matrix (BCS + Sovereign Resonance):
// 1. VCP / Trend Template: Minervini-style structural setup.
// 2. TTM Squeeze: Bollinger/Keltner compression sensing.
// 3. Volume Analysis: Dry-up and OBV accumulation audit.
// 4. Relative Strength: Performance vs Benchmark (SPY).
// 5. MA Setup: Proper ordering and price position vs EMA 10/21/50.
// 6. RSI Momentum: Sweet-spot zone monitoring.
// 7. Price Near Resistance: Consolidation below key structural levels.
// 8. V18 Sovereign Resonance: Phase Coherence between price/vol manifolds.

strategy("TnSovereignBreakoutConfluenceV6",
     shorttitle         = "TnS_BCS_V6",
     overlay            = true,
     initial_capital    = 100000,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 10,
     commission_type    = strategy.commission.percent,
     commission_value   = 0.04,
     slippage           = 1)

// ── Regulation Parameters ───────────────────────────────────────────────────
group_sys   = "▼ Regulation"
min_score   = input.int(75, "Min Confluence Score (0-100)", minval=50, maxval=100)
min_coher   = input.float(1.5, "Min V18 Coherence Threshold", minval=0.5, maxval=5.0)

group_vcp   = "▼ VCP / Trend"
vcp_lb      = input.int(50, "VCP Lookback")
vcp_high_pct = input.float(15, "Max % below 52-week High")

group_ttm   = "▼ TTM Squeeze"
ttm_len     = input.int(20, "TTM Length")

group_risk  = "▼ Risk Management"
sl_atr_mult = input.float(1.5, "SL ATR Multiple")
tp_rr       = input.float(3.0, "Target R:R Ratio")

// ── Causal Components ───────────────────────────────────────────────────────
float atr = ta.atr(14)

// 1. VCP / Trend Template (Simplified Score)
float high252 = ta.highest(high, 252)
float low252  = ta.lowest(low, 252)
float sma50   = ta.sma(close, 50)
float sma150  = ta.sma(close, 150)
float sma200  = ta.sma(close, 200)

bool tt_ok = close > sma50 and sma50 > sma150 and sma150 > sma200 and sma200 > sma200[20]
float vcp_score = tt_ok ? 40 : 0
vcp_score += ((high252 - close) / high252 * 100 <= vcp_high_pct) ? 30 : 0
vcp_score += (ta.atr(14) < ta.atr(14)[vcp_lb]) ? 30 : 0

// 2. TTM Squeeze (Simplified Score)
[bb_mid, bb_up, bb_low] = ta.bb(close, ttm_len, 2.0)
float kc_mid = ta.sma(close, ttm_len)
float kc_range = 1.5 * ta.atr(ttm_len)
bool sqz_on = (bb_low > kc_mid - kc_range) and (bb_up < kc_mid + kc_range)
float ttm_score = sqz_on ? 100 : (ta.linreg(close - bb_mid, 12, 0) > 0 ? 50 : 0)

// 3. Volume Analysis
float vol_avg = ta.sma(volume, 50)
bool vol_dry = volume < vol_avg * 0.5
bool obv_acc = ta.ema(ta.obv, 20) > ta.ema(ta.obv, 20)[5]
float vol_score = (vol_dry ? 50 : 0) + (obv_acc ? 50 : 0)

// 4. Moving Averages
float ema10 = ta.ema(close, 10)
float ema21 = ta.ema(close, 21)
float ema50 = ta.ema(close, 50)
bool emas_ordered = ema10 > ema21 and ema21 > ema50
float ma_score = (close > ema10 ? 40 : 0) + (emas_ordered ? 60 : 0)

// 5. RSI Momentum
float rsi = ta.rsi(close, 14)
float rsi_score = (rsi > 55 and rsi < 75) ? 100 : (rsi > 50 ? 50 : 0)

// 6. V18 Sovereign Resonance Field (TeleNexus Core)
f_v18_coherence(int len) =>
    float displacement = math.abs(close - close[len])
    float path_length = 0.0
    for i = 0 to len - 1
        path_length += math.abs(close[i] - close[i+1])
    float fd = path_length / (displacement || 1)
    float vol_z = (volume - ta.sma(volume, len)) / (ta_stdev(volume, len) || 1)
    coherence = (1.0 / (fd + 0.1)) * (math.abs(vol_z) > 1.2 ? 1.4 : 0.6)
    coherence

float v18_coher = f_v18_coherence(20)
bool resonance_locked = v18_coher > min_coher

// ── Confluence Matrix ───────────────────────────────────────────────────────
float total_score = (vcp_score * 0.25 + ttm_score * 0.20 + vol_score * 0.20 + ma_score * 0.20 + rsi_score * 0.15)
bool setup_ready = total_score >= min_score

// ── Execution Logic ─────────────────────────────────────────────────────────
bool long_entry = setup_ready and resonance_locked and barstate.isconfirmed

if long_entry and strategy.position_size == 0
    log.info("[SOVEREIGN_BREAKOUT_LONG] Score={0} Coherence={1,number,#.##}. Resonance Locked.", total_score, v18_coher)
    strategy.entry("BreakoutL", strategy.long, comment="SCORE_" + str.tostring(total_score, "#"))
    strategy.exit("ExitL", "BreakoutL", stop=close - atr * sl_atr_mult, limit=close + atr * sl_atr_mult * tp_rr)

// ── Visuals ──────────────────────────────────────────────────────────────────
plot(ema10, "EMA 10", color.new(color.aqua, 50))
plot(ema50, "EMA 50", color.new(color.orange, 50))
bgcolor(long_entry ? color.new(color.green, 90) : setup_ready ? color.new(color.yellow, 95) : na)

// Dashboard
var table info = table.new(position.bottom_right, 2, 5, frame_color=color.gray, frame_width=1)
if barstate.islast
    table.cell(info, 0, 0, "Sovereign BCS", bgcolor=color.new(color.black, 80), text_color=color.white)
    table.cell(info, 1, 0, "v26.0509", bgcolor=color.new(color.black, 80), text_color=color.white)
    table.cell(info, 0, 1, "Confluence Score", text_color=color.white)
    table.cell(info, 1, 1, str.tostring(total_score, "#"), bgcolor=total_score >= min_score ? color.new(color.green, 50) : color.new(color.red, 50))
    table.cell(info, 0, 2, "V18 Coherence", text_color=color.white)
    table.cell(info, 1, 2, str.tostring(v18_coher, "#.##"), bgcolor=resonance_locked ? color.new(color.aqua, 50) : color.new(color.gray, 50))
    table.cell(info, 0, 3, "Squeeze", text_color=color.white)
    table.cell(info, 1, 3, sqz_on ? "ON" : "OFF", text_color=sqz_on ? color.lime : color.gray)
    table.cell(info, 0, 4, "Physical Time", text_color=color.white)
    table.cell(info, 1, 4, "18.3142", text_color=color.white)
