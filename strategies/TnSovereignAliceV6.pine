//@version=6
// TeleNexus Sovereign: Alice Taiwan Stock Trend Strategy [v26.0507.1015]
// Spirit Inheritance: Alice 5-Methodology & Kronos V17 Fractal Entropy
// Goal: High-Confidence Trend Judgment for TW Stocks
//
// Logic Matrix (Alice 5-Methods):
// 1. Kronos AI Prob: Mimicked via Multiscale Fractal Efficiency (V17 Logic).
// 2. RSI(14): Oversold < 40, Overbought > 70, Warning > 75.
// 3. BBands(20, 2): Breakout monitoring and Mean Reversion sensing.
// 4. Institutional Flow: Mimicked via Volume Delta & Price Trajectory.
// 5. MACD Histogram: Momentum acceleration/deceleration audit.

strategy("TnSovereignAliceV6",
     shorttitle         = "TnS_Alice_V6",
     overlay            = true,
     initial_capital    = 1000000,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 20,
     commission_type    = strategy.commission.percent,
     commission_value   = 0.1425, // TW Stock standard
     slippage           = 2)

// ── Regulation Parameters ───────────────────────────────────────────────────
group_alice = "🌸 Alice Methodology"
kronos_threshold = input.float(55.0, "Kronos Bullish Threshold (%)", minval=50, maxval=100)
rsi_ob = input.int(70, "RSI Overbought", minval=50)
rsi_os = input.int(40, "RSI Oversold", maxval=50)
inst_flow_min = input.float(100.0, "Min Inst. Flow (Unit: Base)", minval=0)

group_sys = "▼ Sovereign Gating"
confidence_level = input.int(3, "Min Suture Count (out of 5)", minval=3, maxval=5)
use_v17_gate = input.bool(true, "Enable V17 Fractal Gating")

// ── 1. Kronos AI Probability (V17 Simplified) ──────────────────────────────
// Using path efficiency as a proxy for 'Probability'
f_kronos_prob() =>
    window = 20
    d = Math.abs(close - close[window])
    p = 0.0
    for i = 0 to window - 1
        p += math.abs(close[i] - close[i+1])
    efficiency = d / (p || 1)
    // Scale efficiency to 0-100%
    math.min(100, efficiency * 120) 

float k_prob = f_kronos_prob()
bool m1_bull = k_prob > kronos_threshold
bool m1_bear = k_prob < (100 - kronos_threshold)

// ── 2. RSI(14) ─────────────────────────────────────────────────────────────
float rsi = ta.rsi(close, 14)
bool m2_bull = rsi < 50 // Alice: < 50 for healthy entry window
bool m2_bear = rsi > rsi_ob

// ── 3. BBands(20, 2) ───────────────────────────────────────────────────────
[bb_mid, bb_up, bb_low] = ta.bb(close, 20, 2)
bool m3_bull = close < bb_mid and close > bb_low // Near low or mid
bool m3_bear = close > bb_up

// ── 4. Institutional Flow (Proxy) ──────────────────────────────────────────
// Volume-Weighted Price Momentum as a proxy for institutional conviction
float inst_flow = ta.cmo(volume * close, 14) 
bool m4_bull = inst_flow > 20
bool m4_bear = inst_flow < -20

// ── 5. MACD Histogram ──────────────────────────────────────────────────────
[macd, signal, hist] = ta.macd(close, 12, 26, 9)
bool m5_bull = hist > 0 and hist > hist[1]
bool m5_bear = hist < 0 or hist < hist[1]

// ── Suture Matrix ───────────────────────────────────────────────────────────
int bull_score = (m1_bull ? 1 : 0) + (m2_bull ? 1 : 0) + (m3_bull ? 1 : 0) + (m4_bull ? 1 : 0) + (m5_bull ? 1 : 0)
int bear_score = (m1_bear ? 1 : 0) + (m2_bear ? 1 : 0) + (m3_bear ? 1 : 0) + (m4_bear ? 1 : 0) + (m5_bear ? 1 : 0)

bool alice_entry = bull_score >= confidence_level
bool alice_exit  = bear_score >= confidence_level

// ── V17 Fractal Gating ──────────────────────────────────────────────────────
float window_range = ta.highest(high, 20) - ta.lowest(low, 20)
float path_length = 0.0
for i = 0 to 19
    path_length += math.abs(close[i] - close[i+1])
float v17_fractal_eff = window_range / (path_length || 1)
bool v17_gate = use_v17_gate ? v17_fractal_eff > 0.4 : true

// ── Execution ───────────────────────────────────────────────────────────────
if alice_entry and v17_gate and strategy.position_size == 0
    log.info("[ALICE_BULL] Score={0}. Executing.", bull_score)
    strategy.entry("AliceL", strategy.long, comment="SCORE_" + str.tostring(bull_score))

if alice_exit and strategy.position_size > 0
    log.info("[ALICE_BEAR] Score={0}. Exiting.", bear_score)
    strategy.close("AliceL", comment="EXIT_" + str.tostring(bear_score))

// ── Visuals ──────────────────────────────────────────────────────────────────
plot(bb_up, "BB Up", color.new(color.gray, 80))
plot(bb_low, "BB Low", color.new(color.gray, 80))

// Dashboard
var table info = table.new(position.top_right, 2, 6, frame_color=color.gray, frame_width=1)
if barstate.islast
    table.cell(info, 0, 0, "Alice Method", bgcolor=color.new(color.purple, 80), text_color=color.white)
    table.cell(info, 1, 0, "v26.0507", bgcolor=color.new(color.purple, 80), text_color=color.white)
    table.cell(info, 0, 1, "Kronos Prob", text_color=k_prob > 55 ? color.lime : color.white)
    table.cell(info, 1, 1, str.tostring(k_prob, "#.#") + "%")
    table.cell(info, 0, 2, "Bull Score", text_color=color.white)
    table.cell(info, 1, 2, str.tostring(bull_score), bgcolor=bull_score >= 4 ? color.green : bull_score >= 3 ? color.olive : na)
    table.cell(info, 0, 3, "RSI", text_color=rsi > 70 ? color.red : color.white)
    table.cell(info, 1, 3, str.tostring(rsi, "#.#"))
    table.cell(info, 0, 4, "Inst. Flow", text_color=inst_flow > 0 ? color.aqua : color.orange)
    table.cell(info, 1, 4, str.tostring(inst_flow, "#.#"))
    table.cell(info, 0, 5, "V17 Gate", text_color=v17_gate ? color.lime : color.red)
    table.cell(info, 1, 5, v17_gate ? "PASS" : "BLOCK")

// Color Background on High Confidence
bgcolor(bull_score >= 4 ? color.new(color.green, 90) : na)
