//@version=6
strategy("Tn Sovereign Fisher v6 [v26.0425.1832]",
    shorttitle         = "TN_FISHER_v26",
    overlay            = true,
    initial_capital    = 100000,
    default_qty_type   = strategy.percent_of_equity,
    default_qty_value  = 10,
    commission_type    = strategy.commission.percent,
    commission_value   = 0.05,
    slippage           = 2,
    process_orders_on_close = true)

// =====================================================
// MODULE 1: SOVEREIGN FISHER DISCIPLINE
// =====================================================

groupFIS = "🌌 費雪轉換規訓 (Fisher Config)"
fisLen   = input.int(10, "費雪週期", minval=1, group=groupFIS)

// Fisher Transform Calculation
float high_  = ta.highest(hl2, fisLen)
float low_   = ta.lowest(hl2, fisLen)
float value  = 0.0
value := 0.66 * ((hl2 - low_) / (math.max(high_ - low_, 0.001)) - 0.5) + 0.67 * nz(value[1])
float norm   = value > 0.99 ? 0.999 : value < -0.99 ? -0.999 : value
float fish1  = 0.0
fish1 := 0.5 * math.log((1 + norm) / (1 - norm)) + 0.5 * nz(fish1[1])
float fish2  = fish1[1]

bool bullPol = fish1 > fish2
bool bearPol = fish1 < fish2

// =====================================================
// MODULE 2: REGIME & ENERGY AUDIT
// =====================================================

groupAudit = "🛡️ 因果過濾 (Audit Layers)"
trendLen   = input.int(200,   "趨勢地板 (EMA)", group=groupAudit)
atrLen     = input.int(14,    "ATR 週期", group=groupAudit)
slMult     = input.float(2.5, "止損 ATR 倍數", group=groupAudit)
tpMult     = input.float(5.0, "獲利 ATR 倍數", group=groupAudit)

float trendEma = ta.ema(close, trendLen)
float atrVal   = ta.atr(atrLen)

bool regimeBull = close > trendEma
bool regimeBear = close < trendEma

// =====================================================
// MODULE 3: CAUSAL SIGNALS & EXECUTION
// =====================================================

// Long: Fisher crossover AND Bullish Regime
bool longEntry  = ta.crossover(fish1, fish2) and regimeBull
// Short: Fisher crossunder AND Bearish Regime
bool shortEntry = ta.crossunder(fish1, fish2) and regimeBear

if longEntry and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, comment="FISH-B")
    strategy.exit("L-Exit", "Long", stop=close - slMult * atrVal, limit=close + tpMult * atrVal)

if shortEntry and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, comment="FISH-S")
    strategy.exit("S-Exit", "Short", stop=close + slMult * atrVal, limit=close - tpMult * atrVal)

// =====================================================
// MODULE 4: SOVEREIGN AUDIT HUD
// =====================================================

var table hud = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 70), border_width=1)
if barstate.isconfirmed
    table.cell(hud, 0, 0, "◈ FISHER SOV", text_color=color.white, bgcolor=color.new(color.navy, 20))
    table.cell(hud, 1, 0, "STATUS", text_color=color.white, bgcolor=color.new(color.navy, 20))
    
    table.cell(hud, 0, 1, "Fisher Val", text_color=color.gray)
    table.cell(hud, 1, 1, str.tostring(fish1, "##.##"), text_color=bullPol ? color.lime : color.red)
    
    table.cell(hud, 0, 2, "Regime Bias", text_color=color.gray)
    table.cell(hud, 1, 2, regimeBull ? "BULL" : regimeBear ? "BEAR" : "RANGE", text_color=regimeBull ? color.lime : color.red)
    
    table.cell(hud, 0, 3, "Volatility", text_color=color.gray)
    table.cell(hud, 1, 3, str.tostring(atrVal, "##.##"), text_color=color.aqua)
    
    table.cell(hud, 0, 4, "Version", text_color=color.gray)
    table.cell(hud, 1, 4, "v26.0425.1832", text_color=color.gray)

// Visuals
plot(trendEma, "Regime Floor", color.new(color.gray, 60), 2)
plot(fish1, "Fisher", color.new(color.blue, 50), 1, force_overlay=false)
plot(fish2, "Trigger", color.new(color.orange, 50), 1, force_overlay=false)
plotshape(longEntry, "Long", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(shortEntry, "Short", shape.triangledown, location.abovebar, color.red, size=size.small)
