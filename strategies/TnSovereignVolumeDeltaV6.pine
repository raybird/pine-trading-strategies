//@version=6
strategy("Tn Sovereign Volume Delta v6 [v26.0423.0602]",
    shorttitle         = "TN_DELTA_v26",
    overlay            = true,
    initial_capital    = 100000,
    default_qty_type   = strategy.percent_of_equity,
    default_qty_value  = 10,
    commission_type    = strategy.commission.percent,
    commission_value   = 0.05,
    slippage           = 2,
    process_orders_on_close = true)

// =====================================================
// MODULE 1: SOVEREIGN VOLUME DELTA (Mocked for standard charts)
// =====================================================
// Note: True order flow delta requires tick/volume data.
// We approximate delta divergence using price action & volume.

groupDelta = "🌌 能量分佈規訓 (Delta Config)"
deltaLen   = input.int(14, "能量平滑週期", minval=1, group=groupDelta)
divThresh  = input.float(0.5, "背離門檻", step=0.1, group=groupDelta)

// Approximation: Up volume vs Down volume based on intra-bar close vs open
float upVol   = close > open ? volume * (close - low) / (high - low == 0 ? 1 : high - low) : 0
float downVol = close < open ? volume * (high - close) / (high - low == 0 ? 1 : high - low) : 0
float delta   = upVol - downVol
float cumDelta = ta.sma(delta, deltaLen)

// =====================================================
// MODULE 2: REGIME & STRUCTURAL AUDIT
// =====================================================

groupAudit = "🛡️ 結構因果過濾 (Audit Layers)"
trendLen   = input.int(200,   "趨勢地板 (EMA)", group=groupAudit)
atrLen     = input.int(14,    "ATR 週期", group=groupAudit)
slMult     = input.float(2.0, "止損 ATR 倍數", step=0.1, group=groupAudit)
tpMult     = input.float(3.0, "獲利 ATR 倍數", step=0.1, group=groupAudit)

float trendEma = ta.ema(close, trendLen)
float atrVal   = ta.atr(atrLen)

bool regimeBull = close > trendEma
bool regimeBear = close < trendEma

// =====================================================
// MODULE 3: CAUSAL SIGNALS & EXECUTION
// =====================================================

// Divergence: Price making new low, but Delta making higher low (Bullish Divergence)
bool priceLow = low < ta.lowest(low, 5)[1]
bool deltaUp  = cumDelta > ta.lowest(cumDelta, 5)[1]
bool bullDiv  = priceLow and deltaUp and regimeBull

// Divergence: Price making new high, but Delta making lower high (Bearish Divergence)
bool priceHigh = high > ta.highest(high, 5)[1]
bool deltaDown = cumDelta < ta.highest(cumDelta, 5)[1]
bool bearDiv   = priceHigh and deltaDown and regimeBear

if bullDiv and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, comment="DELTA-B")
    strategy.exit("L-Exit", "Long", stop=close - slMult * atrVal, limit=close + tpMult * atrVal)

if bearDiv and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, comment="DELTA-S")
    strategy.exit("S-Exit", "Short", stop=close + slMult * atrVal, limit=close - tpMult * atrVal)

// =====================================================
// MODULE 4: SOVEREIGN AUDIT HUD
// =====================================================

var table hud = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 70), border_width=1)
if barstate.isconfirmed
    table.cell(hud, 0, 0, "◈ DELTA SOV", text_color=color.white, bgcolor=color.new(color.navy, 20))
    table.cell(hud, 1, 0, "STATUS", text_color=color.white, bgcolor=color.new(color.navy, 20))
    
    table.cell(hud, 0, 1, "Cum Delta", text_color=color.gray)
    table.cell(hud, 1, 1, str.tostring(cumDelta, "##.##"), text_color=cumDelta > 0 ? color.lime : color.red)
    
    table.cell(hud, 0, 2, "Regime Audit", text_color=color.gray)
    table.cell(hud, 1, 2, regimeBull ? "BULL-BIAS" : "BEAR-BIAS", text_color=regimeBull ? color.lime : color.red)
    
    table.cell(hud, 0, 3, "Volatility", text_color=color.gray)
    table.cell(hud, 1, 3, str.tostring(atrVal, "##.##"), text_color=color.aqua)
    
    table.cell(hud, 0, 4, "Version", text_color=color.gray)
    table.cell(hud, 1, 4, "v26.0423.0602", text_color=color.gray)

// Visuals
plot(trendEma, "Trend Floor", color.new(color.gray, 60), 1)
plotshape(bullDiv, "Long", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(bearDiv, "Short", shape.triangledown, location.abovebar, color.red, size=size.small)
