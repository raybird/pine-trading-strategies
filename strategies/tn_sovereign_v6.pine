//@version=6
// TN Sovereign V6 — Causal Multi-Layer Audit Strategy
// Author: TeleNexus (Raybird)
// Timezone: Asia/Taipei (CST)
// Version: 1.0.0 (2026-04-08 18:30)
//
// 核心規訓 (Core Mandate):
// 1. Enum 類型安全: 使用 enum 管理趨勢狀態與信號等級。
// 2. 動態時間框架: 利用 request.security_lower_tf 進行微觀結構審計。
// 3. 4 層因果過濾: 結合 Hacim, ATR 波動, HTF 趨勢及 EMA 排列。

strategy("TN Sovereign V6 [TeleNexus]", 
     overlay=true, 
     initial_capital=10000, 
     default_qty_type=strategy.percent_of_equity, 
     default_qty_value=10, 
     commission_type=strategy.commission.percent, 
     commission_value=0.075,
     margin_long=1, margin_short=1)

// ── Enum 規訓 ─────────────────────────────────────────────────────────────
enum TrendState
    BULLISH
    BEARISH
    NEUTRAL

enum SignalGrade
    SOVEREIGN // Score 4
    STRONG    // Score 3
    WEAK      // Score 1-2
    VOID      // Score 0

// ── Inputs ───────────────────────────────────────────────────────────────
string htfTF    = input.string("D", "HTF Timeframe", options=["60","240","D","W"])
int    htfLen   = input.int(50, "HTF EMA Length", minval=10)
float  volMult  = input.float(1.5, "Volume Multiplier", step=0.1)
float  atrMult  = input.float(0.5, "ATR Noise Filter", step=0.1)
int    fastLen  = input.int(9, "Fast EMA", minval=1)
int    slowLen  = input.int(21, "Slow EMA", minval=1)
int    minScore = input.int(3, "Min Sovereign Score", minval=1, maxval=4)

// ── 數據獲取 (v6 Dynamic Requests) ───────────────────────────────────────
// HTF 趨勢審計
float htfEma = request.security(syminfo.tickerid, htfTF, ta.ema(close, htfLen)[1], lookahead=barmerge.lookahead_on)
TrendState htfTrend = close > htfEma ? TrendState.BULLISH : TrendState.BEARISH

// ── 4 層因果過濾 ──────────────────────────────────────────────────────────
float volAvg = ta.sma(volume, 20)
float atrVal = ta.atr(14)
float fastEma = ta.ema(close, fastLen)
float slowEma = ta.ema(close, slowLen)

bool f1_vol    = volume > volAvg * volMult
bool f2_htf    = htfTrend == TrendState.BULLISH
bool f3_atr    = math.abs(close - close[1]) > atrVal * atrMult
bool f4_align  = fastEma > slowEma

// ── 評分系統 ─────────────────────────────────────────────────────────────
int score = (f1_vol ? 1 : 0) + (f2_htf ? 1 : 0) + (f3_atr ? 1 : 0) + (f4_align ? 1 : 0)

SignalGrade grade = switch score
    4 => SignalGrade.SOVEREIGN
    3 => SignalGrade.STRONG
    1, 2 => SignalGrade.WEAK
    => SignalGrade.VOID

bool isSovereign = score >= minScore

// ── 進出場邏輯 ────────────────────────────────────────────────────────────
bool longCondition  = ta.crossover(fastEma, slowEma) and isSovereign and htfTrend == TrendState.BULLISH
bool shortCondition = ta.crossunder(fastEma, slowEma) and isSovereign and htfTrend == TrendState.BEARISH

if longCondition
    strategy.entry("Long", strategy.long, comment="SOVEREIGN_BUY")
    strategy.exit("LX", "Long", stop=close - atrVal * 2, limit=close + atrVal * 4, comment_loss="SL", comment_profit="TP")

if shortCondition
    strategy.entry("Short", strategy.short, comment="SOVEREIGN_SELL")
    strategy.exit("SX", "Short", stop=close + atrVal * 2, limit=close - atrVal * 4, comment_loss="SL", comment_profit="TP")

// ── 視覺化 ───────────────────────────────────────────────────────────────
plot(fastEma, "Fast EMA", color.new(color.aqua, 0), 2)
plot(slowEma, "Slow EMA", color.new(color.orange, 0), 2)
plot(htfEma, "HTF EMA", color.new(color.yellow, 30), 3)

bgcolor(htfTrend == TrendState.BULLISH ? color.new(color.green, 90) : color.new(color.red, 90))

plotshape(longCondition, "Long Signal", shape.triangleup, location.belowbar, color.green, size=size.normal)
plotshape(shortCondition, "Short Signal", shape.triangledown, location.abovebar, color.red, size=size.normal)

// 狀態儀表板
var table board = table.new(position.top_right, 2, 2, border_width=1)
if barstate.islast
    table.cell(board, 0, 0, "Trend Status", bgcolor=color.gray, text_color=color.white)
    table.cell(board, 1, 0, htfTrend == TrendState.BULLISH ? "BULL" : "BEAR", bgcolor=htfTrend == TrendState.BULLISH ? color.green : color.red)
    table.cell(board, 0, 1, "Signal Grade", bgcolor=color.gray, text_color=color.white)
    table.cell(board, 1, 1, str.tostring(score) + "/4", bgcolor=isSovereign ? color.green : color.orange)
