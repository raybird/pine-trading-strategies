//@version=6
strategy("Tn Sovereign STC v6 [v26.0426.0632]",
    shorttitle         = "TN_STC_v26",
    overlay            = true,
    initial_capital    = 100000,
    default_qty_type   = strategy.percent_of_equity,
    default_qty_value  = 10,
    commission_type    = strategy.commission.percent,
    commission_value   = 0.05,
    slippage           = 2,
    process_orders_on_close = true)

// =====================================================
// MODULE 1: SOVEREIGN STC DISCIPLINE
// =====================================================

groupSTC = "🌌 謝夫週期規訓 (STC Config)"
stcLen   = input.int(10, "STC 週期", minval=1, group=groupSTC)
fastLen  = input.int(23, "快線 MACD", minval=1, group=groupSTC)
slowLen  = input.int(50, "慢線 MACD", minval=1, group=groupSTC)
stcUpper = input.float(75, "超買邊界", group=groupSTC)
stcLower = input.float(25, "超賣邊界", group=groupSTC)

// STC Calculation Logic
float macdVal = ta.ema(close, fastLen) - ta.ema(close, slowLen)

calcSTC(source, length) =>
    float lowest  = ta.lowest(source, length)
    float highest = ta.highest(source, length)
    float stoch   = (source - lowest) / (math.max(highest - lowest, 0.00001)) * 100
    float res     = 0.0
    res := nz(res[1]) + (0.5 * (stoch - nz(res[1])))
    res

float dStoch1 = calcSTC(macdVal, stcLen)
float stcVal  = calcSTC(dStoch1, stcLen)

bool bullPol = stcVal > stcVal[1]
bool bearPol = stcVal < stcVal[1]

// =====================================================
// MODULE 2: REGIME & RISK AUDIT
// =====================================================

groupAudit = "🛡️ 因果過濾 (Audit Layers)"
trendLen   = input.int(200,   "趨勢地板 (EMA)", group=groupAudit)
atrLen     = input.int(14,    "ATR 週期", group=groupAudit)
slMult     = input.float(3.0, "止損 ATR 倍數", group=groupAudit)
tpMult     = input.float(6.0, "獲利 ATR 倍數", group=groupAudit)

float trendEma = ta.ema(close, trendLen)
float atrVal   = ta.atr(atrLen)

bool regimeBull = close > trendEma
bool regimeBear = close < trendEma

// =====================================================
// MODULE 3: CAUSAL SIGNALS & EXECUTION
// =====================================================

// Long: STC turns UP from below 25 AND Bullish Regime
bool longEntry  = ta.crossover(stcVal, stcLower) and bullPol and regimeBull
// Short: STC turns DOWN from above 75 AND Bearish Regime
bool shortEntry = ta.crossunder(stcVal, stcUpper) and bearPol and regimeBear

if longEntry and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, comment="STC-B")
    strategy.exit("L-Exit", "Long", stop=close - slMult * atrVal, limit=close + tpMult * atrVal)

if shortEntry and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, comment="STC-S")
    strategy.exit("S-Exit", "Short", stop=close + slMult * atrVal, limit=close - tpMult * atrVal)

// =====================================================
// MODULE 4: SOVEREIGN AUDIT HUD
// =====================================================

var table hud = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 70), border_width=1)
if barstate.isconfirmed
    table.cell(hud, 0, 0, "◈ STC SOVEREIGN", text_color=color.white, bgcolor=color.new(color.navy, 20))
    table.cell(hud, 1, 0, "STATUS", text_color=color.white, bgcolor=color.new(color.navy, 20))
    
    table.cell(hud, 0, 1, "STC Value", text_color=color.gray)
    table.cell(hud, 1, 1, str.tostring(stcVal, "##.#"), text_color=bullPol ? color.lime : color.red)
    
    table.cell(hud, 0, 2, "Regime Bias", text_color=color.gray)
    table.cell(hud, 1, 2, regimeBull ? "UP" : regimeBear ? "DOWN" : "RANGE", text_color=regimeBull ? color.lime : color.red)
    
    table.cell(hud, 0, 3, "Volatility", text_color=color.gray)
    table.cell(hud, 1, 3, str.tostring(atrVal, "##.##"), text_color=color.aqua)
    
    table.cell(hud, 0, 4, "Version", text_color=color.gray)
    table.cell(hud, 1, 4, "v26.0426.0632", text_color=color.gray)

// Visuals
plot(trendEma, "Regime Floor", color.new(color.gray, 60), 2)
plot(stcVal, "STC", color.new(color.blue, 50), 1, force_overlay=false)
hline(stcUpper, "Upper", color.new(color.red, 70))
hline(stcLower, "Lower", color.new(color.green, 70))
plotshape(longEntry, "Long", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(shortEntry, "Short", shape.triangledown, location.abovebar, color.red, size=size.small)
