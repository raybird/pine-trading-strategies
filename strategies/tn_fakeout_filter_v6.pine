//@version=6
strategy("TN Sovereign Fakeout Filter v6", overlay=true, pyramiding=0, initial_capital=100000, commission_type=strategy.commission.percent, commission_value=0.05)

// ------------------------------------------------------------
// 🚀 CORE PHILOSOPHY: CAUSAL FILTERING & SOVEREIGN RISK
// This strategy implements a 4-layer signal quality scoring system
// to eliminate fakeouts and ensure high-conviction execution.
// Version: v26.0414.0010 [CST]
// ------------------------------------------------------------

// ── Inputs ───────────────────────────────────────────────────────────────────
groupFilter = "4-Layer Filter Settings"
htfTF       = input.string("60", "HTF Timeframe", options=["15","30","60","240","D"], group=groupFilter)
htfLen      = input.int(50, "HTF EMA Length", minval=10, group=groupFilter)
volLen      = input.int(20, "Volume MA Length", minval=5, group=groupFilter)
volMult     = input.float(1.5, "Volume Multiplier", step=0.1, group=groupFilter)
atrLen      = input.int(14, "ATR Length", minval=1, group=groupFilter)
atrMult     = input.float(0.3, "ATR Min Move (Mult)", step=0.05, group=groupFilter)
minScore    = input.int(3, "Min Sovereign Score (1-4)", minval=1, maxval=4, group=groupFilter)

groupEma    = "Signal Engine"
fastLen     = input.int(9, "Fast EMA", minval=1, group=groupEma)
slowLen     = input.int(21, "Slow EMA", minval= slowLen < fastLen ? fastLen + 1 : 21, group=groupEma)

groupRisk   = "Sovereign Risk Management"
riskPct     = input.float(1.0, "Risk Per Trade %", minval=0.1, step=0.1, group=groupRisk)
tpMult      = input.float(2.0, "Take Profit (ATR Mult)", minval=1.0, group=groupRisk)
slMult      = input.float(1.5, "Stop Loss (ATR Mult)", minval=1.0, group=groupRisk)

// ── Calculations ─────────────────────────────────────────────────────────────
float fastEma = ta.ema(close, fastLen)
float slowEma = ta.ema(close, slowLen)
float atrVal  = ta.atr(atrLen)
float volAvg  = ta.sma(volume, volLen)

// HTF trend — non-repainting alignment
float htfEma  = request.security(syminfo.tickerid, htfTF, ta.ema(close, htfLen)[1], lookahead=barmerge.lookahead_on)

// ── 4-Layer Causal Filters ─────────────────────────────────────────────────────
bool f1_vol    = volume > volAvg * volMult
bool f2_htf    = close > htfEma
bool f3_atr    = math.abs(close - close[1]) > atrVal * atrMult
bool f4_align  = fastEma > slowEma

// ── Sovereign Score Synthesis ──────────────────────────────────────────────────
int score = (f1_vol ? 1 : 0) + (f2_htf ? 1 : 0) + (f3_atr ? 1 : 0) + (f4_align ? 1 : 0)
bool hasSovereignConviction = score >= minScore

// ── Execution Logic ──────────────────────────────────────────────────────────
bool rawLong  = ta.crossover(fastEma, slowEma)
bool rawShort = ta.crossunder(fastEma, slowEma)

// Entry Conditions
bool longEntry  = rawLong and hasSovereignConviction
bool shortEntry = rawShort and (score <= (4 - minScore))

// Position Sizing based on ATR Risk
float riskAmount = strategy.equity * (riskPct / 100)
float stopDist   = atrVal * slMult
float quantity   = stopDist > 0 ? riskAmount / stopDist : 0.0

if longEntry
    strategy.entry("Sovereign Long", strategy.long, qty=quantity, comment="Score: " + str.tostring(score))
    strategy.exit("Exit Long", "Sovereign Long", stop=close - stopDist, limit=close + atrVal * tpMult)

if shortEntry
    strategy.entry("Sovereign Short", strategy.short, qty=quantity, comment="Score: " + str.tostring(score))
    strategy.exit("Exit Short", "Sovereign Short", stop=close + stopDist, limit=close - atrVal * tpMult)

// ── Visuals ──────────────────────────────────────────────────────────────────
plot(htfEma, color=color.new(color.blue, 50), title="HTF Trend Anchor")
plot(fastEma, color=color.lime, title="Fast EMA")
plot(slowEma, color=color.red, title="Slow EMA")

// Score Background
bgcolor(score >= 3 ? color.new(color.green, 90) : score <= 1 ? color.new(color.red, 90) : na)

// On-chart Information
var table infoBox = table.new(position.top_right, 2, 2, border_width=1)
if barstate.isconfirmed
    table.cell(infoBox, 0, 0, "Sovereign Score", bgcolor=color.new(color.black, 0), text_color=color.white)
    table.cell(infoBox, 1, 0, str.tostring(score), bgcolor=score >= 3 ? color.green : color.orange, text_color=color.white)
    table.cell(infoBox, 0, 1, "Conviction", bgcolor=color.new(color.black, 0), text_color=color.white)
    table.cell(infoBox, 1, 1, hasSovereignConviction ? "STABLE" : "WEAK", bgcolor=hasSovereignConviction ? color.green : color.red, text_color=color.white)
