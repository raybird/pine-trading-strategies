//@version=6
strategy("Tn Sovereign RSI ATR v6 [v26.0423.0003]",
    shorttitle         = "TN_RSI_v26",
    overlay            = true,
    initial_capital    = 100000,
    default_qty_type   = strategy.percent_of_equity,
    default_qty_value  = 10,
    commission_type    = strategy.commission.percent,
    commission_value   = 0.05,
    slippage           = 2,
    process_orders_on_close = true)

// =====================================================
// MODULE 1: SOVEREIGN MOMENTUM & VOLATILITY (RSI/ATR)
// =====================================================

groupRSI = "🌌 動能規訓 (RSI Config)"
rsiLen   = input.int(14,    "RSI 週期", minval=1, group=groupRSI)
rsiLong  = input.float(60,  "做多 RSI 門檻", minval=50, maxval=80, group=groupRSI)
rsiShort = input.float(40,  "做空 RSI 門檻", minval=20, maxval=50, group=groupRSI)

groupAudit = "🛡️ 因果過濾 (Audit Layers)"
trendLen   = input.int(200,   "趨勢地板 (EMA)", group=groupAudit)
atrLen     = input.int(14,    "ATR 週期", group=groupAudit)
slMult     = input.float(2.0, "止損 ATR 倍數", step=0.1, group=groupAudit)
tpMult     = input.float(4.0, "獲利 ATR 倍數", step=0.1, group=groupAudit)

float rsi      = ta.rsi(close, rsiLen)
float trendEma = ta.ema(close, trendLen)
float atrVal   = ta.atr(atrLen)

bool regimeBull = close > trendEma
bool regimeBear = close < trendEma

// =====================================================
// MODULE 2: CAUSAL SIGNALS & EXECUTION
// =====================================================

bool longEntry  = rsi > rsiLong and regimeBull
bool shortEntry = rsi < rsiShort and regimeBear

if longEntry and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, comment="RSI-B")
    strategy.exit("L-Exit", "Long", stop=close - slMult * atrVal, limit=close + tpMult * atrVal)

if shortEntry and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, comment="RSI-S")
    strategy.exit("S-Exit", "Short", stop=close + slMult * atrVal, limit=close - tpMult * atrVal)

// =====================================================
// MODULE 3: SOVEREIGN AUDIT HUD
// =====================================================

var table hud = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 70), border_width=1)
if barstate.isconfirmed
    table.cell(hud, 0, 0, "◈ RSI/ATR SOV", text_color=color.white, bgcolor=color.new(color.navy, 20))
    table.cell(hud, 1, 0, "STATUS", text_color=color.white, bgcolor=color.new(color.navy, 20))
    
    table.cell(hud, 0, 1, "RSI Val", text_color=color.gray)
    table.cell(hud, 1, 1, str.tostring(rsi, "##.##"), text_color=rsi > 50 ? color.lime : color.red)
    
    table.cell(hud, 0, 2, "Regime Audit", text_color=color.gray)
    table.cell(hud, 1, 2, regimeBull ? "BULL-BIAS" : "BEAR-BIAS", text_color=regimeBull ? color.lime : color.red)
    
    table.cell(hud, 0, 3, "Volatility", text_color=color.gray)
    table.cell(hud, 1, 3, str.tostring(atrVal, "##.##"), text_color=color.aqua)
    
    table.cell(hud, 0, 4, "Version", text_color=color.gray)
    table.cell(hud, 1, 4, "v26.0423.0003", text_color=color.gray)

// Visuals
plot(trendEma, "Trend Floor", color.new(color.gray, 60), 1)
plotshape(longEntry, "Long", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(shortEntry, "Short", shape.triangledown, location.abovebar, color.red, size=size.small)
