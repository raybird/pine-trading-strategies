//@version=6
// TN Session Sovereign V6 — Advanced Breakout Audit Strategy
// Author: TeleNexus (Raybird)
// Timezone: Asia/Taipei (CST)
// Version: 1.0.0 (2026-04-10 18:30)
//
// 核心規訓 (Core Mandate):
// 1. 時段狀態機: 使用 enum 管理交易生命週期 (AsiaRange -> Auditing -> Executing)。
// 2. 微觀動能審計: 利用 request.security_lower_tf 捕捉突破瞬間的成交密度。
// 3. UDT 稽核上下文: 使用 User-Defined Types 封裝跨時段因果指標。

strategy("TN Session Sovereign V6 [TeleNexus]", 
     overlay            = true, 
     initial_capital    = 100000, 
     default_qty_type   = strategy.percent_of_equity, 
     default_qty_value  = 5, 
     commission_type    = strategy.commission.percent, 
     commission_value   = 0.005,
     slippage           = 1)

// ── Enum 與 Type 規訓 ────────────────────────────────────────────────────────
enum SessionPhase
    IDLE
    ASIA_ACCUMULATING
    LONDON_AUDITING
    NY_CLOSING

type SessionAudit
    float        asiaHigh
    float        asiaLow
    float        breakoutVolume
    bool         isMomentumConfirmed
    SessionPhase phase

// ── Inputs ───────────────────────────────────────────────────────────────────
string asiaSession   = input.session("0300-0700:1234567", "Asia Range (GMT)", tooltip="GMT Standard Time")
string londonSession = input.session("0800-1600:1234567", "London Session (GMT)")
float  atrMult       = input.float(1.5,  "SL ATR Mult", step=0.1)
float  rrRatio       = input.float(2.0,  "Risk:Reward Ratio", step=0.1)
float  volThresh     = input.float(1.2,  "Breakout Vol Multiplier", step=0.1)

// ── 數據獲取與 UDT 初始化 ──────────────────────────────────────────────────────
var SessionAudit audit = SessionAudit.new(na, na, 0.0, false, SessionPhase.IDLE)

bool isAsia   = not na(time(timeframe.period, asiaSession, "GMT"))
bool isLondon = not na(time(timeframe.period, londonSession, "GMT"))
bool isNewDay = ta.change(time("D")) != 0

if isNewDay
    audit.asiaHigh := na
    audit.asiaLow  := na
    audit.phase    := SessionPhase.IDLE
    audit.isMomentumConfirmed := false

// ── 時段狀態機 (Session State Machine) ─────────────────────────────────────────
if isAsia
    audit.phase    := SessionPhase.ASIA_ACCUMULATING
    audit.asiaHigh := na(audit.asiaHigh) ? high : math.max(audit.asiaHigh, high)
    audit.asiaLow  := na(audit.asiaLow)  ? low  : math.min(audit.asiaLow,  low)
else if isLondon
    audit.phase    := SessionPhase.LONDON_AUDITING

// ── 微觀動能審計 (v6 Security Lower TF) ────────────────────────────────────────
// 當價格接近邊界時，向 1min 請求數據以校驗突破品質
bool nearBoundary = not na(audit.asiaHigh) and (high > audit.asiaHigh * 0.999 or low < audit.asiaLow * 1.001)
float[] lowerVolumes = request.security_lower_tf(syminfo.tickerid, "1", volume)

if isLondon and nearBoundary and array.size(lowerVolumes) > 0
    float lastVol = array.get(lowerVolumes, array.size(lowerVolumes) - 1)
    float avgVol  = array.avg(lowerVolumes)
    audit.breakoutVolume := lastVol / (avgVol > 0 ? avgVol : 1.0)
    if audit.breakoutVolume > volThresh
        audit.isMomentumConfirmed := true
        log.info("SOVEREIGN AUDIT: Breakout Momentum Confirmed at 1m. Ratio: " + str.tostring(audit.breakoutVolume, "#.##"))

// ── 執行路徑 (Pushing) ────────────────────────────────────────────────────────
bool longBreak  = isLondon and ta.crossover(close, audit.asiaHigh) and audit.isMomentumConfirmed
bool shortBreak = isLondon and ta.crossunder(close, audit.asiaLow) and audit.isMomentumConfirmed

if longBreak and strategy.position_size <= 0
    log.warning("PUSH: Executing London Long Breakout. [Causal Alignment: PASS]")
    strategy.entry("Long", strategy.long, comment="STAGING: LONDON_LONG")
    float sl = close - atrMult * ta.atr(14)
    strategy.exit("LX", "Long", stop=sl, limit=close + rrRatio * (close - sl))

if shortBreak and strategy.position_size >= 0
    log.warning("PUSH: Executing London Short Breakout. [Causal Alignment: PASS]")
    strategy.entry("Short", strategy.short, comment="STAGING: LONDON_SHORT")
    float sl = close + atrMult * ta.atr(14)
    strategy.exit("SX", "Short", stop=sl, limit=close - rrRatio * (sl - close))

// ── 視覺化與儀表板 ───────────────────────────────────────────────────────────────
plot(audit.asiaHigh, "Asia High", color.new(color.red, 40), 2, plot.style_steplinebr)
plot(audit.asiaLow,  "Asia Low",  color.new(color.green, 40), 2, plot.style_steplinebr)

bgcolor(isAsia ? color.new(color.blue, 95) : isLondon ? color.new(color.yellow, 97) : na)

// 狀態儀表板
var table board = table.new(position.top_right, 2, 4, border_width=1, frame_color=color.gray)
if barstate.isconfirmed
    table.cell(board, 0, 0, "Phase", bgcolor=color.new(color.navy, 20), text_color=color.white)
    table.cell(board, 1, 0, str.tostring(audit.phase), bgcolor=color.gray)
    table.cell(board, 0, 1, "Momentum", bgcolor=color.new(color.navy, 20), text_color=color.white)
    table.cell(board, 1, 1, audit.isMomentumConfirmed ? "CONFIRMED" : "WAITING", bgcolor=audit.isMomentumConfirmed ? color.green : color.orange)
    table.cell(board, 0, 2, "Vol Ratio", bgcolor=color.new(color.navy, 20), text_color=color.white)
    table.cell(board, 1, 2, str.tostring(audit.breakoutVolume, "#.##"), bgcolor=color.gray)
    table.cell(board, 0, 3, "Day Pillar", bgcolor=color.new(color.navy, 20), text_color=color.white)
    table.cell(board, 1, 3, "JIA YIN (CST)", bgcolor=color.gray)
