//@version=6
strategy("Tn Sovereign BB Breakout v6 [v26.0421.1202]",
    shorttitle         = "TN_BB_v26",
    overlay            = true,
    initial_capital    = 100000,
    default_qty_type   = strategy.percent_of_equity,
    default_qty_value  = 10,
    commission_type    = strategy.commission.percent,
    commission_value   = 0.05,
    slippage           = 2,
    process_orders_on_close = true)

// =====================================================
// MODULE 1: SOVEREIGN VOLATILITY SQUEEZE (KC/BB)
// =====================================================

groupVOL = "🌌 波動率規訓 (Volatility)"
bbLen    = input.int(20,    "布林帶週期", minval=1, group=groupVOL)
bbMult   = input.float(2.0, "布林帶倍數", step=0.1, group=groupVOL)
kcLen    = input.int(20,    "肯特納週期", minval=1, group=groupVOL)
kcMult   = input.float(1.5, "肯特納倍數", step=0.1, group=groupVOL)

[bbUpp, bbBasis, bblow] = ta.bb(close, bbLen, bbMult)
atrVal = ta.atr(kcLen)
kcUpp  = bbBasis + atrVal * kcMult
kclow  = bbBasis - atrVal * kcMult

// Squeeze detection: BB inside KC
bool isSqueezed = (bbUpp < kcUpp) and (bblow > kclow)

// =====================================================
// MODULE 2: CAUSAL ENERGY AUDIT (VOLUME)
// =====================================================

groupAudit = "🛡️ 因果過濾 (Audit Layers)"
useVol     = input.bool(true,  "啟用成交量審計", group=groupAudit)
volMult    = input.float(1.2,  "成交量倍數", step=0.1, group=groupAudit)
atrLen     = input.int(14,     "ATR 週期", group=groupAudit)
slMult     = input.float(2.0,  "止損 ATR 倍數", step=0.1, group=groupAudit)
tpMult     = input.float(4.0,  "獲利 ATR 倍數", step=0.1, group=groupAudit)

volMA = ta.sma(volume, 20)
bool volPass = not useVol or volume > volMA * volMult

// =====================================================
// MODULE 3: CAUSAL SIGNALS & EXECUTION
// =====================================================

// Long: Close crosses above BB Upper AND Volume Audit PASS
bool longEntry  = ta.crossover(close, bbUpp) and volPass
// Short: Close crosses below BB Lower AND Volume Audit PASS
bool shortEntry = ta.crossunder(close, bblow) and volPass

if longEntry and strategy.position_size == 0
    strategy.entry("Long", strategy.long, comment="BB-B")
    strategy.exit("L-Exit", "Long", stop=close - slMult * atrVal, limit=close + tpMult * atrVal)

if shortEntry and strategy.position_size == 0
    strategy.entry("Short", strategy.short, comment="BB-S")
    strategy.exit("S-Exit", "Short", stop=close + slMult * atrVal, limit=close - tpMult * atrVal)

// =====================================================
// MODULE 4: SOVEREIGN AUDIT HUD
// =====================================================

var table hud = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 70), border_width=1)
if barstate.isconfirmed
    table.cell(hud, 0, 0, "◈ BB SOV", text_color=color.white, bgcolor=color.new(color.navy, 20))
    table.cell(hud, 1, 0, "STATUS", text_color=color.white, bgcolor=color.new(color.navy, 20))
    
    table.cell(hud, 0, 1, "Squeeze", text_color=color.gray)
    table.cell(hud, 1, 1, isSqueezed ? "CHARGING" : "STABLE", text_color=isSqueezed ? color.orange : color.lime)
    
    table.cell(hud, 0, 2, "Energy Audit", text_color=color.gray)
    table.cell(hud, 1, 2, volPass ? "PASS" : "LOW-E", text_color=volPass ? color.lime : color.red)
    
    table.cell(hud, 0, 3, "Volatility", text_color=color.gray)
    table.cell(hud, 1, 3, str.tostring(atrVal, "##.##"), text_color=color.aqua)
    
    table.cell(hud, 0, 4, "Version", text_color=color.gray)
    table.cell(hud, 1, 4, "v26.0421.1202", text_color=color.gray)

// Visuals
p_bb_u = plot(bbUpp, "BB Upper", color.new(color.blue, 30))
p_bb_l = plot(bblow, "BB Lower", color.new(color.blue, 30))
p_kc_u = plot(kcUpp, "KC Upper", color.new(color.gray, 60), style=plot.style_linebr)
p_kc_l = plot(kclow, "KC Lower", color.new(color.gray, 60), style=plot.style_linebr)
fill(p_bb_u, p_bb_l, color.new(color.blue, 95))
plotshape(longEntry, "Long", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(shortEntry, "Short", shape.triangledown, location.abovebar, color.red, size=size.small)
