//@version=6
// TeleNexus Sovereign: Imbalance Confluence Strategy [v26.0506.1830]
// Spirit Inheritance: Institutional Orderflow & Fractal Gravity (Kronos V14)
// Goal: Causal Pivot Detection via Volume/Price Equilibrium Break
//
// Logic Chain:
// 1. Imbalance Detection: Find gaps where Buy/Sell pressure is asymmetrical (FVG + Volume Imbalance).
// 2. Fractal Resonance: Ensure the imbalance occurs at a low-fractal dimension point (high-efficiency expansion).
// 3. Gravity Alignment: Verify that price is moving toward a higher-scale liquidity magnet.
// 4. Sovereign Execution: Dynamic ATR-based risk gating.

strategy("TnSovereignImbalanceConfluenceV6",
     shorttitle         = "TnS_Imbalance_V6",
     overlay            = true,
     initial_capital    = 100000,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 10,
     commission_type    = strategy.commission.percent,
     commission_value   = 0.05,
     slippage           = 1)

// ── Regulation Parameters ───────────────────────────────────────────────────
group_sys   = "▼ Regulation"
imb_min_atr = input.float(0.5, "Min Imbalance Size (ATR)", minval=0.1, step=0.1)
frac_threshold = input.float(0.6, "Min Fractal Efficiency", minval=0.1, maxval=1.0)
lookback    = input.int(20, "Lookback for Magnet", minval=5)

group_risk  = "▼ Risk Management"
sl_mult     = input.float(1.5, "SL Multiplier (ATR)")
tp_rr       = input.float(3.0, "Target R:R")

// ── Causal Components ───────────────────────────────────────────────────────
float atr = ta.atr(14)

// 1. Imbalance Logic
bool fvg_bull = low > high[2] and (low - high[2]) > atr * imb_min_atr
bool fvg_bear = high < low[2] and (low[2] - high) > atr * imb_min_atr

// Volume Imbalance (Price gap with high relative volume)
bool vol_imb = volume > ta.sma(volume, 20) * 1.5

// 2. Fractal Efficiency (Path Efficiency Audit)
float window_range = ta.highest(high, 20) - ta.lowest(low, 20)
float path_length = 0.0
for i = 0 to 19
    path_length += math.abs(close[i] - close[i+1])
float fractal_eff = window_range / (path_length || 1)

// 3. Causal Gravity (Liquidity Magnet Sensing)
float magnet_high = ta.highest(high[1], lookback)
float magnet_low  = ta.lowest(low[1], lookback)

// ── Execution Logic ─────────────────────────────────────────────────────────
bool bull_confluence = fvg_bull and vol_imb and fractal_eff > frac_threshold and close < magnet_high
bool bear_confluence = fvg_bear and vol_imb and fractal_eff > frac_threshold and close > magnet_low

if bull_confluence and strategy.position_size == 0
    log.info("[SOVEREIGN_IMBALANCE_BULL] Confluence detected. Efficiency: {0,number,#.##}", fractal_eff)
    strategy.entry("ImbLong", strategy.long, comment="IMB_BULL")
    strategy.exit("ExitL", "ImbLong", stop=low[1] - atr * sl_mult, limit=close + (close - (low[1] - atr * sl_mult)) * tp_rr)

if bear_confluence and strategy.position_size == 0
    log.info("[SOVEREIGN_IMBALANCE_BEAR] Confluence detected. Efficiency: {0,number,#.##}", fractal_eff)
    strategy.entry("ImbShort", strategy.short, comment="IMB_BEAR")
    strategy.exit("ExitS", "ImbShort", stop=high[1] + atr * sl_mult, limit=close - ((high[1] + atr * sl_mult) - close) * tp_rr)

// ── Visuals ──────────────────────────────────────────────────────────────────
plot(magnet_high, "Magnet BSL", color.new(color.red, 80), style=plot.style_stepline)
plot(magnet_low,  "Magnet SSL", color.new(color.lime, 80), style=plot.style_stepline)

// Render Imbalance Zones
if fvg_bull
    box.new(bar_index[1], low, bar_index + 5, high[2], bgcolor=color.new(color.lime, 90), border_color=na)
if fvg_bear
    box.new(bar_index[1], high, bar_index + 5, low[2], bgcolor=color.new(color.red, 90), border_color=na)

// Status Labels
var table info = table.new(position.top_right, 2, 2, frame_color=color.gray, frame_width=1)
if barstate.islast
    table.cell(info, 0, 0, "Efficiency", text_color=color.white)
    table.cell(info, 1, 0, str.tostring(fractal_eff, "#.##"), bgcolor=fractal_eff > frac_threshold ? color.new(color.green, 50) : color.new(color.red, 50))
    table.cell(info, 0, 1, "Causal Drift", text_color=color.white)
    table.cell(info, 1, 1, "V14_ALIGNED", bgcolor=color.new(color.blue, 50))
