//@version=6
strategy("Tn Sovereign CMO v6 [v26.0425.0631]",
    shorttitle         = "TN_CMO_v26",
    overlay            = true,
    initial_capital    = 100000,
    default_qty_type   = strategy.percent_of_equity,
    default_qty_value  = 10,
    commission_type    = strategy.commission.percent,
    commission_value   = 0.05,
    slippage           = 2,
    process_orders_on_close = true)

// =====================================================
// MODULE 1: SOVEREIGN CMO DISCIPLINE
// =====================================================

groupCMO = "🌌 錢德動能規訓 (CMO Config)"
cmoLen   = input.int(14, "CMO 週期", minval=1, group=groupCMO)
extLevel = input.float(50.0, "極端區域門檻", step=5.0, group=groupCMO)

// CMO Calculation
float diff = ta.change(close)
float sumUp   = ta.sum(diff > 0 ? diff : 0, cmoLen)
float sumDown = ta.sum(diff < 0 ? -diff : 0, cmoLen)
float cmoVal  = 100 * (sumUp - sumDown) / (sumUp + sumDown)

bool bullPol = cmoVal > 0
bool bearPol = cmoVal < 0

// =====================================================
// MODULE 2: REGIME & DIVERGENCE AUDIT
// =====================================================

groupAudit = "🛡️ 因果過濾 (Audit Layers)"
trendLen   = input.int(200,   "趨勢地板 (EMA)", group=groupAudit)
atrLen     = input.int(14,    "ATR 週期", group=groupAudit)
slMult     = input.float(2.0, "止損 ATR 倍數", group=groupAudit)
tpMult     = input.float(4.0, "獲利 ATR 倍數", group=groupAudit)

float trendEma = ta.ema(close, trendLen)
float atrVal   = ta.atr(atrLen)

bool regimeBull = close > trendEma
bool regimeBear = close < trendEma

// Causal Divergence: Price Low vs CMO Higher Low
bool priceLow = low < ta.lowest(low, 5)[1]
bool cmoUp    = cmoVal > ta.lowest(cmoVal, 5)[1]
bool bullDiv  = priceLow and cmoUp and cmoVal < -extLevel

// Causal Divergence: Price High vs CMO Lower High
bool priceHigh = high > ta.highest(high, 5)[1]
bool cmoDown   = cmoVal < ta.highest(cmoVal, 5)[1]
bool bearDiv   = priceHigh and cmoDown and cmoVal > extLevel

// =====================================================
// MODULE 3: CAUSAL SIGNALS & EXECUTION
// =====================================================

// Long: Bullish Divergence OR CMO Cross Zero (from below) AND Bullish Regime
bool longEntry  = (bullDiv or ta.crossover(cmoVal, -extLevel)) and regimeBull
// Short: Bearish Divergence OR CMO Cross Zero (from above) AND Bearish Regime
bool shortEntry = (bearDiv or ta.crossunder(cmoVal, extLevel)) and regimeBear

if longEntry and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, comment="CMO-B")
    strategy.exit("L-Exit", "Long", stop=close - slMult * atrVal, limit=close + tpMult * atrVal)

if shortEntry and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, comment="CMO-S")
    strategy.exit("S-Exit", "Short", stop=close + slMult * atrVal, limit=close - tpMult * atrVal)

// =====================================================
// MODULE 4: SOVEREIGN AUDIT HUD
// =====================================================

var table hud = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 70), border_width=1)
if barstate.isconfirmed
    table.cell(hud, 0, 0, "◈ CMO SOVEREIGN", text_color=color.white, bgcolor=color.new(color.navy, 20))
    table.cell(hud, 1, 0, "STATUS", text_color=color.white, bgcolor=color.new(color.navy, 20))
    
    table.cell(hud, 0, 1, "CMO Val", text_color=color.gray)
    table.cell(hud, 1, 1, str.tostring(cmoVal, "##.#"), text_color=bullPol ? color.lime : color.red)
    
    table.cell(hud, 0, 2, "Divergence", text_color=color.gray)
    table.cell(hud, 1, 2, bullDiv ? "BULL-DIV" : bearDiv ? "BEAR-DIV" : "NONE", text_color=bullDiv ? color.lime : bearDiv ? color.red : color.gray)
    
    table.cell(hud, 0, 3, "Regime Bias", text_color=color.gray)
    table.cell(hud, 1, 3, regimeBull ? "UP" : regimeBear ? "DOWN" : "RANGE", text_color=regimeBull ? color.lime : color.red)
    
    table.cell(hud, 0, 4, "Version", text_color=color.gray)
    table.cell(hud, 1, 4, "v26.0425.0631", text_color=color.gray)

// Visuals
plot(trendEma, "Regime Floor", color.new(color.gray, 60), 1)
plotshape(longEntry, "Long", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(shortEntry, "Short", shape.triangledown, location.abovebar, color.red, size=size.small)
