//@version=6
strategy(
  title           = "Tn Sovereign VAMO v6",
  shorttitle      = "TnVAMO",
  overlay         = true,
  format          = format.price,
  initial_capital = 10000,
  default_qty_type = strategy.percent_of_equity,
  default_qty_value = 100,
  commission_type  = strategy.commission.percent,
  commission_value = 0.03,
  slippage         = 2
)

enum VamoState
    FLAT
    LONG
    SHORT

// --- Inputs ---
vamoLen     = input.int(14,  "VAMO Length")
signalLen   = input.int(9,   "Signal EMA Length")
atrMult     = input.float(1.5, "ATR Multiplier", step = 0.1)
tpMult      = input.float(2.0, "TP Multiplier",  step = 0.1)
regimeLen   = input.int(50,  "Volatility Regime Lookback")
stopVolPct  = input.float(0.8, "Stop Volatility Percentile", step = 0.05)

// --- VAMO Calculation ---
rocVal    = ta.roc(close, vamoLen)
atrVal    = ta.atr(vamoLen)
vamoLine  = rocVal / atrVal
signalLine = ta.ema(vamoLine, signalLen)
hist      = vamoLine - signalLine

// --- Volatility Regime Filter ---
atrRegime = ta.atr(regimeLen)
atrHist   = array.new<float>()
if barstate.isconfirmed and not na(atrRegime)
    array.push(atrHist, atrRegime)
    if array.size(atrHist) > regimeLen
        array.shift(atrHist)

volThreshold = array.percentile_nearest_rank(atrHist, stopVolPct)
volFilter    = atrRegime < volThreshold or array.size(atrHist) < regimeLen

// --- Entry Conditions ---
longEntry  = ta.crossover(vamoLine, signalLine) and vamoLine > 0 and volFilter
shortEntry = ta.crossunder(vamoLine, signalLine) and vamoLine < 0 and volFilter

// --- Risk Management ---
entryPrice = close
slDistance = atrVal * atrMult
tpDistance = slDistance * tpMult

longSl  = entryPrice - slDistance
longTp  = entryPrice + tpDistance
shortSl = entryPrice + slDistance
shortTp = entryPrice - tpDistance

// --- Causal Audit State ---
var auditTable = table.new(position.top_right, 4, 2, bgcolor = color.new(color.black, 80), border_width = 0)
var line vamoPlot = na

if barstate.islast
    table.cell(auditTable, 0, 0, "VAMO", text_color = color.white, text_size = size.small)
    table.cell(auditTable, 0, 1, str.tostring(vamoLine, "#.##"), text_color = color.lime, text_size = size.small)
    table.cell(auditTable, 1, 0, "Signal", text_color = color.white, text_size = size.small)
    table.cell(auditTable, 1, 1, str.tostring(signalLine, "#.##"), text_color = color.orange, text_size = size.small)
    table.cell(auditTable, 2, 0, "VolFilter", text_color = color.white, text_size = size.small)
    table.cell(auditTable, 2, 1, volFilter ? "ON" : "OFF", text_color = volFilter ? color.lime : color.red, text_size = size.small)
    table.cell(auditTable, 3, 0, "State", text_color = color.white, text_size = size.small)

if longEntry
    strategy.entry("VAMO_L", strategy.long)
    strategy.exit("VAMO_L_X", "VAMO_L", stop = longSl, limit = longTp)

if shortEntry
    strategy.entry("VAMO_S", strategy.short)
    strategy.exit("VAMO_S_X", "VAMO_S", stop = shortSl, limit = shortTp)

// --- Visuals ---
plot(vamoLine,   "VAMO", color = color.fuchsia, linewidth = 2)
plot(signalLine, "Signal", color = color.orange, linewidth = 1)
hline(0, "Zero", color = color.gray, linestyle = hline.style_dotted)
plot(hist, "Histogram", color = hist > 0 ? color.lime : color.red, style = plot.style_histogram, linewidth = 2)

bgcolor(longEntry ? color.new(color.lime, 85) : na)
bgcolor(shortEntry ? color.new(color.red, 85) : na)

// --- Causal Audit State Labels ---
if longEntry
    label.new(bar_index, low, "VAMO LONG\nSL=" + str.tostring(slDistance, "#.##") + "\nTP=" + str.tostring(tpDistance, "#.##"),
              style = label.style_label_up, color = color.lime, textcolor = color.black, size = size.tiny)
if shortEntry
    label.new(bar_index, high, "VAMO SHORT\nSL=" + str.tostring(slDistance, "#.##") + "\nTP=" + str.tostring(tpDistance, "#.##"),
              style = label.style_label_down, color = color.red, textcolor = color.white, size = size.tiny)