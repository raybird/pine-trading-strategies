//@version=6
// @description: TeleNexus 多代理人集成訂單流策略 - v6 核心實作
// @author: TeleNexus AI
// @strategy: 利用 v6 原生 footprint 獲取買賣不平衡矩陣，結合三個獨立 Agent（Delta、Imbalance、POC）進行加權投票，實現因果共振執行。

strategy("TN Multi-Agent OF Ensemble Sovereign v6", overlay = true, initial_capital = 10000, default_qty_type = strategy.percent_of_equity, default_qty_value = 15)

// 1. 利用 v6 Enum 定義規訓靈敏度
enum SensingRegime
    Sovereign = 0.5 // 高主權門檻 (需強共識)
    Standard  = 0.3 // 標準因果對位
    Pulse     = 0.1 // 高頻感知

SensingRegime regime = input.enum(SensingRegime.Standard, "感知規訓模式")
float entryThresh = switch regime
    SensingRegime.Sovereign => 0.5
    SensingRegime.Standard  => 0.3
    SensingRegime.Pulse     => 0.1

// 2. 代理人權重分配 (Ensemble Weights)
float wDelta = input.float(0.3, "Delta Agent 權重", minval = 0, maxval = 1)
float wImb   = input.float(0.5, "Imbalance Agent 權重", minval = 0, maxval = 1)
float wPoc   = input.float(0.2, "POC Agent 權重", minval = 0, maxval = 1)

// 3. 獲取 v6 足跡物理數據
fp = request.footprint(syminfo.tickerid)

// --- Agent 1: Delta 代理 (物理淨壓分析) ---
method agent_delta(footprint _fp) =>
    if na(_fp) => 0.0
    float d = _fp.delta()
    float v = _fp.total_volume()
    v > 0 ? (d / v) : 0.0

// --- Agent 2: 不平衡代理 (矩陣堆疊偵測) ---
method agent_imbalance(footprint _fp, float _ratio) =>
    if na(_fp) => 0.0
    volume_row[] _rows = _fp.rows()
    int _bI = 0, int _sI = 0
    if array.size(_rows) > 0
        for i = 0 to array.size(_rows) - 1
            volume_row _r = array.get(_rows, i)
            float _bv = _r.buy_vol(), float _sv = _r.sell_vol()
            if _bv > _sv * _ratio => _bI += 1
            if _sv > _bv * _ratio => _sI += 1
    total = _bI + _sI
    total > 0 ? (_bI - _sI) / float(total) : 0.0

// --- Agent 3: POC 代理 (控制點位移對位) ---
method agent_poc(footprint _fp) =>
    if na(_fp) => 0.0
    volume_row _pocR = _fp.poc_row()
    float _pocP = _pocR.price_low()
    close > _pocP ? 1.0 : close < _pocP ? -1.0 : 0.0

// 4. 蜂群集成決算
float s1 = fp.agent_delta()
float s2 = fp.agent_imbalance(2.5)
float s3 = fp.agent_poc()

float ensembleScore = (s1 * wDelta) + (s2 * wImb) + (s3 * wPoc)

// 5. 高時框規訓對位 (HTF Alignment)
htfTrend = request.security(syminfo.tickerid, "D", ta.ema(close, 50))
bool isTrendAligned = (ensembleScore > 0 and close > htfTrend) or (ensembleScore < 0 and close < htfTrend)

// 6. 執行規訓
if ensembleScore > entryThresh and isTrendAligned
    strategy.entry("Long_Ens", strategy.long, comment = str.format("Score: {0,number,#.##}", ensembleScore))

if ensembleScore < -entryThresh and isTrendAligned
    strategy.entry("Short_Ens", strategy.short, comment = str.format("Score: {0,number,#.##}", ensembleScore))

// 7. 視覺化：集成 HUD
var table hud = table.new(position.top_right, 2, 5, bgcolor = color.new(color.black, 30), border_width = 1)
if barstate.islast
    table.cell(hud, 0, 0, "Agent", text_color = color.white)
    table.cell(hud, 1, 0, "Score", text_color = color.white)
    table.cell(hud, 0, 1, "Delta", text_color = color.gray), table.cell(hud, 1, 1, str.tostring(s1, "#.##"), text_color = color.yellow)
    table.cell(hud, 0, 2, "Imbalance", text_color = color.gray), table.cell(hud, 1, 2, str.tostring(s2, "#.##"), text_color = color.yellow)
    table.cell(hud, 0, 3, "POC", text_color = color.gray), table.cell(hud, 1, 3, str.tostring(s3, "#.##"), text_color = color.yellow)
    table.cell(hud, 0, 4, "ENSEMBLE", text_color = color.white, bgcolor = color.blue), table.cell(hud, 1, 4, str.tostring(ensembleScore, "#.##"), text_color = color.white, bgcolor = color.blue)

// 8. 物理日誌審計 (v6 log.info)
if barstate.islastconfirmedhistory
    log.info("Weekly Cycle Start: Ensemble Score = {0,number,#.##} | Trend Aligned = {1}", ensembleScore, isTrendAligned)
