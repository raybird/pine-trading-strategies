//@version=6
// @description: TeleNexus 訂單流堆疊失衡主權策略 - v6 核心實作
// @author: TeleNexus AI
// @strategy: 利用 v6 request.footprint() 掃描 K 線內部的買賣成交分布，偵測連續價位的「堆疊失衡」，結合 VWAP 趨勢規訓執行。

strategy("TN Stacked Imbalance Sovereign v6", overlay = true, initial_capital = 10000, default_qty_type = strategy.percent_of_equity, default_qty_value = 15)

// 1. 利用 v6 Enum 定義規訓靈敏度
enum SensingMode
    Pulse = "High Frequency (2 Stacked)"
    Sovereign = "Institutional (3 Stacked)"
    Conservative = "Heavy Bias (4 Stacked)"

SensingMode mode = input.enum(SensingMode.Sovereign, "感知規訓模式")
float imbRatio  = input.float(3.0, "失衡比例 (e.g. 3:1)", minval = 1.1, step = 0.1)

// 2. 獲取 v6 原生 Footprint 數據與處理邏輯
// 註：在 v6 中，footprint 數據需要透過專門的 method 進行解析
fp = request.footprint(syminfo.tickerid)

// [v6 方法論] 偵測堆疊失衡
method detect_stacked_imb(footprint _fp, bool _isBuy, int _required) =>
    int _count = 0
    if not na(_fp)
        volume_row[] _rows = _fp.rows()
        if array.size(_rows) > 0
            for i = 0 to array.size(_rows) - 1
                volume_row _row = array.get(_rows, i)
                float _b = _row.buy_vol()
                float _s = _row.sell_vol()
                if _isBuy and _b > _s * imbRatio
                    _count += 1
                else if not _isBuy and _s > _b * imbRatio
                    _count += 1
                else
                    _count := 0
                if _count >= _required
                    break
    _count >= _required

int reqLevels = switch mode
    SensingMode.Pulse        => 2
    SensingMode.Sovereign    => 3
    SensingMode.Conservative => 4

bool isBuyImb  = fp.detect_stacked_imb(true, reqLevels)
bool isSellImb = fp.detect_stacked_imb(false, reqLevels)

// 3. 趨勢與物理地板規訓
vwapVal = ta.vwap
bool isUptrend   = close > vwapVal and close > ta.sma(close, 50)
bool isDowntrend = close < vwapVal and close < ta.sma(close, 50)

// 4. 執行邏輯
if isBuyImb and isUptrend
    strategy.entry("Long OFI", strategy.long, comment = "Stacked Buy Imbalance")
    log.info("Sovereign Buy Triggered: {0} Stacked Levels Detected", reqLevels)

if isSellImb and isDowntrend
    strategy.entry("Short OFI", strategy.short, comment = "Stacked Sell Imbalance")
    log.info("Sovereign Sell Triggered: {0} Stacked Levels Detected", reqLevels)

// 5. 動態出口規訓
atr = ta.atr(14)
if strategy.position_size > 0
    strategy.exit("Exit", "Long OFI", stop = close - atr * 2, limit = close + atr * 4)
if strategy.position_size < 0
    strategy.exit("Exit", "Short OFI", stop = close + atr * 2, limit = close - atr * 4)

// 6. 視覺化地板 (v6 Switch 色彩)
bgcolor(isBuyImb ? color.new(color.green, 85) : isSellImb ? color.new(color.red, 85) : na)
plot(vwapVal, "Dynamic VWAP", color = color.new(color.gray, 50))

// 7. 物理狀態儀表板
var table monitor = table.new(position.top_right, 2, 2, bgcolor = color.new(color.black, 30), border_width = 1)
if barstate.islast
    table.cell(monitor, 0, 0, "Delta", text_color = color.white)
    table.cell(monitor, 1, 0, str.tostring(fp.delta(), "#.##"), bgcolor = fp.delta() > 0 ? color.green : color.red)
    table.cell(monitor, 0, 1, "Mode", text_color = color.white)
    table.cell(monitor, 1, 1, str.tostring(mode), text_color = color.yellow)
