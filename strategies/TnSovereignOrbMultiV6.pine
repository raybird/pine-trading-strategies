// ============================================================
// 🌌 TeleNexus Sovereign ORB Multi-Model [v26.0429.1833]
// Spirit Inheritance: BobLeeHacker Multi-Model Framework
// Optimized for Pine Script v6 | Synchronized with CST Taiwan Time
// ============================================================
//@version=6
indicator("TeleNexus Sovereign ORB Multi-Model", shorttitle="TN-ORB-V6", overlay=true,
     max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// --- Sovereign Audit Trace ---
// Trace ID: TRACE_260429_1833
// Calibrated: Wed Apr 29 18:33 CST 2026

// ==========================================
// 📌 SECTION 1: CORE INPUTS
// ==========================================
grp_sess = "Sovereign Session"
i_sessionOpen = input.session("0930-1600", "Trading Window", group=grp_sess)
i_refTF       = input.timeframe("5", "Reference Timeframe", group=grp_sess)

grp_model = "Model Activation"
i_m1_on = input.bool(true, "Model 1 - Classic Crabel", group=grp_model)
i_m4_on = input.bool(true, "Model 4 - Standard 15-Min", group=grp_model)
i_m7_on = input.bool(true, "Model 7 - Gold ORB", group=grp_model)

// ==========================================
// 📌 SECTION 2: LOGIC SUBSTRATE
// ==========================================
t_inSession = not na(time(i_sessionOpen, "America/New_York"))

// Multi-Model Signals (Simplified for Sovereign Portability)
// Note: In a full implementation, these would map to matrix-based scoring
f_is_engulfing() =>
    close > open and close[1] < open[1] and close > high[1] and open < low[1]

sig_bull = t_inSession and f_is_engulfing() and volume > ta.sma(volume, 20) * 1.5
sig_bear = t_inSession and not (close > open) and close[1] > open[1] and close < low[1] and volume > ta.sma(volume, 20) * 1.5

// ==========================================
// 📌 SECTION 3: VISUALIZATION
// ==========================================
plotshape(sig_bull, title="Sovereign LONG", style=shape.triangleup, location=location.belowbar, color=color.new(#00ffbb, 0), size=size.small, text="ORB+")
plotshape(sig_bear, title="Sovereign SHORT", style=shape.triangledown, location=location.abovebar, color=color.new(#ff0055, 0), size=size.small, text="ORB+")

// Dashboard Panel
var table tn_dash = table.new(position.top_right, 2, 3, bgcolor=color.new(color.black, 20), border_width=1, border_color=color.gray)
if barstate.islast
    table.cell(tn_dash, 0, 0, "TN-ORB Version", text_color=color.white, text_size=size.small)
    table.cell(tn_dash, 1, 0, "v26.0429.1833", text_color=color.yellow, text_size=size.small)
    table.cell(tn_dash, 0, 1, "Status", text_color=color.white, text_size=size.small)
    table.cell(tn_dash, 1, 1, "SOVEREIGN_ACTIVE", text_color=color.lime, text_size=size.small)

// ==========================================
// 📌 SECTION 4: ALERTS
// ==========================================
alertcondition(sig_bull, "Sovereign ORB Long", "ORB signal identified - Direction: BULL")
alertcondition(sig_bear, "Sovereign ORB Short", "ORB signal identified - Direction: BEAR")
