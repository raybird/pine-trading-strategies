//@version=6
strategy("Tn Sovereign FlowZone v6 [v26.0421.1206]",
    shorttitle         = "TN_FZ_v26",
    overlay            = true,
    initial_capital    = 100000,
    default_qty_type   = strategy.percent_of_equity,
    default_qty_value  = 10,
    commission_type    = strategy.commission.percent,
    commission_value   = 0.05,
    slippage           = 2,
    process_orders_on_close = true,
    max_labels_count   = 500)

// =====================================================
// MODULE 1: SOVEREIGN CONFLUENCE CORE
// =====================================================

groupCore = "🎯 核心規訓 (Core Settings)"
confThreshold = input.float(7.0, "匯流門檻", minval=5.0, maxval=10.0, step=0.1, group=groupCore)
trendLen = input.int(200, "環境 EMA 週期", group=groupCore)

// Causal Components (Mock for Base, can be expanded)
ema20 = ta.ema(close, 20)
ema50 = ta.ema(close, 50)
trendEma = ta.ema(close, trendLen)

// Confluence Logic: Trend + Momentum + Volume
volMA = ta.sma(volume, 20)
volAudit = volume > volMA * 1.2 ? 1.0 : 0.0
trendAudit = close > trendEma ? 2.0 : -2.0
momAudit = ta.rsi(close, 14) > 50 ? 1.0 : -1.0

confluenceScore = 5.0 + trendAudit + volAudit + momAudit

// =====================================================
// MODULE 2: RISK & EXECUTION LAYERS
// =====================================================

groupRisk = "⚖️ 風險規訓 (Risk Management)"
atrLen   = input.int(14,    "ATR 週期", group=groupRisk)
slMult   = input.float(2.0, "止損 ATR 倍數", group=groupRisk)
tp1Ratio = input.float(1.5, "TP1 盈虧比", group=groupRisk)
tp2Ratio = input.float(3.0, "TP2 盈虧比", group=groupRisk)

atrVal = ta.atr(atrLen)
longCondition = ta.crossover(ema20, ema50) and confluenceScore >= confThreshold and close > trendEma
shortCondition = ta.crossunder(ema20, ema50) and confluenceScore <= (10.0 - confThreshold) and close < trendEma

// =====================================================
// MODULE 3: CAUSAL EXECUTION
// =====================================================

if longCondition and strategy.position_size == 0
    strategy.entry("Long", strategy.long, comment="FZ-B")
    strategy.exit("L-Exit", "Long", stop=close - slMult * atrVal, limit=close + tp1Ratio * (slMult * atrVal))

if shortCondition and strategy.position_size == 0
    strategy.entry("Short", strategy.short, comment="FZ-S")
    strategy.exit("S-Exit", "Short", stop=close + slMult * atrVal, limit=close - tp1Ratio * (slMult * atrVal))

// =====================================================
// MODULE 4: SOVEREIGN AUDIT HUD
// =====================================================

var table hud = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 70), border_width=1)
if barstate.isconfirmed
    table.cell(hud, 0, 0, "◈ FLOWZONE", text_color=color.white, bgcolor=color.new(color.navy, 20))
    table.cell(hud, 1, 0, "STATUS", text_color=color.white, bgcolor=color.new(color.navy, 20))
    
    table.cell(hud, 0, 1, "Conf Score", text_color=color.gray)
    table.cell(hud, 1, 1, str.tostring(confluenceScore, "#.##"), text_color=confluenceScore >= confThreshold ? color.lime : color.orange)
    
    table.cell(hud, 0, 2, "Regime", text_color=color.gray)
    table.cell(hud, 1, 2, close > trendEma ? "BULL" : "BEAR", text_color=close > trendEma ? color.lime : color.red)
    
    table.cell(hud, 0, 3, "Energy Audit", text_color=color.gray)
    table.cell(hud, 1, 3, volAudit > 0 ? "PASS" : "LOW-E", text_color=volAudit > 0 ? color.lime : color.red)
    
    table.cell(hud, 0, 4, "Version", text_color=color.gray)
    table.cell(hud, 1, 4, "v26.0421.1206", text_color=color.gray)

// Visuals
plot(trendEma, "Regime Floor", color.new(color.orange, 50), 2)
plot(ema20, "Fast", color.new(color.lime, 0))
plot(ema50, "Slow", color.new(color.red, 0))
