//@version=6
// @description: TeleNexus 馬可維茲最小變異投資組合 - v6 核心實作
// @author: TeleNexus AI
// @strategy: 利用 matrix 代數運算求解全球最小變異數組合 (GMVP)，動態優化多資產權重以對沖系統性風險。

strategy("TN Markowitz GMVP Sovereign v6", overlay = true, initial_capital = 100000)

// 1. 利用 v6 Enum 定義再平衡規訓
enum RebalanceFreq
    Fast = 10
    Standard = 20
    Sovereign = 50

RebalanceFreq freq = input.enum(RebalanceFreq.Standard, "再平衡頻率 (Bars)")
int lookback = input.int(30, "協方差回顧長度", minval = 10)

// 2. 資產集群輸入 (可動態對焦不同實體資產)
s1 = input.symbol("BINANCE:BTCUSDT", "資產 1")
s2 = input.symbol("BINANCE:ETHUSDT", "資產 2")
s3 = input.symbol("BINANCE:SOLUSDT", "資產 3")

// 獲取價格與計算對數收益率
c1 = request.security(s1, timeframe.period, close)
c2 = request.security(s2, timeframe.period, close)
c3 = request.security(s3, timeframe.period, close)

r1 = math.log(c1 / c1[1])
r2 = math.log(c2 / c2[1])
r3 = math.log(c3 / c3[1])

// 3. 投資組合優化邏輯 (v6 Matrix Algebra)
int f_val = switch freq
    RebalanceFreq.Fast      => 10
    RebalanceFreq.Standard  => 20
    RebalanceFreq.Sovereign => 50

bool is_rebalance = bar_index % f_val == 0

// 宣告持久化權重變數
var float w1 = 0.33, var float w2 = 0.33, var float w3 = 0.34

if is_rebalance and not na(r1[lookback])
    // A. 建立收益率矩陣 R [lookback x 3]
    matrix<float> R = matrix.new<float>(lookback, 3)
    for i = 0 to lookback - 1
        R.set(i, 0, r1[i])
        R.set(i, 1, r2[i])
        R.set(i, 2, r3[i])

    // B. 去中心化處理 (De-mean)
    for j = 0 to 2
        float sum = 0.0
        for i = 0 to lookback - 1
            sum += R.get(i, j)
        float avg = sum / lookback
        for i = 0 to lookback - 1
            R.set(i, j, R.get(i, j) - avg)

    // C. 計算協方差矩陣 Sigma = (R^T * R) / (n-1)
    matrix<float> RT = R.transpose()
    matrix<float> Sigma = RT.mult(R)
    for i = 0 to 2
        for j = 0 to 2
            Sigma.set(i, j, Sigma.get(i, j) / (lookback - 1))

    // D. 求解最優權重 w = (Sigma^-1 * 1) / (1^T * Sigma^-1 * 1)
    matrix<float> SigmaInv = Sigma.inv()
    if not na(SigmaInv)
        matrix<float> ones = matrix.new<float>(3, 1, 1.0)
        matrix<float> num = SigmaInv.mult(ones)
        matrix<float> onesT = ones.transpose()
        matrix<float> denom_mat = onesT.mult(num)
        float denom = denom_mat.get(0, 0)

        w1 := num.get(0, 0) / denom
        w2 := num.get(1, 0) / denom
        w3 := num.get(2, 0) / denom

// 4. 執行規訓與視覺化
if is_rebalance
    strategy.entry("Portfolio", strategy.long, comment = str.format("Weights: {0,number,#.##}/{1,number,#.##}/{2,number,#.##}", w1, w2, w3))

// 5. 權重儀表板 (v6 Table API)
var table p_table = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 20), border_width=1)
if barstate.islast
    table.cell(p_table, 0, 0, "Asset", text_color=color.white)
    table.cell(p_table, 1, 0, "GMVP Weight", text_color=color.white)
    table.cell(p_table, 0, 1, s1, text_color=color.white)
    table.cell(p_table, 1, 1, str.tostring(w1, "#.##"), bgcolor=color.new(color.green, 100 - int(w1*100)))
    table.cell(p_table, 0, 2, s2, text_color=color.white)
    table.cell(p_table, 1, 2, str.tostring(w2, "#.##"), bgcolor=color.new(color.green, 100 - int(w2*100)))
    table.cell(p_table, 0, 3, s3, text_color=color.white)
    table.cell(p_table, 1, 3, str.tostring(w3, "#.##"), bgcolor=color.new(color.green, 100 - int(w3*100)))
