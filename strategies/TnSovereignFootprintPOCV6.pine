//@version=6
strategy("TN Sovereign Footprint POC v6", overlay=true, initial_capital=100000, currency=currency.USD, commission_type=strategy.commission.percent, commission_value=0.05)

// ------------------------------------------------------------
// 🚀 CORE PHILOSOPHY: POC BREAKOUT & INSTITUTIONAL INTENT
// This strategy utilizes Pine Script v6 Matrix and UDT to simulate 
// and audit "Point of Control" (POC) breakouts. It identifies 
// price levels where institutional volume is concentrated.
// Version: v26.0429.0631 [CST]
// ------------------------------------------------------------

// ── User Defined Types (v6) ──────────────────────────────────────────────────
type SignalState
    bool isBull = false
    bool isBear = false
    float pocLevel = na
    float volumeRatio = 0.0

// ── Inputs ───────────────────────────────────────────────────────────────────
groupPOC    = "POC Configuration"
lookback    = input.int(20, "POC Audit Lookback", minval=5, group=groupPOC)
volThreshold = input.float(1.5, "POC Volume Threshold", minval=1.0, group=groupPOC)

groupRisk   = "Sovereign Risk Architecture"
riskPct     = input.float(1.0, "Risk % Per Trade", minval=0.1, step=0.1, group=groupRisk)
atrLen      = input.int(14, "ATR Lookback", group=groupRisk)
slMult      = input.float(2.0, "Stop Loss (ATR Mult)", group=groupRisk)

// ── Calculations ─────────────────────────────────────────────────────────────
atr = ta.atr(atrLen)
volMa = ta.sma(volume, 20)

// Simulated POC calculation (Finding the high-volume node in the lookback)
// In a full v6 Footprint implementation, we'd use request.footprint()
float highestVol = 0.0
float simulatedPOC = na

for i = 1 to lookback
    if volume[i] > highestVol
        highestVol := volume[i]
        simulatedPOC := (high[i] + low[i] + close[i]) / 3

// Causal Audit: Breakout of Simulated POC
SignalState state = SignalState.new()
state.pocLevel := simulatedPOC
state.volumeRatio := volume / volMa

if ta.crossover(close, simulatedPOC) and state.volumeRatio > volThreshold
    state.isBull := true
if ta.crossunder(close, simulatedPOC) and state.volumeRatio > volThreshold
    state.isBear := true

// ── Sovereign Execution ──────────────────────────────────────────────────────
float riskAmt = strategy.equity * (riskPct / 100)
float stopDist = atr * slMult
float qty = stopDist > 0 ? riskAmt / stopDist : 0.0

if state.isBull and strategy.position_size == 0
    strategy.entry("POC Long", strategy.long, qty=qty, comment="POC_Break_Bull")
    strategy.exit("LX", "POC Long", stop=close - stopDist, limit=close + atr * 4.0)

if state.isBear and strategy.position_size == 0
    strategy.entry("POC Short", strategy.short, qty=qty, comment="POC_Break_Bear")
    strategy.exit("SX", "POC Short", stop=close + stopDist, limit=close - atr * 4.0)

// ── Visuals ──────────────────────────────────────────────────────────────────
plot(state.pocLevel, "Historical POC", color.new(color.orange, 50), 2, plot.style_circles)
plotshape(state.isBull, "Bull Signal", shape.triangleup, location.belowbar, color.green, size=size.small)
plotshape(state.isBear, "Bear Signal", shape.triangledown, location.abovebar, color.red, size=size.small)

// Dashboard: Sovereign Causal Table
var table dashboard = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 70), border_width=1)
if barstate.isconfirmed
    table.cell(dashboard, 0, 0, "Signal Mode", text_color=color.white)
    table.cell(dashboard, 1, 0, "FOOTPRINT", bgcolor=color.teal, text_color=color.white)
    table.cell(dashboard, 0, 1, "Vol Ratio", text_color=color.white)
    table.cell(dashboard, 1, 1, str.tostring(state.volumeRatio, "#.##"), bgcolor=state.volumeRatio > volThreshold ? color.green : color.red)
    table.cell(dashboard, 0, 2, "POC Level", text_color=color.white)
    table.cell(dashboard, 1, 2, str.tostring(state.pocLevel, "#.####"), text_color=color.white)
    table.cell(dashboard, 0, 3, "Sovereignty", text_color=color.white)
    table.cell(dashboard, 1, 3, "v6-VALID", bgcolor=color.green, text_color=color.white)
