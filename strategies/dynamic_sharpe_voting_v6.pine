//@version=6
// @description: TeleNexus 動態加權夏普投票策略 - v6 核心實作
// @author: TeleNexus AI
// @strategy: 即時計算多因子子策略的滾動夏普比率，並根據效能動態分配投票權重，實現自適應因果對位。

strategy("TN Dynamic Sharpe Voting Sovereign v6", overlay = true, initial_capital = 10000, default_qty_type = strategy.percent_of_equity, default_qty_value = 10)

// 1. 利用 v6 Enum 定義規訓嚴格度
enum ThresholdLevel
    Safe     = 0.4 // 需高度共識
    Standard = 0.2 // 中度共識
    Aggressive = 0.1 // 低共識即可

ThresholdLevel level = input.enum(ThresholdLevel.Standard, "因果共識門檻")
int lookback = input.int(50, "夏普回顧週期", minval = 10)
float rf_rate = input.float(0.02, "年化無風險利率 (%)") / 252 / 100

// 2. 子策略定義 (利用 v6 Method Chaining)
method get_sig_rsi(float src, int len) =>
    src.rsi(len) > 50 ? 1 : -1

method get_sig_macd(float src) =>
    [m, s, _] = src.macd(12, 26, 9)
    m > s ? 1 : -1

method get_sig_ema(float src) =>
    src.ema(20) > src.ema(50) ? 1 : -1

// 3. 夏普權重演算方法 (v6 Method Syntax)
method calc_weight(int sig, int len) =>
    // 虛擬收益率計算 (依據信號極性)
    float ret = (close / close[1] - 1) * sig[1]
    float avg = ret.sma(len)
    float dev = ret.stdev(len)
    float sharpe = dev != 0 ? (avg - rf_rate) / dev * math.sqrt(252) : 0.0
    math.max(sharpe, 0.01) // 權重地板

// 4. 聯邦投票執行
s1 = close.get_sig_rsi(14)
s2 = close.get_sig_macd()
s3 = close.get_sig_ema()

w1 = s1.calc_weight(lookback)
w2 = s2.calc_weight(lookback)
w3 = s3.calc_weight(lookback)

float total_w = w1 + w2 + w3
float vote_score = (s1 * w1 + s2 * w2 + s3 * w3) / total_w

// 5. 執行規訓
float limit = switch level
    ThresholdLevel.Safe       => 0.4
    ThresholdLevel.Standard   => 0.2
    ThresholdLevel.Aggressive => 0.1

if vote_score > limit
    strategy.entry("Long", strategy.long, comment = str.format("Score: {0,number,#.##}", vote_score))

if vote_score < -limit
    strategy.entry("Short", strategy.short, comment = str.format("Score: {0,number,#.##}", vote_score))

// 6. 視覺化：夏普效能矩陣 (v6 Table API)
var table ui = table.new(position.top_right, 2, 4, bgcolor = color.new(color.black, 30), border_width = 1)
if barstate.islast
    table.cell(ui, 0, 0, "Factor", text_color = color.white)
    table.cell(ui, 1, 0, "Weight %", text_color = color.white)
    table.cell(ui, 0, 1, "RSI", text_color = color.gray), table.cell(ui, 1, 1, str.tostring(w1/total_w * 100, "#.#") + "%", bgcolor = s1 > 0 ? color.green : color.red)
    table.cell(ui, 0, 2, "MACD", text_color = color.gray), table.cell(ui, 1, 2, str.tostring(w2/total_w * 100, "#.#") + "%", bgcolor = s2 > 0 ? color.green : color.red)
    table.cell(ui, 0, 3, "EMA", text_color = color.gray), table.cell(ui, 1, 3, str.tostring(w3/total_w * 100, "#.#") + "%", bgcolor = s3 > 0 ? color.green : color.red)

// 7. 物理背景規訓
bgcolor(vote_score > limit ? color.new(color.green, 90) : vote_score < -limit ? color.new(color.red, 90) : na)
