//@version=6
strategy("TN Sovereign Donchian Breakout v6", overlay=true, pyramiding=0, initial_capital=100000, commission_type=strategy.commission.percent, commission_value=0.05)

// ------------------------------------------------------------
// 🚀 CORE PHILOSOPHY: DONCHIAN BREAKOUT & CAUSAL FILTERING
// Captures structural volatility breakouts based on N-period 
// price channels, filtered by macro trend and volume conviction.
// Version: v26.0414.1200 [CST]
// ------------------------------------------------------------

// ── Inputs ───────────────────────────────────────────────────────────────────
groupDonchian = "Donchian Channel Settings"
donchianLen   = input.int(20, "Channel Length", minval=1, group=groupDonchian)
useVolume     = input.bool(true, "Enable Volume Conviction", group=groupDonchian)

groupCausal   = "Causal Filter (Sovereignty)"
useHTF        = input.bool(true, "Enable HTF Trend Filter", group=groupCausal)
htfTF         = input.timeframe("240", "HTF Timeframe", group=groupCausal)
htfLen        = input.int(50, "HTF EMA Length", group=groupCausal)

groupRisk     = "Sovereign Risk Management"
riskPct       = input.float(1.0, "Risk % Per Trade", minval=0.1, step=0.1, group=groupRisk)
atrLen        = input.int(14, "ATR Length", group=groupRisk)
slMult        = input.float(1.5, "Stop Loss (ATR Mult)", group=groupRisk)
tpMult        = input.float(3.0, "Take Profit (ATR Mult)", group=groupRisk)

// ── Calculations ─────────────────────────────────────────────────────────────
upperBand = ta.highest(high, donchianLen)[1]
lowerBand = ta.lowest(low, donchianLen)[1]
midLine   = (upperBand + lowerBand) / 2

atrVal = ta.atr(atrLen)
volAvg = ta.sma(volume, 20)

// HTF Causal Anchor
float htfEma = request.security(syminfo.tickerid, htfTF, ta.ema(close, htfLen)[1], lookahead=barmerge.lookahead_on)
bool isBullishRegime = not useHTF or close > htfEma
bool isBearishRegime = not useHTF or close < htfEma

// ── Execution Logic ──────────────────────────────────────────────────────────
longBreakout  = ta.crossover(close, upperBand)
shortBreakout = ta.crossunder(close, lowerBand)

// Entry Conditions with Conviction
longEntry  = longBreakout and isBullishRegime and (not useVolume or volume > volAvg)
shortEntry = shortBreakout and isBearishRegime and (not useVolume or volume > volAvg)

// Position Sizing
riskAmount = strategy.equity * (riskPct / 100)
stopDist   = atrVal * slMult
qty = stopDist > 0 ? riskAmount / stopDist : 0.0

if longEntry
    strategy.entry("Sovereign Long", strategy.long, qty=qty, comment="UpperBreak")
    strategy.exit("Exit Long", "Sovereign Long", stop=close - stopDist, limit=close + atrVal * tpMult)

if shortEntry
    strategy.entry("Sovereign Short", strategy.short, qty=qty, comment="LowerBreak")
    strategy.exit("Exit Short", "Sovereign Short", stop=close + stopDist, limit=close - atrVal * tpMult)

// ── Visuals ──────────────────────────────────────────────────────────────────
p1 = plot(upperBand, color=color.new(color.green, 50), title="Donchian Upper")
p2 = plot(lowerBand, color=color.new(color.red, 50), title="Donchian Lower")
fill(p1, p2, color=color.new(color.gray, 90), title="Channel Fill")
plot(htfEma, color=color.new(color.blue, 30), linewidth=2, title="Causal Anchor")

// Dashboard
var table tb = table.new(position.top_right, 2, 2, border_width=1)
if barstate.isconfirmed
    table.cell(tb, 0, 0, "Regime", bgcolor=color.black, text_color=color.white)
    table.cell(tb, 1, 0, isBullishRegime ? "BULLISH" : "BEARISH", bgcolor=isBullishRegime ? color.green : color.red, text_color=color.white)
    table.cell(tb, 0, 1, "Sovereignty", bgcolor=color.black, text_color=color.white)
    table.cell(tb, 1, 1, "ACTIVE", bgcolor=color.blue, text_color=color.white)
