//@version=6
// TeleNexus Sovereign: Fakeout-Confirmed Strategy [v26.0502.0830]
// 精神繼承：Ugur Pala (Fakeout-Confirmed 4-Filter Layer)
// 規訓目標：主權級信號過濾與因果對位
// 
// 核心邏輯：
// 1. 因果密度 F1 (量能)：確認機構參與度，過濾散戶噪聲。
// 2. 趨勢共振 F2 (HTF)：確保路徑對齊大週期引力。
// 3. 穩定性審計 F3 (K線確認)：訊號產生後需經過指定數量 K 線驗證。
// 4. 波動率門檻 F4 (ATR)：確保物理位移具備統計顯著性，排除盤整磨損。

strategy("TnSovereignFakeoutConfirmedV6",
     overlay            = true,
     initial_capital    = 10000,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 10,
     commission_type    = strategy.commission.percent,
     commission_value   = 0.05,
     slippage           = 1)

// ── 規訓參數 ───────────────────────────────────────────────────────────────
group_strat = "核心規訓 / Core Regulation"
fastLen     = input.int(12,    "快速因果長度", minval=1, group=group_strat)
slowLen     = input.int(26,    "慢速因果長度", minval=1, group=group_strat)
atrLen      = input.int(14,    "ATR 波動長度", minval=1, group=group_strat)
slMult      = input.float(1.5, "止損倍數 (ATR)", step=0.1, group=group_strat)
tpMult      = input.float(3.0, "止盈倍數 (ATR)", step=0.1, group=group_strat)

group_f1    = "F1: 機構量能過濾 / Institutional Volume"
useVol      = input.bool(true, "啟用量能審計", group=group_f1)
volLen      = input.int(20,    "量能平均長度", group=group_f1)
volMult     = input.float(1.8, "量能突發權重", group=group_f1)

group_f2    = "F2: 跨域路徑對齊 / HTF Alignment"
useHTF      = input.bool(true, "啟用高時區對齊", group=group_f2)
htfTF       = input.string("240", "高時區尺度", options=["60","120","240","D"], group=group_f2)
htfLen      = input.int(50,    "HTF 趨勢長度", group=group_f2)

group_f3    = "F3: 穩定性審計 / Stability Audit"
useBar      = input.bool(true, "啟用 K 線確認", group=group_f3)
barConf     = input.int(2,     "確認 K 線數量", minval=1, maxval=5, group=group_f3)

// ── 因果運算 ───────────────────────────────────────────────────────────────
float fastEma = ta.ema(close, fastLen)
float slowEma = ta.ema(close, slowLen)
float atrVal  = ta.atr(atrLen)
float volAvg  = ta.sma(volume, volLen)

// 使用 request.security 獲取高時區趨勢，對齊物理時間
float htfEma = request.security(syminfo.tickerid, htfTF, ta.ema(close, htfLen)[1], lookahead=barmerge.lookahead_on)

// ── 四極過濾規訓 ──────────────────────────────────────────────────────────────
bool f1_vol   = not useVol or volume > volAvg * volMult
bool f2_htfL  = not useHTF or close > htfEma
bool f2_htfS  = not useHTF or close < htfEma
bool f4_noise = math.abs(close - close[1]) > atrVal * 0.2 // 基本波動率過濾

// ── 信號演化 ─────────────────────────────────────────────────────────────────
bool rawLong  = ta.crossover(fastEma, slowEma)
bool rawShort = ta.crossunder(fastEma, slowEma)

var int barCountL = -1
var int barCountS = -1

if rawLong
    barCountL := 0
if rawShort
    barCountS := 0

if barCountL >= 0 and barCountL < barConf
    barCountL += 1
if barCountS >= 0 and barCountS < barConf
    barCountS += 1

bool barConfL = not useBar or (barCountL == barConf and close > slowEma)
bool barConfS = not useBar or (barCountS == barConf and close < slowEma)

// 最終因果合成
bool longEntry  = (useBar ? barConfL : rawLong) and f1_vol and f2_htfL and f4_noise
bool shortEntry = (useBar ? barConfS : rawShort) and f1_vol and f2_htfS and f4_noise

// ── 執行即規訓 ───────────────────────────────────────────────────────────────
if longEntry and strategy.position_size == 0
    log.info("[SOVEREIGN_LONG] 因果密度達標，執行路徑對位入長")
    strategy.entry("SovereignLong", strategy.long, comment="IN_LONG")
    strategy.exit("LongExit", "SovereignLong", 
         stop=close - slMult * atrVal, 
         limit=close + tpMult * atrVal, 
         comment_loss="SL_HIT", 
         comment_profit="TP_HIT")

if shortEntry and strategy.position_size == 0
    log.info("[SOVEREIGN_SHORT] 因果密度達標，執行路徑對位入短")
    strategy.entry("SovereignShort", strategy.short, comment="IN_SHORT")
    strategy.exit("ShortExit", "SovereignShort", 
         stop=close + slMult * atrVal, 
         limit=close - tpMult * atrVal, 
         comment_loss="SL_HIT", 
         comment_profit="TP_HIT")

// ── 視覺化呈現 ───────────────────────────────────────────────────────────────
plot(fastEma, "快速因果線", color.new(color.aqua, 20))
plot(slowEma, "慢速因果線", color.new(color.orange, 20), linewidth=2)
plot(htfEma,  "主權趨勢線", color.new(color.gray, 50), style=plot.style_stepline)

plotshape(longEntry,  "因果多頭", shape.triangleup,   location.belowbar, color.lime, size=size.normal)
plotshape(shortEntry, "因果空頭", shape.triangledown,  location.abovebar, color.red,  size=size.normal)

// 物理時間與版本標註
var table info = table.new(position.bottom_right, 1, 1)
if barstate.islast
    table.cell(info, 0, 0, "TeleNexus v26.0502.0830\nSovereign Fakeout Confirmed", bgcolor=color.new(color.black, 80), text_color=color.white, text_size=size.small)
