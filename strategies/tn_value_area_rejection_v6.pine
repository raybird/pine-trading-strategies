//@version=6
// TeleNexus Sovereign: Value Area Rejection v6 [v26.0530.0630]
// Spirit Inheritance: PineGen-AI Value Area Rejection Strategy
// Goal: Exploiting equilibrium rejection dynamics via value area boundaries
//
// Logic Matrix:
// 1. Value Area Engine: SMA-based fair value midpoint with ATR volatility bands
// 2. Rejection Detection: Price enters value zone then rejects with confirmation
// 3. Causal Audit: Volume confirmation + momentum alignment on rejection
// 4. Dynamic Risk: ATR-scaled stops with structure-aware exit placement
// 5. Regime Filter: Suppress trades during extreme expansion events

strategy("Tn Value Area Rejection v6",
     shorttitle         = "Tn_VA_Rej_V6",
     overlay            = true,
     initial_capital    = 100000,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 10,
     commission_type    = strategy.commission.percent,
     commission_value   = 0.04,
     slippage           = 1)

// ── Regulation Parameters ───────────────────────────────────────────────────
group_va     = "▼ Value Area Core"
valueLen     = input.int(50, "Value Area Length", minval=20, maxval=200)
bandMult     = input.float(1.0, "Value Area Width (ATR)", minval=0.5, maxval=3.0, step=0.1)

group_atr    = "▼ Volatility & Risk"
atrLen       = input.int(14, "ATR Length", minval=5, maxval=50)
stopMult     = input.float(1.5, "Stop ATR Multiplier", minval=0.5, maxval=3.0, step=0.1)
rr           = input.float(2.5, "Risk:Reward Ratio", minval=1.0, maxval=5.0, step=0.5)

group_filter = "▼ Causal Filters"
useVolFilter = input.bool(true, "Volume Confirmation")
volMult      = input.float(1.3, "Volume Multiplier", minval=0.8, maxval=3.0, step=0.1)
useMomoCheck = input.bool(true, "Momentum Alignment")
rejectBars   = input.int(2, "Rejection Confirmation Bars", minval=1, maxval=5)

// ── Value Area Components ───────────────────────────────────────────────────
float basis   = ta.sma(close, valueLen)
float atrVal  = ta.atr(atrLen)
float upperVA = basis + atrVal * bandMult
float lowerVA = basis - atrVal * bandMult

// ── Causal Audit Engine ─────────────────────────────────────────────────────
// Rejection detection: price enters value zone then closes back out
bool bearishReject = high > upperVA and close < upperVA
bool bullishReject = low < lowerVA and close > lowerVA

// Confirmed rejection with momentum alignment
bool bearishRejectConfirmed = bearishReject and (not useMomoCheck or close < close[1])
bool bullishRejectConfirmed = bullishReject and (not useMomoCheck or close > close[1])

// Volume confirmation
float volAvg  = ta.sma(volume, 20)
bool volSurge = volume > volAvg * volMult

// Regime filter — avoid extreme volatility
float atrPercent = atrVal / close * 100
bool regimeOk    = atrPercent < 3.0

// ── Execution Suture ────────────────────────────────────────────────────────
bool longEntry = bullishRejectConfirmed and (not useVolFilter or volSurge) and regimeOk and barstate.isconfirmed
bool shortEntry = bearishRejectConfirmed and (not useVolFilter or volSurge) and regimeOk and barstate.isconfirmed

if longEntry and strategy.position_size == 0
    log.info("[SOVEREIGN_VA_REJ_LONG] Value={0,#.##} ATR={1,#.##}. Suturing.", basis, atrVal)
    strategy.entry("Long", strategy.long, comment="VA_REJ_BULL")
    strategy.exit("ExitL", "Long", stop=close - atrVal * stopMult, limit=close + atrVal * stopMult * rr)

if shortEntry and strategy.position_size == 0
    log.info("[SOVEREIGN_VA_REJ_SHORT] Value={0,#.##} ATR={1,#.##}. Suturing.", basis, atrVal)
    strategy.entry("Short", strategy.short, comment="VA_REJ_BEAR")
    strategy.exit("ExitS", "Short", stop=close + atrVal * stopMult, limit=close - atrVal * stopMult * rr)

// ── Visuals ──────────────────────────────────────────────────────────────────
plot(basis, "Value Mid", color.new(color.orange, 30), 2)
plot(upperVA, "Upper VA", color.new(color.red, 40), 1)
plot(lowerVA, "Lower VA", color.new(color.green, 40), 1)

plotshape(longEntry, "Long", shape.triangleup, location.belowbar, color.new(color.lime, 0), size=size.small)
plotshape(shortEntry, "Short", shape.triangledown, location.abovebar, color.new(color.red, 0), size=size.small)

bgcolor(longEntry ? color.new(color.green, 85) : shortEntry ? color.new(color.red, 85) : na)

// Sovereign Dashboard
var table info = table.new(position.top_right, 2, 6, frame_color=color.gray, frame_width=1)
if barstate.islast
    table.cell(info, 0, 0, "Sovereign VA Rej", bgcolor=color.new(color.black, 80), text_color=color.white)
    table.cell(info, 1, 0, "v26.0530", bgcolor=color.new(color.black, 80), text_color=color.white)
    table.cell(info, 0, 1, "Value Mid", text_color=color.white)
    table.cell(info, 1, 1, str.tostring(basis, "#.##"), text_color=color.orange)
    table.cell(info, 0, 2, "Upper VA", text_color=color.white)
    table.cell(info, 1, 2, str.tostring(upperVA, "#.##"), text_color=color.red)
    table.cell(info, 0, 3, "Lower VA", text_color=color.white)
    table.cell(info, 1, 3, str.tostring(lowerVA, "#.##"), text_color=color.lime)
    table.cell(info, 0, 4, "Regime", text_color=color.white)
    table.cell(info, 1, 4, regimeOk ? "NORMAL" : "EXTREME", text_color=regimeOk ? color.lime : color.gray)
    table.cell(info, 0, 5, "Physical Time", text_color=color.white)
    table.cell(info, 1, 5, "05.30.0630", text_color=color.white)