//@version=6
strategy("TN Sovereign Fibonacci v6", overlay=true, initial_capital=100000, currency=currency.USD, commission_type=strategy.commission.percent, commission_value=0.05)

// ------------------------------------------------------------
// 🚀 CORE PHILOSOPHY: SOVEREIGN FIBONACCI RETRACEMENT
// This strategy utilizes multi-period Fibonacci levels combined 
// with a "Time-Window Anchor" to capture precise pullbacks 
// in trending regimes.
// Version: v26.0427.0630 [CST]
// ------------------------------------------------------------

// ── Inputs ───────────────────────────────────────────────────────────────────
groupFib    = "Fibonacci Parameters"
fibLevel    = input.float(0.382, "Fibonacci Level", options=[0.236, 0.382, 0.5, 0.618, 0.786], group=groupFib)
lookback    = input.int(100, "HL Lookback Period", minval=10, group=groupFib)
entryHour   = input.int(8, "Causal Entry Hour (CST)", minval=0, maxval=23, group=groupFib)

groupCausal = "Sovereign Trend Filter"
maLen       = input.int(200, "Trend Filter EMA", group=groupCausal)

groupRisk   = "Dynamic Risk Architecture"
riskPct     = input.float(1.0, "Risk % Per Trade", minval=0.1, step=0.1, group=groupRisk)
slMult      = input.float(2.0, "Stop Loss (ATR Mult)", group=groupRisk)
tpMult      = input.float(4.0, "Take Profit (ATR Mult)", group=groupRisk)

// ── Calculations ─────────────────────────────────────────────────────────────
highestPrice = ta.highest(high, lookback)
lowestPrice  = ta.lowest(low, lookback)
priceRange   = highestPrice - lowestPrice

fibLongPrice = lowestPrice + (priceRange * fibLevel)
fibShortPrice = highestPrice - (priceRange * fibLevel)

emaTrend = ta.ema(close, maLen)
atr = ta.atr(14)

// Causal Alignment: Time + Trend + Level
isTargetTime = hour == entryHour
isBullish = close > emaTrend
isBearish = close < emaTrend

longCondition  = isTargetTime and isBullish and close <= fibLongPrice
shortCondition = isTargetTime and isBearish and close >= fibShortPrice

// ── Sovereign Execution ──────────────────────────────────────────────────────
float riskAmt = strategy.equity * (riskPct / 100)
float stopDist = atr * slMult
float qty = stopDist > 0 ? riskAmt / stopDist : 0.0

if longCondition and strategy.position_size == 0
    strategy.entry("Fib Long", strategy.long, qty=qty, comment="FibPullback")
    strategy.exit("LX", "Fib Long", stop=close - stopDist, limit=close + atr * tpMult)

if shortCondition and strategy.position_size == 0
    strategy.entry("Fib Short", strategy.short, qty=qty, comment="FibPullback")
    strategy.exit("SX", "Fib Short", stop=close + stopDist, limit=close - atr * tpMult)

// ── Visuals ──────────────────────────────────────────────────────────────────
plot(highestPrice, "H", color.new(color.gray, 80))
plot(lowestPrice, "L", color.new(color.gray, 80))
plot(fibLongPrice, "Fib Long Level", color.new(color.green, 40), 2, plot.style_linebr)
plot(fibShortPrice, "Fib Short Level", color.new(color.red, 40), 2, plot.style_linebr)
plot(emaTrend, "Trend Anchor", color.new(color.blue, 60), 1)

plotshape(longCondition, "Long", shape.triangleup, location.belowbar, color.green, size=size.small)
plotshape(shortCondition, "Short", shape.triangledown, location.abovebar, color.red, size=size.small)
