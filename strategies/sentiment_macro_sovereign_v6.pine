//@version=6
// @description: TeleNexus 情緒宏觀主權過濾策略 - v6 核心實作
// @author: TeleNexus AI
// @strategy: 透過 request.seed() 注入外部情緒數據（如 Santiment 或 SSO 指標），作為 EMA 交叉策略的物理過濾器。

strategy("TN Sentiment Macro Sovereign v6", overlay = true, initial_capital = 10000, default_qty_type = strategy.percent_of_equity, default_qty_value = 10)

// 1. 利用 v6 Enum 定義規訓模式
enum FilterRegime
    Aggressive = "High Sensitivity"
    Balanced   = "Standard Causal"
    Sovereign  = "Full Protective"

FilterRegime regime = input.enum(FilterRegime.Balanced, "因果過濾規訓")

// 2. 獲取情緒宏觀數據 (request.seed)
// 範例數據源：SEED_CRYPTO_SANTIMENT，符號：BTC_SOCIAL_VOLUME
float rawSentiment = request.seed("SEED_CRYPTO_SANTIMENT", "BTC_SOCIAL_VOLUME", close)
float smoothSentiment = ta.sma(nz(rawSentiment, 50.0), 14)

// 3. 宏觀主權過濾邏輯
bool isSentimentBullish = smoothSentiment > 60.0
bool isSentimentBearish = smoothSentiment < 40.0

// 4. 技術面邏輯
emaFast = ta.ema(close, 12)
emaSlow = ta.ema(close, 26)
bool techLong = ta.crossover(emaFast, emaSlow)
bool techShort = ta.crossunder(emaFast, emaSlow)

// 5. [主權注入] 集成執行條件
bool canLong = techLong and (regime == FilterRegime.Aggressive or isSentimentBullish)
bool canShort = techShort and (regime == FilterRegime.Aggressive or isSentimentBearish)

// 6. 執行規訓與物理日誌
if canLong
    strategy.entry("Long", strategy.long, comment = "Macro Sentiment Long")
    log.info("Sovereign Entry [Long]: Sentiment={0,number,#.##}", smoothSentiment)

if canShort
    strategy.entry("Short", strategy.short, comment = "Macro Sentiment Short")
    log.info("Sovereign Entry [Short]: Sentiment={0,number,#.##}", smoothSentiment)

if (strategy.position_size > 0 and techShort) or (strategy.position_size < 0 and techLong)
    strategy.close_all(comment = "Causal Flip Exit")

// 7. 視覺化地板
bgcolor(isSentimentBullish ? color.new(color.green, 90) : isSentimentBearish ? color.new(color.red, 90) : na)
plot(emaFast, color = color.blue)
plot(emaSlow, color = color.orange)

// 狀態儀表板 (v6 Table API)
var table dash = table.new(position.top_right, 2, 2, bgcolor = color.new(color.black, 30), border_width = 1)
if barstate.islast
    table.cell(dash, 0, 0, "Sentiment", text_color = color.white)
    table.cell(dash, 1, 0, str.tostring(smoothSentiment, "#.##"), text_color = color.yellow)
    table.cell(dash, 0, 1, "Regime", text_color = color.white)
    table.cell(dash, 1, 1, str.tostring(regime), text_color = color.aqua)
