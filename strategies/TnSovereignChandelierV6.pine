//@version=6
strategy("Tn Sovereign Chandelier v6 [v26.0420.1206]",
    shorttitle         = "TN_CHAN_v26",
    overlay            = true,
    initial_capital    = 100000,
    default_qty_type   = strategy.percent_of_equity,
    default_qty_value  = 10,
    commission_type    = strategy.commission.percent,
    commission_value   = 0.05,
    slippage           = 2,
    process_orders_on_close = true)

// =====================================================
// MODULE 1: SOVEREIGN VOLATILITY CORE
// Chandelier Exit Logic (Ugur Pala adaptation)
// =====================================================

groupCE = "🕯️ 吊燈規訓 (Chandelier Settings)"
atrLen  = input.int(22,   "ATR 週期", minval=1, group=groupCE)
atrMult = input.float(3.0, "ATR 倍數", step=0.1, group=groupCE)

float atrVal = ta.atr(atrLen)
float longStop  = ta.highest(high, atrLen) - atrMult * atrVal
float shortStop = ta.lowest(low, atrLen) + atrMult * atrVal

var float chandLong  = na
var float chandShort = na
var int   direction  = 1

chandLong  := longStop > nz(chandLong[1], longStop) ? longStop : nz(chandLong[1], longStop)
chandShort := shortStop < nz(chandShort[1], shortStop) ? shortStop : nz(chandShort[1], shortStop)

if close > nz(chandShort[1], chandShort)
    direction := 1
if close < nz(chandLong[1], chandLong)
    direction := -1

// =====================================================
// MODULE 2: CAUSAL AUDIT LAYERS
// =====================================================

groupAudit = "🛡️ 因果審計 (Audit Layers)"
useRegime  = input.bool(true, "啟用 200 EMA 環境過濾", group=groupAudit)
regimeLen  = input.int(200, "環境 EMA 週期", group=groupAudit)
useVol     = input.bool(true, "啟用成交量審計", group=groupAudit)

float regimeEma = ta.ema(close, regimeLen)
bool isBullRegime = not useRegime or close > regimeEma
bool isBearRegime = not useRegime or close < regimeEma

volAvg = ta.sma(volume, 20)
bool volPass = not useVol or volume > volAvg * 1.2

// =====================================================
// MODULE 3: SIGNAL SYNTHESIS & EXECUTION
// =====================================================

bool longEntry  = ta.change(direction) > 0 and isBullRegime and volPass
bool shortEntry = ta.change(direction) < 0 and isBearRegime and volPass

if longEntry and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, comment="CE-L")

if shortEntry and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, comment="CE-S")

// =====================================================
// MODULE 4: SOVEREIGN HUD
// =====================================================

var table hud = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 70), border_width=1)
if barstate.isconfirmed
    table.cell(hud, 0, 0, "◈ SOVEREIGN", text_color=color.white, bgcolor=color.new(color.navy, 20))
    table.cell(hud, 1, 0, "STATUS", text_color=color.white, bgcolor=color.new(color.navy, 20))
    
    table.cell(hud, 0, 1, "Direction", text_color=color.gray)
    table.cell(hud, 1, 1, direction == 1 ? "BULL" : "BEAR", text_color=direction == 1 ? color.lime : color.red)
    
    table.cell(hud, 0, 2, "Regime", text_color=color.gray)
    table.cell(hud, 1, 2, isBullRegime ? "LONG-BIAS" : "SHORT-BIAS", text_color=color.yellow)
    
    table.cell(hud, 0, 3, "Vol Audit", text_color=color.gray)
    table.cell(hud, 1, 3, volPass ? "PASS" : "LOW-E", text_color=volPass ? color.lime : color.orange)
    
    table.cell(hud, 0, 4, "Version", text_color=color.gray)
    table.cell(hud, 1, 4, "v26.0420.1206", text_color=color.gray)

// Visuals
plot(direction == 1 ? chandLong : na, "Long Stop", color.new(color.lime, 0), 2, style=plot.style_linebr)
plot(direction == -1 ? chandShort : na, "Short Stop", color.new(color.red, 0), 2, style=plot.style_linebr)
plot(regimeEma, "Regime Floor", color.new(color.gray, 60), 1)
plotshape(longEntry, "Long", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(shortEntry, "Short", shape.triangledown, location.abovebar, color.red, size=size.small)
