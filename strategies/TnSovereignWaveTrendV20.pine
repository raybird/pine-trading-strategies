//@version=6
// TeleNexus Sovereign: WaveTrend Thermodynamic Equilibrium [v26.0510.1838]
// Spirit Inheritance: WavesUnchained WaveTrend & Kronos V20 Geometric Thermodynamics
// Goal: Momentum Reversal via Thermodynamic Expansion Sensing
//
// Logic Chain:
// 1. WaveTrend Oscillator: Smoothing price deviation to identify overextension.
// 2. V20 Thermodynamic Audit: Calculating 'Free Energy' vs 'Fractal Entropy'.
// 3. Adiabatic Expansion: Sensing ordered growth/reversal (High Energy, Low Entropy).
// 4. Directional Suture: Cross-audit between momentum and thermodynamic phase.

strategy("TnSovereignWaveTrendV20",
     shorttitle         = "TnS_WT_V20",
     overlay            = true,
     initial_capital    = 100000,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 10,
     commission_type    = strategy.commission.percent,
     commission_value   = 0.05,
     slippage           = 1)

// ── Regulation Parameters ───────────────────────────────────────────────────
group_wt    = "▼ WaveTrend Engine"
wt_n1       = input.int(10, "Channel Length")
wt_n2       = input.int(21, "Average Length")
wt_ob       = input.float(60, "Overbought Level")
wt_os       = input.float(-60, "Oversold Level")

group_v20   = "▼ V20 Thermodynamic Gating"
min_energy  = input.float(1.6, "Min Free Energy", minval=0.5, maxval=5.0)
max_entropy = input.float(1.35, "Max Fractal Entropy (D)", minval=1.0, maxval=2.0)

group_risk  = "▼ Risk Management"
sl_atr_mult = input.float(2.0, "SL ATR Multiple")
tp_rr       = input.float(2.8, "Target R:R")

// ── Causal Components ───────────────────────────────────────────────────────
float atr = ta.atr(14)

// 1. WaveTrend Core (Simplified for Strategy Efficiency)
float ap = hlc3
float esa = ta.ema(ap, wt_n1)
float d = ta.ema(math.abs(ap - esa), wt_n1)
float ci = (ap - esa) / (0.015 * d)
float tci = ta.ema(ci, wt_n2)

float wt1 = tci
float wt2 = ta.sma(wt1, 4)

bool wt_cross_up = ta.crossover(wt1, wt2)
bool wt_cross_dn = ta.crossunder(wt1, wt2)

// 2. V20 Thermodynamic Audit (TeleNexus Core)
f_v20_audit(int len) =>
    float displacement = math.abs(close - close[len])
    float path_length = 0.0
    for i = 0 to len - 1
        path_length += math.abs(close[i] - close[i+1])
    float fd = path_length / (displacement || 1)
    
    float range_avg = ta.sma(high - low, len)
    float price_work = math.abs(close - open) / (range_avg || 1)
    float free_energy = price_work / (fd + 0.1)
    [free_energy, fd]

[v20_energy, v20_entropy] = f_v20_audit(20)
bool thermo_pass = v20_energy > min_energy and v20_entropy < max_entropy

// ── Execution Logic ─────────────────────────────────────────────────────────
bool long_entry  = wt_cross_up and wt1 < wt_os and thermo_pass and barstate.isconfirmed
bool short_entry = wt_cross_dn and wt1 > wt_ob and thermo_pass and barstate.isconfirmed

if long_entry and strategy.position_size == 0
    log.info("[SOVEREIGN_WT_LONG] Energy={0,number,#.##} Entropy={1,number,#.##}. Expanding.", v20_energy, v20_entropy)
    strategy.entry("Long", strategy.long, comment="WT_OS_RESONANCE")
    strategy.exit("ExitL", "Long", stop=close - atr * sl_atr_mult, limit=close + atr * sl_atr_mult * tp_rr)

if short_entry and strategy.position_size == 0
    log.info("[SOVEREIGN_WT_SHORT] Energy={0,number,#.##} Entropy={1,number,#.##}. Expanding.", v20_energy, v20_entropy)
    strategy.entry("Short", strategy.short, comment="WT_OB_RESONANCE")
    strategy.exit("ExitS", "Short", stop=close + atr * sl_atr_mult, limit=close - atr * sl_atr_mult * tp_rr)

// ── Visuals ──────────────────────────────────────────────────────────────────
plot(wt1, "WT1 (Causal)", color.new(color.aqua, 0), display=display.none)
plot(wt2, "WT2 (Temporal)", color.new(color.orange, 0), display=display.none)

bgcolor(long_entry ? color.new(color.green, 85) : short_entry ? color.new(color.red, 85) : na)

// HUD
var table info = table.new(position.top_right, 2, 5, frame_color=color.gray, frame_width=1)
if barstate.islast
    table.cell(info, 0, 0, "Sovereign WT", bgcolor=color.new(color.black, 80), text_color=color.white)
    table.cell(info, 1, 0, "v26.0510", bgcolor=color.new(color.black, 80), text_color=color.white)
    table.cell(info, 0, 1, "Free Energy", text_color=color.white)
    table.cell(info, 1, 1, str.tostring(v20_energy, "#.##"), bgcolor=v20_energy > min_energy ? color.new(color.green, 50) : color.new(color.red, 50))
    table.cell(info, 0, 2, "Fractal D", text_color=color.white)
    table.cell(info, 1, 2, str.tostring(v20_entropy, "#.##"), bgcolor=v20_entropy < max_entropy ? color.new(color.aqua, 50) : color.new(color.orange, 50))
    table.cell(info, 0, 3, "WT Value", text_color=color.white)
    table.cell(info, 1, 3, str.tostring(wt1, "#.#"), text_color=wt1 < wt_os ? color.lime : wt1 > wt_ob ? color.red : color.white)
    table.cell(info, 0, 4, "Physical Time", text_color=color.white)
    table.cell(info, 1, 4, "18.3814", text_color=color.white)
