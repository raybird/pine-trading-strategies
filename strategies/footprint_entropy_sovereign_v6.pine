//@version=6
// @description: TeleNexus 足跡熵矩陣累積策略 - v6 核心實作
// @author: TeleNexus AI (Core v2.9.0)
// @strategy: 利用 v6 原生 footprint 計算香農熵 (Shannon Entropy)，識別成交量集中度，結合 CVD 與 POC 實現主權級趨勢捕捉。
// [[MEMORY_INTENT:{"level":"rule","confidence":"high","reason":"Implementing Footprint Entropy logic as a core causal sensing standard.","summary":"Established Footprint Entropy Matrix as the primary sensing mechanism for identifying institutional accumulation zones."}]]

strategy("TN Footprint Entropy Sovereign v6", overlay = true, initial_capital = 10000, default_qty_type = strategy.percent_of_equity, default_qty_value = 15)

// 1. 利用 v6 Enum 定義感知規訓
enum EntropyRegime
    Sovereign = 0.7 // 強制有序 (低熵)
    Standard  = 0.8 // 標準因果
    Adaptive  = 0.9 // 靈活感知

EntropyRegime regime = input.enum(EntropyRegime.Standard, "能量感知規訓等級")
int entropyLen       = input.int(20, "熵矩陣回顧長度")

// 2. 獲取 v6 足跡物理對象
fp = request.footprint(10, 70)[1]

// 3. 核心因果演算：Shannon Entropy (能量有序度)
method get_entropy(footprint _fp) =>
    float _ent = 0.0
    if not na(_fp)
        volume_row[] _rows = _fp.rows()
        float _tVol = _fp.total_volume()
        if _tVol > 0
            for _r in _rows
                float _rVol = _r.volume()
                if _rVol > 0
                    float _p = _rVol / _tVol
                    _ent -= _p * math.log(_p)
    _ent

currentEntropy = fp.get_entropy()
avgEntropy     = ta.sma(currentEntropy, entropyLen)
float thresh   = switch regime
    EntropyRegime.Sovereign => 0.7
    EntropyRegime.Standard  => 0.8
    EntropyRegime.Adaptive  => 0.9

// 物理邊界檢查：低熵代表能量高度集中 (機構活動)
bool isOrdered = currentEntropy < (avgEntropy * thresh)

// 4. 趨勢與動量對位 (CVD & POC)
var float cvd = 0.0
if not na(fp)
    cvd += fp.delta()

pocPrice = not na(fp) ? fp.poc().price_low() : na
bool accumulation = ta.change(cvd) > 0
bool distribution = ta.change(cvd) < 0

// 5. 執行規訓 (v6 Explicit Booleans)
if isOrdered and accumulation and close > pocPrice
    strategy.entry("Long_Ent", strategy.long, comment = str.format("LowEnt Acc: {0,number,#.##}", currentEntropy))

if isOrdered and distribution and close < pocPrice
    strategy.entry("Short_Ent", strategy.short, comment = str.format("LowEnt Dist: {0,number,#.##}", currentEntropy))

// 6. 視覺化：能量狀態 HUD
var table hud = table.new(position.top_right, 2, 3, bgcolor = color.new(color.black, 30), border_width = 1)
if barstate.islast
    table.cell(hud, 0, 0, "Entropy", text_color = color.white)
    table.cell(hud, 1, 0, str.tostring(currentEntropy, "#.##"), bgcolor = isOrdered ? color.green : color.red)
    table.cell(hud, 0, 1, "CVD Delta", text_color = color.white)
    table.cell(hud, 1, 1, str.tostring(ta.change(cvd), "#.##"), text_color = accumulation ? color.lime : color.orange)
    table.cell(hud, 0, 2, "Regime", text_color = color.white)
    table.cell(hud, 1, 2, str.tostring(regime), text_color = color.yellow)

plot(pocPrice, "POC Line", color.new(color.orange, 50), 2, plot.style_linebr)
bgcolor(isOrdered ? color.new(color.blue, 95) : na)

// 7. 物理退出規訓 (ATR 追蹤)
atr = ta.atr(14)
if strategy.position_size > 0
    strategy.exit("Exit", "Long_Ent", stop = close - atr * 2, limit = close + atr * 4)
if strategy.position_size < 0
    strategy.exit("Exit", "Short_Ent", stop = close + atr * 2, limit = close - atr * 4)
