//@version=6
strategy("ZZC Market Structure Sovereign v6 [v26.0418.1802]",
     overlay=true,
     initial_capital=100000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=10,
     commission_type=strategy.commission.percent,
     commission_value=0.05,
     max_labels_count=500,
     max_lines_count=500)

// =====================================================
// MODULE 1: CAUSAL ZIGZAG SUBSTRATE
// =====================================================
groupZZ = "因果波段核心 (ZigZag)"
zzLen   = input.int(5, "Pivot 長度", minval=2, group=groupZZ)
zzAtr   = input.int(14, "ATR 週期", group=groupZZ)
zzMult  = input.float(2.0, "ATR 乘數", step=0.1, group=groupZZ)

// Non-repainting ZigZag (Simplified for Sovereign implementation)
atrVal = ta.atr(zzAtr)
ph = ta.pivothigh(high, zzLen, zzLen)
pl = ta.pivotlow(low, zzLen, zzLen)

var float lastPivotPrice = na
var int dir = 0 

if not na(ph)
    lastPivotPrice := ph
    dir := -1
if not na(pl)
    lastPivotPrice := pl
    dir := 1

// =====================================================
// MODULE 2: SOVEREIGN CORRIDORS (VOLATILITY)
// =====================================================
groupMS = "主權通道 (Structure)"
kcLen   = input.int(20, "KC 長度", group=groupMS)
kcMult  = input.float(1.5, "KC 乘數", group=groupMS)

emaBase = ta.ema(close, kcLen)
kcUpper = emaBase + atrVal * kcMult
kcLower = emaBase - atrVal * kcMult

// Market Regime Detection
inCorridor = close < kcUpper and close > kcLower
breakoutUp = ta.crossover(close, kcUpper)
breakoutDn = ta.crossunder(close, kcLower)

// =====================================================
// MODULE 3: EXECUTION & RISK規訓
// =====================================================
groupRisk = "主權風險管理"
slMult    = input.float(2.0, "止損 ATR 倍數", group=groupRisk)
tpMult    = input.float(4.0, "獲利 ATR 倍數", group=groupRisk)

// Entry Conditions based on ZZC logic
longTrigger  = dir == 1 and close > emaBase and inCorridor
shortTrigger = dir == -1 and close < emaBase and inCorridor

if longTrigger and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, comment="ZZC-UP")
    strategy.exit("L-Exit", "Long", stop=close - atrVal * slMult, limit=close + atrVal * tpMult)

if shortTrigger and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, comment="ZZC-DN")
    strategy.exit("S-Exit", "Short", stop=close + atrVal * slMult, limit=close - atrVal * tpMult)

// =====================================================
// MODULE 4: VISUALS & AUDIT
// =====================================================
plot(emaBase, "基準線", color.new(color.gray, 50))
fill(plot(kcUpper, color=color.new(color.blue, 80)), plot(kcLower, color=color.new(color.blue, 80)), color.new(color.blue, 95), title="主權隧道")

plotshape(longTrigger, "Long Signal", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(shortTrigger, "Short Signal", shape.triangledown, location.abovebar, color.red, size=size.small)

// Real-time Discipline Table
var table dt = table.new(position.top_right, 2, 3, bgcolor=color.new(color.black, 70), border_width=1)
if barstate.isconfirmed
    table.cell(dt, 0, 0, "Regime", text_color=color.white)
    table.cell(dt, 1, 0, close > emaBase ? "Bullish" : "Bearish", text_color=close > emaBase ? color.lime : color.red)
    table.cell(dt, 0, 1, "Structure", text_color=color.white)
    table.cell(dt, 1, 1, inCorridor ? "Inside" : "Expansion", text_color=inCorridor ? color.aqua : color.orange)
    table.cell(dt, 0, 2, "Version", text_color=color.gray)
    table.cell(dt, 1, 2, "v26.0418.1802", text_color=color.gray)
